---
/**
 * menu.astro — Fixed-price set menu page
 *
 * SSR: reads menu.json from src/data at request time (VPS/Node adapter).
 * Mobile-first: no hero, content immediately visible — designed for QR table use.
 * JSON-LD: Schema.org Menu with fixed-price Offer for SEO and AI crawlability.
 */

import fs from 'node:fs';
import Layout from '../layouts/Layout.astro';
import GarlandDivider from '../components/GarlandDivider.astro';
import menuFallback from '../data/menu.json';

// On VPS (SSR), read the live file written by n8n. Fall back to bundled data on Cloudflare.
let menu: typeof menuFallback = menuFallback;
const menuDataPath = process.env.MENU_DATA_PATH;
if (menuDataPath) {
  try { menu = JSON.parse(fs.readFileSync(`${menuDataPath}/menu.json`, 'utf-8')); } catch {}
}

// EU 14 major allergens — label, colour
const ALLERGENS: Record<string, { label: string; bg: string; text: string }> = {
  'gluten':       { label: 'Gluten',       bg: 'bg-amber-100',   text: 'text-amber-800'  },
  'lácteos':      { label: 'Lácteos',      bg: 'bg-sky-100',     text: 'text-sky-800'    },
  'huevo':        { label: 'Huevo',        bg: 'bg-yellow-100',  text: 'text-yellow-800' },
  'pescado':      { label: 'Pescado',      bg: 'bg-blue-100',    text: 'text-blue-800'   },
  'crustáceos':   { label: 'Crustáceos',   bg: 'bg-orange-100',  text: 'text-orange-800' },
  'moluscos':     { label: 'Moluscos',     bg: 'bg-violet-100',  text: 'text-violet-800' },
  'frutos secos': { label: 'Frutos secos', bg: 'bg-green-100',   text: 'text-green-800'  },
  'cacahuetes':   { label: 'Cacahuetes',   bg: 'bg-lime-100',    text: 'text-lime-800'   },
  'soja':         { label: 'Soja',         bg: 'bg-emerald-100', text: 'text-emerald-800'},
  'sulfitos':     { label: 'Sulfitos',     bg: 'bg-rose-100',    text: 'text-rose-800'   },
  'mostaza':      { label: 'Mostaza',      bg: 'bg-yellow-50',   text: 'text-yellow-700' },
  'sésamo':       { label: 'Sésamo',       bg: 'bg-stone-100',   text: 'text-stone-700'  },
  'apio':         { label: 'Apio',         bg: 'bg-teal-100',    text: 'text-teal-800'   },
  'altramuces':   { label: 'Altramuces',   bg: 'bg-pink-100',    text: 'text-pink-800'   },
};

const menuSchema = {
  "@context": "https://schema.org",
  "@type": "Menu",
  "name": `${menu.name} — Restaurante Porta D'irta`,
  "description": `Menú especial a precio fijo de ${menu.price}€ por persona. ${menu.priceNote}. Disponible: ${menu.available}.`,
  "url": "https://www.portadirta.com/menu",
  "inLanguage": "es",
  "offers": {
    "@type": "Offer",
    "price": menu.price.toFixed(2),
    "priceCurrency": "EUR",
    "description": menu.priceNote
  },
  "hasMenuSection": menu.sections.map(section => ({
    "@type": "MenuSection",
    "name": section.name,
    "description": section.note || undefined,
    "hasMenuItem": section.items.map(item => ({
      "@type": "MenuItem",
      "name": item.name,
      "description": item.description || undefined,
      ...(item.supplement ? {
        "offers": {
          "@type": "Offer",
          "price": (menu.price + item.supplement).toFixed(2),
          "priceCurrency": "EUR",
          "description": `+${item.supplement}€/pers. suplemento`
        }
      } : {})
    }))
  }))
};
---

<Layout
  title="Menú Especial — Restaurante"
  description={`Menú especial de ${menu.price}€ por persona en el restaurante Porta D'irta, Peñíscola. ${menu.priceNote}. Disponible ${menu.available}.`}
  ogImage="/assets/images/food-paella-wine.jpg"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(menuSchema)} />

  <!-- ── Page header ─────────────────────────────────────────────── -->
  <section class="bg-brand-blue pt-28 pb-12">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center flex flex-col items-center gap-4">
      <p class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">Restaurante Porta D'irta</p>
      <h1 class="font-display font-light italic text-5xl sm:text-6xl text-white leading-tight">
        {menu.name}
      </h1>
      <GarlandDivider light />

      <!-- Price badge -->
      <div class="flex flex-col items-center gap-1">
        <span class="font-display text-4xl text-brand-gold font-light">{menu.price.toFixed(0)}€</span>
        <span class="font-body text-white/60 text-sm">{menu.priceNote}</span>
      </div>

      {menu.available && (
        <p class="font-body text-xs uppercase tracking-[0.2em] text-brand-sand/70">
          Disponible: {menu.available}
        </p>
      )}
    </div>
  </section>

  <!-- ── Menu sections ───────────────────────────────────────────── -->
  <section class="bg-brand-cream py-12">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 flex flex-col gap-10">

      {menu.sections.map((section, i) => (
        <div>

          <!-- Section heading -->
          <div class="flex items-center gap-4 mb-5">
            <div class="flex items-center gap-3 shrink-0">
              <span class="font-body text-xs text-brand-gold uppercase tracking-widest">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h2 class="font-display text-2xl sm:text-3xl text-brand-blue">
                {section.name}
              </h2>
            </div>
            <div class="flex-1 h-px bg-brand-blue/15"></div>
          </div>

          {section.note && (
            <p class="font-body text-xs text-brand-stone uppercase tracking-widest mb-4 -mt-2">
              {section.note}
            </p>
          )}

          <!-- Items -->
          <ul class="flex flex-col gap-3">
            {section.items.map(item => (
              <li class="flex items-start justify-between gap-4">
                <div class="flex items-start gap-2 min-w-0">
                  {section.choose && (
                    <span class="mt-1.5 shrink-0 w-1.5 h-1.5 rounded-full bg-brand-gold/60"></span>
                  )}
                  <div class="flex flex-col gap-1">
                    <span class="font-body text-brand-blue text-base leading-snug">
                      {item.name}
                    </span>
                    {item.description && (
                      <span class="font-body text-brand-stone text-sm">{item.description}</span>
                    )}
                    {item.allergens && item.allergens.length > 0 && (
                      <div class="flex flex-wrap gap-1 mt-0.5">
                        {item.allergens.map((a: string) => {
                          const info = ALLERGENS[a.toLowerCase()] ?? { label: a, bg: 'bg-gray-100', text: 'text-gray-700' };
                          return (
                            <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold leading-none ${info.bg} ${info.text}`}>
                              {info.label}
                            </span>
                          );
                        })}
                      </div>
                    )}
                  </div>
                </div>
                {item.supplement && (
                  <span class="font-body text-brand-gold text-sm shrink-0 tabular-nums whitespace-nowrap">
                    +{item.supplement.toFixed(0)}€/pers.
                  </span>
                )}
              </li>
            ))}
          </ul>

          {section.choose && (
            <p class="font-body text-xs text-brand-stone/50 italic mt-3">
              Elige un plato
            </p>
          )}

        </div>
      ))}

      <!-- Allergen legend -->
      <div class="border-t border-brand-sand/40 pt-6 flex flex-col gap-3">
        <p class="font-body text-[11px] uppercase tracking-widest text-brand-stone/60">Alérgenos</p>
        <div class="flex flex-wrap gap-2">
          {Object.values(ALLERGENS).map(a => (
            <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold ${a.bg} ${a.text}`}>{a.label}</span>
          ))}
        </div>
        <p class="font-body text-[11px] text-brand-stone/50 italic mt-1">
          Intolerancia o alergia grave? Indícalo a nuestro equipo y lo gestionamos con todo el cuidado.
        </p>
      </div>

    </div>
  </section>

  <!-- ── CTA ─────────────────────────────────────────────────────── -->
  <section class="bg-brand-blue py-12">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-center gap-4 text-center">
      <a
        href="/carta"
        class="font-body text-sm uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200"
      >
        Ver La Carta →
      </a>
      <span class="hidden sm:block text-white/20">|</span>
      <a
        href="/restaurante#reservar"
        class="inline-flex items-center px-6 py-3 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium transition-colors duration-200"
      >
        Reservar mesa
      </a>
    </div>
  </section>

</Layout>
