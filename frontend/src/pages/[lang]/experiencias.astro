          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2"><label for="nombre" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{c.formName}</label><input type="text" id="nombre" name="nombre" required placeholder={c.formNamePlaceholder} class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200" /></div>
            <div class="flex flex-col gap-2"><label for="email" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{c.formEmail}</label><input type="email" id="email" name="email" required placeholder={c.formEmailPlaceholder} class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200" /></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2"><label for="telefono" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{c.formPhone}</label><input type="tel" id="telefono" name="telefono" placeholder={c.formPhonePlaceholder} class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200" /></div>
            <div class="flex flex-col gap-2"><label for="tipo-experiencia" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{c.formType}</label><select id="tipo-experiencia" name="experiencia" required class="bg-white/20 border border-white/30 text-white rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200 appearance-none"><option value="" disabled selected class="text-brand-blue">{c.formTypePlaceholder}</option>{c.formTypeOptions.map((o) => <option value={o} class="text-brand-blue">{o}</option>)}</select></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2"><label for="fecha-llegada" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{c.formDate}</label><input type="date" id="fecha-llegada" name="fecha" class="bg-white/20 border border-white/30 text-white rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200 [color-scheme:dark]" /></div>
            <div class="flex flex-col gap-2"><label for="personas" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{c.formPeople}</label><input type="number" id="personas" name="personas" min="1" max="20" placeholder={c.formPeoplePlaceholder} class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200" /></div>
          </div>
          <div class="flex flex-col gap-2"><label for="mensaje" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{c.formMessage}</label><textarea id="mensaje" name="mensaje" rows="5" placeholder={c.formMessagePlaceholder} class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200 resize-y"></textarea></div>
          <div class="flex items-start gap-3"><input type="checkbox" id="rgpd" name="rgpd" required class="mt-1 h-4 w-4 flex-shrink-0 rounded border-white/40 bg-white/20 text-brand-gold focus:ring-brand-gold" /><label for="rgpd" class="font-body text-xs text-white/70 leading-relaxed">{c.formPrivacy} <a href="/privacidad" target="_blank" class="underline hover:text-brand-gold">{c.formPrivacyLink}</a>{c.formPrivacyTail}</label></div>
          <div class="flex flex-col items-center gap-4 "><button type="submit" class="inline-flex items-center justify-center px-10 py-4 bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium rounded-lg transition-colors duration-300 shadow-lg w-full sm:w-auto">{c.formSubmit}</button><p class="font-body text-white/50 text-xs text-center">{c.formNote}</p></div>
        </FormHandler>
      </div>
    </div>
  </section>

  <section class="bg-brand-cream py-24 md:py-32 px-4 border-t border-brand-sand/30" aria-label={c.moreLabel}>
    <div class="max-w-5xl mx-auto">
      <p class="font-body text-center uppercase tracking-[0.3em] text-brand-stone text-xs font-medium mb-12">{c.moreLabel}</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href={getRelativeLocaleUrl(lang, 'hotel')} class="group flex items-center justify-between px-8 py-7 border border-brand-sand/50 rounded-xl hover:border-brand-gold hover:bg-white transition-all duration-300" aria-label={c.moreHotel}><span class="font-display text-2xl text-brand-blue font-light group-hover:text-brand-gold transition-colors duration-300">{c.moreHotel}</span><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-sand group-hover:text-brand-gold group-hover:translate-x-1 transition-all duration-300" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
        <a href={getRelativeLocaleUrl(lang, 'restaurante')} class="group flex items-center justify-between px-8 py-7 border border-brand-sand/50 rounded-xl hover:border-brand-gold hover:bg-white transition-all duration-300" aria-label={c.moreRestaurant}><span class="font-display text-2xl text-brand-blue font-light group-hover:text-brand-gold transition-colors duration-300">{c.moreRestaurant}</span><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-sand group-hover:text-brand-gold group-hover:translate-x-1 transition-all duration-300" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
        <a href={getRelativeLocaleUrl(lang, 'eventos')} class="group flex items-center justify-between px-8 py-7 border border-brand-sand/50 rounded-xl hover:border-brand-gold hover:bg-white transition-all duration-300" aria-label={c.moreEvents}><span class="font-display text-2xl text-brand-blue font-light group-hover:text-brand-gold transition-colors duration-300">{c.moreEvents}</span><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-sand group-hover:text-brand-gold group-hover:translate-x-1 transition-all duration-300" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('a.exp-cta[data-exp]').forEach(function(link) {
      link.addEventListener('click', function() {
        var sel = document.getElementById('tipo-experiencia');
        if (sel) sel.value = link.dataset.exp;
      });
    });
  </script>
</Layout>
