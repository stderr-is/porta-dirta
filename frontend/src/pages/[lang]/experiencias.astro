const c = copy[lang];

const colaboradores = (await getCollection('colaboradores')).sort((a, b) => a.data.orden - b.data.orden);

const hieventsUrl = import.meta.env.PUBLIC_HIEVENTS_URL ?? 'http://localhost:8082';
const tastyigniterUrl = import.meta.env.PUBLIC_TASTYIGNITER_URL ?? 'http://localhost:8081';

let hiEvents: any[] = [];
try {
  const res = await fetch(`${hieventsUrl}/api/public/organizers/1/events`, { headers: { Accept: 'application/json' } });
  if (res.ok) {
    const json = await res.json();
    hiEvents = json.data ?? [];
  }
} catch (e: any) {
  console.warn('[experiencias] Hi.Events unavailable:', e.message);
}

function getExp(slug: string) {
  const ev = hiEvents.find((e) => e.slug === slug);
  if (!ev) return { price: null, label: slug, anchor: '#contacto' };
  const rawPrice = ev.product_categories?.flatMap((cat: any) => cat.products ?? [])?.find((p: any) => p.price != null)?.price ?? null;
  return { price: rawPrice != null ? Math.round(rawPrice / 100) : null, label: ev.title as string, anchor: '#contacto' };
}

const sierra = getExp('ruta-guiada-sierra-de-irta');
const kayak = getExp('kayak-y-snorkel-en-la-costa');
const vinos = getExp('cata-de-vinos-y-gastronomia');
const castle = getExp('visita-guiada-al-castillo-papal');

interface HiPackage {
  id: number;
  title: string;
  slug: string;
  description_preview: string;
  start_date: string;
  lifecycle_status: 'UPCOMING' | 'PAST' | 'ENDED';
  cover_url: string | null;
  price: number | null;
  booking_url: string;
}

const hiEventsBaseUrl = import.meta.env.PUBLIC_HIEVENTS_URL ?? 'https://eventos.portadirta.com';

const livePackages: HiPackage[] = hiEvents
  .filter((e: any) => e.status === 'LIVE')
  .sort((a: any, b: any) => {
    if (a.lifecycle_status === 'UPCOMING' && b.lifecycle_status !== 'UPCOMING') return -1;
    if (a.lifecycle_status !== 'UPCOMING' && b.lifecycle_status === 'UPCOMING') return 1;
    return new Date(a.start_date).getTime() - new Date(b.start_date).getTime();
  })
  .map((e: any) => {
    const rawPrice = e.product_categories?.flatMap((cat: any) => cat.products ?? [])?.find((p: any) => p.price != null)?.price ?? null;
    return {
      id: e.id,
      title: e.title,
      slug: e.slug,
      description_preview: e.description_preview ?? '',
      start_date: e.start_date,
      lifecycle_status: e.lifecycle_status ?? 'UPCOMING',
      cover_url: e.images?.[0]?.url ?? null,
      price: rawPrice != null ? Math.round(rawPrice / 100) : null,
      booking_url: `${hiEventsBaseUrl}/e/${e.slug}`,
    };
  });

const packageCopy = c.hiEventsPackages ?? {};
