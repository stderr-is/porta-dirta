---
/**
 * src/pages/[lang]/hotel.astro — Dynamic hotel page for all locales
 */

import Layout from '../../layouts/Layout.astro';
import GarlandDivider from '../../components/GarlandDivider.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';      

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

export async function getStaticPaths() {
  return ['en', 'fr', 'de'].map((lang) => {
    return {
      params: { lang },
    };
  });
}

const bookingUrl = "https://www.booking.com/hotel/es/porta-d-irta.es.html";
---

<Layout
  title={t('hotel.meta_title')}
  description={t('hotel.meta_description')}
  lang={lang}
  ogImage={t('hotel.og_image')}
>
  <!-- SECTION 1: HERO -->
  <section
    class="relative min-h-screen flex flex-col items-center justify-center text-center overflow-hidden"
    aria-label="Hero — Porta D'irta Hotel"
  >
    <img
      src={t('hotel.hero_img')}
      alt={t('hotel.hero_alt')}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-brand-forest/55"></div>

    <div class="relative z-10 flex flex-col items-center gap-6 px-4 py-24 md:py-40">
      <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
        {t('hotel.hero_label')}
      </span>
      <h1
        class="font-display italic text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-white leading-tight max-w-3xl"
      >
        {t('hotel.hero_heading')}
      </h1>
      <GarlandDivider light />
      <p class="font-body text-base sm:text-lg text-white/80 max-w-xl leading-relaxed">
        {t('hotel.hero_body')}
      </p>
      
      <!-- Botones duales -->
      <div class="flex flex-col sm:flex-row items-center gap-4 mt-4">
        <a
          href={getRelativeLocaleUrl(lang, 'restaurante') + '#reservar'}
          class="inline-flex items-center gap-2 px-8 py-4 rounded-sm border border-white/40 hover:border-white text-white font-body text-sm uppercase tracking-widest font-bold transition-all backdrop-blur-sm bg-white/5"
        >
          {lang === 'es' ? 'Reservar Mesa' : 'Book a Table'}
        </a>
        <a
          href={bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-bold transition-all shadow-lg"
        >
          {lang === 'es' ? 'Reservar Habitación' : 'Book a Room'}
          <img src="https://upload.wikimedia.org/wikipedia/commons/b/be/Booking.com_logo.svg" class="h-3.5 brightness-0" alt="Booking" />
        </a>
      </div>
    </div>

    <a
      href="#property-intro"
      class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 text-white/60 hover:text-brand-gold transition-colors duration-300 animate-bounce"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </a>
  </section>

  <!-- SECTION 2: PROPERTY INTRO -->
  <section id="property-intro" class="bg-brand-cream py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="flex flex-col gap-6">
          <span class="font-body text-xs uppercase tracking-[0.35em] text-brand-gold">{t('hotel.property_label')}</span>
          <h2 class="font-display font-light text-5xl md:text-6xl text-brand-blue leading-tight">{t('hotel.property_heading')}</h2>
          <GarlandDivider />
          <p class="font-body text-brand-stone text-lg leading-relaxed max-w-md">{t('hotel.property_body')}</p>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <img src={t('hotel.img_url_villa1')} class="w-full h-48 md:h-56 object-cover rounded-sm" />
          <img src={t('hotel.img_url_villa2')} class="w-full h-48 md:h-56 object-cover rounded-sm" />
          <img src={t('hotel.img_url_villa3')} class="w-full h-48 md:h-56 object-cover rounded-sm" />
          <img src={t('hotel.img_url_villa4')} class="w-full h-48 md:h-56 object-cover rounded-sm" />
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: ROOM LISTINGS -->
  <section class="bg-brand-blue py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">{t('hotel.rooms_label')}</span>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-white mt-3">{t('hotel.rooms_heading')}</h2>
        <GarlandDivider light />
        <p class="font-body text-sm text-white/60 mt-4 max-w-xl mx-auto">{t('hotel.rooms_body')}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Habitación 1 -->
        <article class="flex flex-col gap-6">
          <img src={t('hotel.room1_img_url')} class="w-full h-80 object-cover rounded-sm shadow-2xl" />
          <div class="flex flex-col gap-4">
            <h3 class="font-display text-3xl text-white">{t('hotel.room1_title')}</h3>
            <p class="font-body text-white/70 leading-relaxed">{t('hotel.room1_body')}</p>
            <a href={bookingUrl} target="_blank" class="inline-flex items-center justify-center gap-2 bg-brand-gold hover:bg-brand-stone text-brand-blue px-8 py-4 rounded-sm font-bold uppercase tracking-widest text-xs transition-all w-fit">
              Reservar en Booking.com
              <img src="https://upload.wikimedia.org/wikipedia/commons/b/be/Booking.com_logo.svg" class="h-3 brightness-0" />
            </a>
          </div>
        </article>

        <!-- Habitación 2 -->
        <article class="flex flex-col gap-6">
          <img src={t('hotel.room2_img_url')} class="w-full h-80 object-cover rounded-sm shadow-2xl" />
          <div class="flex flex-col gap-4">
            <h3 class="font-display text-3xl text-white">{t('hotel.room2_title')}</h3>
            <p class="font-body text-white/70 leading-relaxed">{t('hotel.room2_body')}</p>
            <a href={bookingUrl} target="_blank" class="inline-flex items-center justify-center gap-2 bg-brand-gold hover:bg-brand-stone text-brand-blue px-8 py-4 rounded-sm font-bold uppercase tracking-widest text-xs transition-all w-fit">
              Reservar en Booking.com
              <img src="https://upload.wikimedia.org/wikipedia/commons/b/be/Booking.com_logo.svg" class="h-3 brightness-0" />
            </a>
          </div>
        </article>

        <!-- Habitación 3 -->
        <article class="flex flex-col gap-6">
          <img src={t('hotel.room3_img_url')} class="w-full h-80 object-cover rounded-sm shadow-2xl" />
          <div class="flex flex-col gap-4">
            <h3 class="font-display text-3xl text-white">{t('hotel.room3_title')}</h3>
            <p class="font-body text-white/70 leading-relaxed">{t('hotel.room3_body')}</p>
            <a href={bookingUrl} target="_blank" class="inline-flex items-center justify-center gap-2 bg-brand-gold hover:bg-brand-stone text-brand-blue px-8 py-4 rounded-sm font-bold uppercase tracking-widest text-xs transition-all w-fit">
              Reservar en Booking.com
              <img src="https://upload.wikimedia.org/wikipedia/commons/b/be/Booking.com_logo.svg" class="h-3 brightness-0" />
            </a>
          </div>
        </article>

        <!-- Habitación 4 -->
        <article class="flex flex-col gap-6">
          <img src={t('hotel.room4_img_url')} class="w-full h-80 object-cover rounded-sm shadow-2xl" />
          <div class="flex flex-col gap-4">
            <h3 class="font-display text-3xl text-white">{t('hotel.room4_title')}</h3>
            <p class="font-body text-white/70 leading-relaxed">{t('hotel.room4_body')}</p>
            <a href={bookingUrl} target="_blank" class="inline-flex items-center justify-center gap-2 bg-brand-gold hover:bg-brand-stone text-brand-blue px-8 py-4 rounded-sm font-bold uppercase tracking-widest text-xs transition-all w-fit">
              Reservar en Booking.com
              <img src="https://upload.wikimedia.org/wikipedia/commons/b/be/Booking.com_logo.svg" class="h-3 brightness-0" />
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>
</Layout>