---
/**
 * src/pages/[lang]/restaurante.astro — Dynamic restaurant page for all locales
 */

import Layout from '../../layouts/Layout.astro';
import GarlandDivider from '../../components/GarlandDivider.astro';
import BotanicalAccent from '../../components/BotanicalAccent.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const menuNightTagsValue = t('restaurante.menu_night_tags', { returnObjects: true });
const menuSpecialTagsValue = t('restaurante.menu_special_tags', { returnObjects: true });
const menuNightTags = Array.isArray(menuNightTagsValue)
  ? menuNightTagsValue.filter((value): value is string => typeof value === 'string')
  : [];
const menuSpecialTags = Array.isArray(menuSpecialTagsValue)
  ? menuSpecialTagsValue.filter((value): value is string => typeof value === 'string')
  : [];

export async function getStaticPaths() {
  return ['en', 'fr', 'de'].map((lang) => {
    return {
      params: { lang },
    };
  });
}
---

<Layout
  title={t('restaurante.meta_title')}
  description={t('restaurante.meta_description')}
  ogImage={t('restaurante.og_image')}
  lang={lang}
>

  <script type="application/ld+json" slot="head" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "Restaurant",
      "name": t('restaurante.schema_name'),
      "description": t('restaurante.schema_description'),
      "url": `https://www.portadirta.com/${lang === 'es' ? '' : lang + '/'}restaurante`,
      "telephone": t('contacto.restaurant_phone'),
      "servesCuisine": t('restaurante.schema_servesCuisine', { returnObjects: true }),
      "priceRange": t('restaurante.schema_priceRange'),
      "acceptsReservations": "true",
      "menu": `https://www.portadirta.com/${lang === 'es' ? '' : lang + '/'}carta`,
      "currenciesAccepted": "EUR",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": t('restaurante.schema_streetAddress'),
        "addressLocality": t('restaurante.schema_addressLocality'),
        "addressRegion": t('restaurante.schema_addressRegion'),
        "postalCode": t('restaurante.schema_postalCode'),
        "addressCountry": "ES"
      },
      "image": `https://www.portadirta.com${t('restaurante.og_image')}`,
      "isContainedInPlace": {
        "@type": "LodgingBusiness",
        "name": "Porta D'irta",
        "url": `https://www.portadirta.com/${lang === 'es' ? '' : lang + '/'}hotel`
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "13:00",
          "closes": "16:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "20:00",
          "closes": "22:00"
        }
      ],
      "hasMap": t('restaurante.schema_hasMap')
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": t('nav.home'),
          "item": `https://www.portadirta.com/${lang === 'es' ? '' : lang + '/'}`
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": t('nav.restaurante'),
          "item": `https://www.portadirta.com/${lang === 'es' ? '' : lang + '/'}restaurante`
        }
      ]
    }
  ])} />

  <!-- ================================================================
       SECTION 1 — HERO
       ================================================================ -->
  <section
    class="relative min-h-screen flex flex-col items-center justify-center text-center overflow-hidden"
    aria-label={t('restaurante.hero_alt')}
  >
    <img
      src={t('restaurante.hero_img')}
      alt={t('restaurante.hero_alt')}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      decoding="async"
    />

    <!-- Brand-blue overlay -->
    <div class="absolute inset-0 bg-brand-forest/52"></div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center gap-6 px-4 py-20 md:py-32  md:">
      <!-- Eyebrow label -->
      <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
        {t('restaurante.hero_label')}
      </span>

      <!-- Main heading -->
      <h1 class="font-display italic text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-white leading-tight max-w-3xl">
        {t('restaurante.hero_heading')}
      </h1>

      <!-- Tagline -->
      <p class="font-body text-base sm:text-lg text-white/80 max-w-xl leading-relaxed">
        {t('restaurante.hero_body')}
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row items-center gap-4 mt-2">
        <a
          href="#reservar"
          class="inline-flex items-center px-8 py-4 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium transition-colors duration-300 shadow-lg"
        >
          {t('restaurante.hero_cta_reserve')}
        </a>
        <a
          href="#filosofia"
          class="inline-flex items-center px-8 py-4 rounded-sm border border-white/60 hover:border-white text-white font-body text-sm uppercase tracking-widest font-medium transition-colors duration-300"
        >
          {t('restaurante.hero_cta_discover')}
        </a>
      </div>
    </div>

    <!-- Scroll chevron -->
    <a
      href="#filosofia"
      class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 text-white/60 hover:text-brand-gold transition-colors duration-300 animate-bounce"
      aria-label={t('restaurante.hero_scroll_down_aria')}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </a>
  </section>

  <!-- ================================================================
       SECTION 2 — PHILOSOPHY / ABOUT
       ================================================================ -->
  <section
    id="filosofia"
    class="bg-brand-cream py-24 md:py-32"
    aria-label={t('restaurante.philosophy_label')}
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center min-h-[60vh]">

        <!-- Left: text -->
        <div class="flex flex-col gap-6">
          <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
            {t('restaurante.philosophy_label')}
          </span>
          <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-brand-blue leading-tight">
            {t('restaurante.philosophy_heading')}
          </h2>
          <p class="font-body text-base text-brand-stone leading-relaxed">
            {t('restaurante.philosophy_body1')}
          </p>
          <p class="font-body text-base text-brand-stone leading-relaxed">
            {t('restaurante.philosophy_body2')}
          </p>
        </div>

        <!-- Right: image -->
        <div>
          <img
            src={t('restaurante.philosophy_img')}
            alt={t('restaurante.philosophy_img_alt')}
            width="800" height="600"
            class="w-full h-auto rounded-sm shadow-xl object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================================
       SECTION 2b — MENÚ ESPECIAL SEMANA SANTA (temporary — remove after ~April 27 2026)
       ================================================================ -->
  <section
    class="relative bg-brand-cream py-24 md:py-32 overflow-hidden border-t border-brand-forest/5"
    aria-label={t('restaurante.easter_label')}
  >
    <!-- Sage botanical accents for a "pressed leaves" look on light background -->
    <div class="opacity-20 text-brand-forest">
      <BotanicalAccent position="top-left" />
      <BotanicalAccent position="bottom-right" />
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-20">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">

        <!-- Column 1: Editorial Image & Intro (5 cols) -->
        <div class="lg:col-span-5 flex flex-col gap-8">
          <div class="flex flex-col gap-4">
            <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
              {t('restaurante.easter_label')}
            </span>
            <h2 class="font-display text-4xl sm:text-5xl md:text-6xl text-brand-blue leading-[1.1]">
              {t('restaurante.easter_heading_part1')} <br />
              <span class="italic font-light text-brand-forest/80">{t('restaurante.easter_heading_part2')}</span>
            </h2>
            <div class="w-20 h-px bg-brand-gold/60 mt-2"></div>
          </div>

          <p class="font-body text-base text-brand-stone leading-relaxed max-w-md">
            {t('restaurante.easter_body')}
          </p>

          <div class="relative rounded-sm overflow-hidden aspect-[4/5] shadow-2xl group">
            <img
              src={t('restaurante.easter_img')}
              alt={t('restaurante.easter_img_alt')}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-brand-forest/10 mix-blend-multiply"></div>
          </div>
        </div>

        <!-- Column 2: The Menu Card (7 cols) -->
        <div class="lg:col-span-7">
          <!-- Premium Light Glassmorphism card -->
          <div class="relative backdrop-blur-xl bg-white/40 border border-brand-forest/10 rounded-xl overflow-hidden shadow-[0_32px_64px_-16px_rgba(26,46,26,0.12)]">

            <!-- Woven Palm motif background detail -->
            <div class="absolute top-0 right-0 p-4 opacity-[0.03] text-brand-forest pointer-events-none">
              <svg class="w-32 h-32 rotate-12" viewBox="0 0 24 24" fill="currentColor"><path d="M12,2C11.5,2 11,2.19 10.59,2.59L2.59,10.59C2.19,11 2,11.5 2,12C2,12.5 2.19,13 2.59,13.41L10.59,21.41C11,21.81 11.5,22 12,22C12.5,22 13,21.81 13.41,21.41L21.41,13.41C21.81,13 22,12.5 22,12C22,11.5 21.81,11 21.41,10.59L13.41,2.59C13,2.19 12.5,2 12,2M12,4L20,12L12,20L4,12L12,4M12,6L6,12L12,18L18,12L12,6Z"/></svg>
            </div>

            <!-- Card Header: Info & "Wax Seal" Price -->
            <div class="flex items-center justify-between px-8 py-5 border-b border-brand-forest/5 bg-white/30">
              <div>
                <p class="font-body text-[9px] uppercase tracking-[0.2em] text-brand-gold mb-0.5 font-bold">{t('restaurante.easter_lunch_service')}</p>
                <p class="font-body text-xs text-brand-blue/70">{t('restaurante.easter_hours')}</p>
              </div>

              <!-- Wax Seal Price Badge -->
              <div class="relative flex items-center justify-center">
                <div class="absolute inset-0 scale-110 opacity-20 text-brand-gold">
                  <svg viewBox="0 0 100 100" fill="currentColor"><path d="M50 0 C22.4 0 0 22.4 0 50 C0 77.6 22.4 100 50 100 C77.6 100 100 77.6 100 50 C100 22.4 77.6 0 50 0 M50 10 C72.1 10 90 27.9 90 50 C90 72.1 72.1 90 50 90 C27.9 90 10 72.1 10 50 C10 27.9 27.9 10 50 10"/></svg>
                </div>
                <div class="relative bg-brand-forest/5 border border-brand-gold/20 rounded-full w-14 h-14 flex flex-col items-center justify-center shadow-inner">
                  <span class="font-display text-xl text-brand-blue leading-none">{t('restaurante.easter_price')}</span>
                  <span class="font-body text-[7px] uppercase tracking-tighter text-brand-stone/60">{t('restaurante.easter_p_p')}</span>
                </div>
              </div>
            </div>

            <!-- Menu body -->
            <div class="px-8 sm:px-12 py-8 flex flex-col gap-8">

              <!-- Aperitivos -->
              <div class="group">
                <div class="flex items-center gap-3 mb-3">
                  <span class="font-display text-lg text-purple-900/40 italic leading-none">I.</span>
                  <h3 class="font-body text-[9px] uppercase tracking-[0.4em] text-brand-blue font-bold flex items-center gap-2">
                    {t('restaurante.easter_aperitivo_title')}
                  </h3>
                  <div class="flex-1 h-px bg-brand-forest/10 transition-all duration-500 group-hover:bg-brand-gold/30"></div>
                </div>
                <div class="pl-8 flex flex-col gap-1">
                  <span class="font-body text-sm text-brand-blue/90 font-medium tracking-tight">{t('restaurante.easter_aperitivo_item')}</span>
                  <div class="flex flex-wrap gap-2">
                    <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Gluten</span>
                    <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Lácteos</span>
                  </div>
                </div>
              </div>

              <!-- Entrantes -->
              <div class="group">
                <div class="flex items-center gap-3 mb-3">
                  <span class="font-display text-lg text-purple-900/40 italic leading-none">II.</span>
                  <h3 class="font-body text-[9px] uppercase tracking-[0.4em] text-brand-blue font-bold flex items-center gap-2">
                    {t('restaurante.easter_entrantes_title')}
                  </h3>
                  <div class="flex-1 h-px bg-brand-forest/10 transition-all duration-500 group-hover:bg-brand-gold/30"></div>
                </div>
                <div class="pl-8 flex flex-col gap-4">
                  <!-- Item 1 -->
                  <div class="flex flex-col gap-1">
                    <span class="font-body text-sm text-brand-blue/90 font-medium max-w-sm leading-snug tracking-tight">{t('restaurante.easter_entrantes_item1')}</span>
                    <div class="flex flex-wrap gap-2">
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Gluten</span>
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Lácteos</span>
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Sulfitos</span>
                    </div>
                  </div>
                  <!-- Minimal divider -->
                  <div class="flex justify-start pl-2 opacity-10"><div class="w-4 h-px bg-brand-forest"></div></div>
                  <!-- Item 2 -->
                  <div class="flex flex-col gap-1">
                    <span class="font-body text-sm text-brand-blue/90 font-medium max-w-sm leading-snug tracking-tight">{t('restaurante.easter_entrantes_item2')}</span>
                    <div class="flex flex-wrap gap-2">
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Moluscos</span>
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Gluten</span>
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Sulfitos</span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Platos -->
              <div class="group">
                <div class="flex items-center gap-3 mb-1">
                  <span class="font-display text-lg text-purple-900/40 italic leading-none">III.</span>
                  <h3 class="font-body text-[9px] uppercase tracking-[0.4em] text-brand-blue font-bold flex items-center gap-2">
                    {t('restaurante.easter_principales_title')}
                  </h3>
                  <div class="flex-1 h-px bg-brand-forest/10 transition-all duration-500 group-hover:bg-brand-gold/30"></div>
                </div>
                <p class="font-body text-[7px] text-brand-stone/40 italic mb-3 pl-8 uppercase tracking-[0.15em] font-bold">{t('restaurante.easter_principales_note')}</p>
                <div class="pl-8 flex flex-col gap-4">
                  <!-- Option 1 -->
                  <div class="flex flex-col gap-1">
                    <span class="font-body text-sm text-brand-blue/90 font-medium leading-none tracking-tight">{t('restaurante.easter_principales_item1')}</span>
                    <div class="flex flex-wrap gap-2">
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Gluten</span>
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Crustáceos</span>
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Pescado</span>
                    </div>
                  </div>
                  <!-- Option 2 -->
                  <div class="flex flex-col gap-1">
                    <span class="font-body text-sm text-brand-blue/90 font-medium leading-snug tracking-tight">{t('restaurante.easter_principales_item2')}</span>
                    <div class="flex flex-wrap gap-2">
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Sulfitos</span>
                    </div>
                  </div>
                  <!-- Option 3 (Premium) -->
                  <div class="flex flex-col gap-1">
                    <div class="flex items-center justify-between gap-4">
                      <span class="font-body text-sm text-brand-blue/90 font-medium leading-none tracking-tight">{t('restaurante.easter_principales_item3')}</span>
                      <span class="font-body text-[7px] text-brand-gold border border-brand-gold/20 px-1.5 py-0.5 rounded-sm font-bold bg-white/50">+5€</span>
                    </div>
                    <div class="flex flex-wrap gap-2">
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1.5 py-0.5 rounded-sm">Crustáceos</span>
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1.5 py-0.5 rounded-sm">Sulfitos</span>
                    </div>
                  </div>
                  <!-- Option 4 -->
                  <div class="flex flex-col gap-1">
                    <span class="font-body text-sm text-brand-blue/90 font-medium leading-snug tracking-tight">{t('restaurante.easter_principales_item4')}</span>
                    <div class="flex flex-wrap gap-2">
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1.5 py-0.5 rounded-sm">Lácteos</span>
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1.5 py-0.5 rounded-sm">Sulfitos</span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Postres -->
              <div class="group">
                <div class="flex items-center gap-3 mb-3">
                  <span class="font-display text-lg text-purple-900/40 italic leading-none">IV.</span>
                  <h3 class="font-body text-[9px] uppercase tracking-[0.4em] text-brand-blue font-bold flex items-center gap-2">
                    {t('restaurante.easter_postres_title')}
                  </h3>
                  <div class="flex-1 h-px bg-brand-forest/10 transition-all duration-500 group-hover:bg-brand-gold/30"></div>
                </div>
                <div class="pl-8 flex flex-col gap-4">
                  <div class="flex flex-col gap-1">
                    <span class="font-body text-sm text-brand-blue/90 font-medium leading-none tracking-tight">{t('restaurante.easter_postres_item1')}</span>
                    <div class="flex flex-wrap gap-2">
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1 py-0.5 rounded-sm">Lácteos</span>
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1.5 py-0.5 rounded-sm">Gluten</span>
                    </div>
                  </div>
                  <!-- Minimal divider -->
                  <div class="flex justify-start pl-2 opacity-10"><div class="w-4 h-px bg-brand-forest"></div></div>
                  <div class="flex flex-col gap-1">
                    <span class="font-body text-sm text-brand-blue/90 font-medium leading-none tracking-tight">{t('restaurante.easter_postres_item2')}</span>
                    <div class="flex flex-wrap gap-2">
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1.5 py-0.5 rounded-sm">Gluten</span>
                      <span class="text-[7px] uppercase tracking-wider text-brand-stone/40 border border-brand-stone/10 px-1.5 py-0.5 rounded-sm">Frutos secos</span>
                    </div>
                  </div>
                </div>
              </div>

            </div>

            <!-- Card Footer: Terms & Booking -->
            <div class="px-8 py-6 border-t border-brand-forest/5 bg-white/20 flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left">
              <p class="font-body text-[10px] text-brand-stone/50 leading-relaxed max-w-[220px]">
                {t('restaurante.easter_footer_note')}
              </p>
              <a
                href="#reservar"
                onclick="document.querySelector('[name=observaciones]') ? document.querySelector('[name=observaciones]').value = 'Reserva para Menú Semana Santa' : null"
                class="inline-flex items-center px-8 py-3.5 rounded-sm bg-brand-forest/90 hover:bg-brand-blue text-white font-body text-[10px] uppercase tracking-[0.2em] font-bold transition-all duration-300 shadow-md"
              >
                {t('restaurante.hero_cta_reserve')}
              </a>
            </div>

          </div>
        </div>

      </div>

    </div>

    <!-- Transition to the dark blue Menus section below -->
    <div class="absolute bottom-0 left-0 w-full translate-y-1/2 z-10">
      <GarlandDivider />
    </div>
  </section>

  <!-- ================================================================
       SECTION 3 — DAY & NIGHT MENUS
       ================================================================ -->
  <section
    class="bg-brand-blue py-24 md:py-32"
    aria-label={t('restaurante.menus_aria_label')}
  >
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section heading -->
      <div id="carta" class="text-center mb-16">
        <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
          {t('restaurante.menu_day_label')}
        </span>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-white mt-3">
          {t('restaurante.menu_day_heading')}
        </h2>
        <p class="font-body text-sm text-white/60 mt-4 max-w-xl mx-auto leading-relaxed">
          {t('restaurante.menu_day_body')}
        </p>
      </div>

      <!-- Two editorial cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">

        <!-- Card: De Día -->
        <a
          href={getRelativeLocaleUrl(lang, 'taperia')}
          class="group relative rounded-2xl overflow-hidden flex flex-col min-h-[520px] shadow-2xl"
          aria-label={t('restaurante.menu_day_aria_label')}
        >
          <img
            src={t('restaurante.menu_day_img')}
            alt={t('restaurante.menu_day_img_alt')}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
