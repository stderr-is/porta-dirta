  <!-- Pre-fill form from URL params sent by Beds24 confirmation emails.
       Supported params: fecha (YYYY-MM-DD), personas, nombre, email, telefono
       Example: /restaurante?fecha=2026-07-15&personas=2&nombre=John+Doe&email=john@example.com -->
  <script is:inline define:vars={{ tastyigniterUrl: import.meta.env.PUBLIC_TASTYIGNITER_URL ?? 'https://restaurant.portadirta.com', lang }}>
    document.getElementById('restaurant-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      var form = e.target;
      var btn = form.querySelector('button[type="submit"]');
      var originalText = btn.textContent;
      btn.textContent = translatedStrings.form_sending; // Use translated string
      btn.disabled = true;

      try {
        var formData = new FormData(form);
        var data = {
          nombre:        formData.get('nombre'),
          email:         formData.get('email'),
          telefono:      formData.get('telefono'),
          personas:      parseInt(formData.get('personas'), 10),
          fecha:         formData.get('fecha'),
          hora:          formData.get('hora'),
          observaciones: formData.get('observaciones') || '',
        };
        var res = await fetch(tastyigniterUrl + '/api/public/reservations', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) {
          var errBody = await res.json().catch(function() { return {}; });
          throw new Error(errBody.message || translatedStrings.form_error_msg); // Use translated string
        }
        form.innerHTML = '<div class="text-center py-8"><p class="text-brand-gold font-display text-2xl italic">' + translatedStrings.form_success_msg + '</p></div>'; // Use translated string
      } catch (err) {
        btn.textContent = originalText;
        btn.disabled = false;
        var errDiv = form.querySelector('.form-error');
        if (!errDiv) {
          errDiv = document.createElement('p');
          errDiv.className = 'form-error text-red-400 text-sm text-center mt-2';
          form.appendChild(errDiv);
        }
        errDiv.textContent = translatedStrings.form_error_msg; // Use translated string
      }
    });

    // Translate optgroup labels in time select
    const timeSelect = document.getElementById('hora');
    if (timeSelect) {
      const optgroups = timeSelect.querySelectorAll('optgroup');
      optgroups.forEach(group => {
        if (group.label === 'Mediodía') {
          group.label = translatedStrings.form_mediodia_label;
        } else if (group.label === 'Noche') {
          group.label = translatedStrings.form_noche_label;
        }
      });
    }

    // Helper for accessing translations in inline script
    // This is a simplified version; a more robust solution would be to use a proper client-side i18n library
    const getNestedTranslation = (obj, path) => {
      return path.split('.').reduce((acc, part) => acc && acc[part], obj);
    };

    // Assuming `translations` is available globally from `translations.ts` or passed via define:vars
    // For now, hardcode the path to translations; a better way would be to pass `t` function
    // For simplicity, directly access the es translations and manually pass them.
    // THIS IS A TEMPORARY WORKAROUND, AND SHOULD BE REPLACED WITH A PROPER CLIENT-SIDE I18N APPROACH
    const allTranslations = {
      es: {
        form_sending: 'Enviando...',
        form_success_msg: '¡Reserva confirmada! Nos pondremos en contacto pronto.',
        form_error_msg: 'Ha ocurrido un error. Por favor inténtalo de nuevo o llámanos directamente.',
        form_mediodia_label: 'Mediodía',
        form_noche_label: 'Noche',
      },
      en: {
        form_sending: 'Sending...',
        form_success_msg: 'Reservation confirmed! We will contact you soon.',
        form_error_msg: 'An error occurred. Please try again or call us directly.',
        form_mediodia_label: 'Lunch',
        form_noche_label: 'Dinner',
      },
      fr: {
        form_sending: 'Envoi en cours...',
        form_success_msg: 'Réservation confirmée ! Nous vous contacterons bientôt.',
        form_error_msg: 'Une erreur est survenue. Veuillez réessayer ou nous appeler directement.',
        form_mediodia_label: 'Midi',
        form_noche_label: 'Soir',
      },
      de: {
        form_sending: 'Wird gesendet...',
        form_success_msg: 'Reservierung bestätigt! Wir werden Sie bald kontaktieren.',
        form_error_msg: 'Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut oder rufen Sie uns direkt an.',
        form_mediodia_label: 'Mittag',
        form_noche_label: 'Abend',
      },
    };
    const translatedStrings = allTranslations[lang] || allTranslations.es; // Fallback to Spanish
  </script>

