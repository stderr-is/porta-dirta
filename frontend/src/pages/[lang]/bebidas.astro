---
/**
 * src/pages/[lang]/bebidas.astro — Drinks list (multilingual)
 */
import fs from 'node:fs';
import Layout from '../../layouts/Layout.astro';
import GarlandDivider from '../../components/GarlandDivider.astro';
import bebidasFallback from '../../data/bebidas.json';
import type { DynamicMenuData, MenuSection, MenuTranslationSection } from '../../types/menu';
export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'fr' } }, { params: { lang: 'de' } }];
}
const { lang } = Astro.params;
const langParam = lang as string;
if (!langParam || !['en', 'fr', 'de'].includes(langParam)) {
  return new Response(null, { status: 404 });
}
const ui = {
  en: {
    title: 'Drinks \u2014 Restaurant',
    description: "Wines, beers and drinks at Porta D'irta, Pe\u00f1\u00edscola.",
    subtitle: "Porta D'irta Restaurant",
    updated_prefix: 'Updated',
    footer_note: 'Prices include VAT. Availability subject to season.',
    back_link: '\u2190 All menus',
    book_link: 'Book a table',
  },
  fr: {
    title: 'Boissons \u2014 Restaurant',
    description: "Vins, bi\u00e8res et boissons \u00e0 Porta D'irta, Pe\u00f1\u00edscola.",
    subtitle: "Restaurant Porta D'irta",
    updated_prefix: 'Mise \u00e0 jour le',
    footer_note: 'Prix TTC. Disponibilit\u00e9 selon la saison.',
    back_link: '\u2190 Tous les menus',
    book_link: 'R\u00e9server une table',
  },
  de: {
    title: 'Getr\u00e4nke \u2014 Restaurant',
    description: "Weine, Biere und Getr\u00e4nke bei Porta D'irta, Pe\u00f1\u00edscola.",
    subtitle: "Restaurant Porta D'irta",
    updated_prefix: 'Aktualisiert am',
    footer_note: 'Preise inkl. MwSt. Verf\u00fcgbarkeit je nach Saison.',
    back_link: '\u2190 Alle Men\u00fcs',
    book_link: 'Tisch reservieren',
  },
};
const t = ui[lang as keyof typeof ui];
let bebidas: DynamicMenuData = bebidasFallback;
const menuDataPath = process.env.MENU_DATA_PATH;
if (menuDataPath) {
  try { bebidas = JSON.parse(fs.readFileSync(`${menuDataPath}/bebidas.json`, 'utf-8')); } catch {}
}
// Keep numeric fields from base items and only override translatable text fields.
const langSections: MenuTranslationSection[] | undefined = bebidas.translations?.[langParam]?.sections;
const sections: MenuSection[] = langSections?.length
  ? bebidas.sections.map((baseSection, sectionIndex) => {
      const tSection = langSections[sectionIndex];
      return {
        ...baseSection,
        name: tSection?.name ?? baseSection.name,
        items: baseSection.items.map((baseItem, itemIndex) => {
          const tItem = tSection?.items?.[itemIndex];
          return {
            ...baseItem,
            name: tItem?.name ?? baseItem.name,
            description: tItem?.description ?? baseItem.description,
          };
        }),
      };
    })
  : bebidas.sections;
const updatedDate = new Intl.DateTimeFormat(lang, { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(bebidas.updated));
---

<Layout
  title={t.title}
  description={t.description}
  ogImage="/assets/images/food-paella-wine.jpg"
>
  <section class="bg-brand-blue pt-28 pb-10">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center flex flex-col items-center gap-3">
      <p class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">{t.subtitle}</p>
      <h1 class="font-display font-light italic text-5xl sm:text-6xl text-white leading-tight">Bebidas</h1>
      <GarlandDivider light />
      <p class="font-body text-white/50 text-xs">{t.updated_prefix} {updatedDate}</p>
    </div>
  </section>
  <section class="bg-brand-cream py-10">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 flex flex-col gap-10">
      {sections.map(section => (
        <div>
          <div class="flex items-center gap-3 mb-1">
            <h2 class="font-display text-2xl sm:text-3xl text-brand-blue shrink-0">{section.name}</h2>
            <div class="flex-1 h-px bg-brand-blue/15"></div>
          </div>
          <ul class="flex flex-col divide-y divide-brand-sand/40">
            {section.items.map(item => (
              <li class="py-3.5 flex items-start justify-between gap-3">
                <div class="flex flex-col gap-1 min-w-0">
                  <span class="font-body font-medium text-brand-blue text-[15px] leading-snug">{item.name}</span>
                  {item.description && <span class="font-body text-brand-stone text-[13px] leading-relaxed">{item.description}</span>}
                </div>
                <div class="flex flex-col items-end shrink-0 gap-0.5 pt-0.5">
                  <span class="font-body font-medium text-brand-gold text-[15px] tabular-nums">{item.price.toFixed(2)} €</span>
                  {item.unit && <span class="font-body text-[11px] text-brand-stone/50 uppercase tracking-wide">{item.unit}</span>}
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
      <p class="font-body text-[11px] text-brand-stone/50 italic text-center border-t border-brand-sand/40 pt-6">
        {t.footer_note}
      </p>
    </div>
  </section>
  <section class="bg-brand-blue py-10">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href={`/${lang}/mesa`} class="font-body text-sm uppercase tracking-widest text-white/60 hover:text-brand-gold transition-colors duration-200">{t.back_link}</a>
      <span class="hidden sm:block text-white/20">|</span>
      <a href={`/${lang}/reservar`} class="inline-flex items-center px-6 py-3 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium transition-colors duration-200">
        {t.book_link}
      </a>
    </div>
  </section>
</Layout>
