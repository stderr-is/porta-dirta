---
/**
 * src/pages/[lang]/index.astro — Dynamic homepage for all locales
 */

import Layout from '../../layouts/Layout.astro';
import GarlandDivider from '../../components/GarlandDivider.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

export async function getStaticPaths() {
  return ['en', 'fr', 'de'].map((lang) => {
    return {
      params: { lang },
    };
  });
}
---

<Layout
  title={t('home.meta_title')}
  description={t('home.meta_description')}
  lang={lang}
  ogImage={t('home.og_image')}
>
  <link rel="preload" as="image" href="/assets/video/hero-poster.jpg" fetchpriority="high" slot="head" />

  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["Organization", "LodgingBusiness"],
    "name": "Porta D'irta",
    "url": `https://www.portadirta.com/${lang}/`,
    "logo": "https://www.portadirta.com/assets/logos/logo-negativo.png",
    "telephone": "+34644026066",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Camí del Pebret, s/n",
      "addressLocality": "Peñíscola",
      "addressRegion": "Castellón",
      "postalCode": "12598",
      "addressCountry": "ES"
    },
    "sameAs": [
      "https://instagram.com/portadirta",
      "https://facebook.com/portadirta"
    ]
  })} />

  <!-- SECTION 1: HERO -->
  <section
    class="relative flex flex-col items-center justify-center min-h-screen w-full overflow-hidden"
    aria-label="Hero — Porta D'irta"
  >
    <video
      id="hero-video"
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/assets/video/hero-poster.jpg"
      aria-hidden="true"
    >
      <source src="/assets/video/hero.webm" type="video/webm" />
      <source src="/assets/video/hero.mp4" type="video/mp4" />
    </video>

    <img
      id="hero-video-fallback"
      src="/assets/video/hero-poster.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover hidden"
      aria-hidden="true"
    />

    <div class="absolute inset-0 bg-brand-forest/55 pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 flex flex-col items-center gap-6 px-4 py-20 md:py-32 text-center w-full max-w-3xl mx-auto">
      <h1 class="font-display font-light italic text-5xl sm:text-8xl md:text-9xl text-white leading-none tracking-tight">
        Porta D'irta
      </h1>

      <p class="font-body uppercase tracking-[0.2em] sm:tracking-[0.4em] text-brand-sand text-sm">
        {t('home.hero_location')}
      </p>

      <GarlandDivider light />

      <!-- Restaurant Priority CTA -->
            <!-- Botones duales de reserva -->
      <div class="flex flex-col sm:flex-row items-center gap-4 mt-6">
        <!-- BOTÓN MESA -->
        <a
          href={getRelativeLocaleUrl(lang, 'restaurante') + '#reservar'}
          class="inline-flex items-center gap-2 px-8 py-4 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-bold transition-all shadow-lg"
        >
          {t('home.cta_restaurant')}
        </a>
        
        <!-- BOTÓN HABITACIÓN (BOOKING) -->
        <a
          href="https://www.booking.com/hotel/es/porta-d-irta.es.html"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-sm border border-white/60 hover:border-white text-white font-body text-sm uppercase tracking-widest font-medium transition-all backdrop-blur-sm bg-white/5"
        >
          {t('home.cta_hotel')}
          <img src="https://upload.wikimedia.org/wikipedia/commons/b/be/Booking.com_logo.svg" class="h-3.5 invert brightness-0 invert" alt="Booking" />
        </a>
      </div>
    </div>

    <div
      class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40 animate-bounce z-10"
      aria-hidden="true"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"     
        fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </div>
  </section>

  <script>
    const heroVideo = document.getElementById('hero-video');
    const heroFallback = document.getElementById('hero-video-fallback');

    if (heroVideo instanceof HTMLVideoElement && heroFallback instanceof HTMLImageElement) { 
      const showFallback = () => {
        heroVideo.classList.add('hidden');
        heroFallback.classList.remove('hidden');
      };

      heroVideo.addEventListener('error', showFallback);
      heroVideo.addEventListener('stalled', showFallback);

      const maybePromise = heroVideo.play();
      if (maybePromise && typeof maybePromise.catch === 'function') {
        maybePromise.catch(showFallback);
      }
    }
  </script>

  <!-- SECTION 2: THE RESTAURANT -->
  <section
    id="restaurante"
    class="relative min-h-screen flex items-center bg-brand-blue py-24 md:py-32 overflow-hidden"
    aria-label="Restaurant"
  >
    <div class="absolute inset-0" aria-hidden="true">
      <img src={t('home.restaurant_hero_img')} alt="" class="w-full h-full object-cover opacity-30" loading="lazy" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-t from-brand-forest/80 via-brand-forest/45 to-brand-forest/20"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 w-full text-center flex flex-col items-center gap-8">
      <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
        {t('home.restaurant_label')}
      </span>
      <h2 class="font-display font-light italic text-5xl md:text-7xl text-white leading-tight">
        {t('home.restaurant_heading')}
      </h2>
      <GarlandDivider light />
      <p class="font-body text-white/75 text-lg leading-relaxed max-w-xl">
        {t('home.restaurant_body')}
      </p>

      <div class="flex flex-wrap justify-center gap-3">
        <span class="font-body text-xs uppercase tracking-widest text-white border border-white/30 rounded-full px-5 py-2">
          {t('home.pill_menu_dia')}
        </span>
        <span class="font-body text-xs uppercase tracking-widest text-white border border-white/30 rounded-full px-5 py-2">
          {t('home.pill_carta')}
        </span>
        <span class="font-body text-xs uppercase tracking-widest text-white border border-white/30 rounded-full px-5 py-2">
          {t('home.pill_eventos')}
        </span>
      </div>

      <a
        href={getRelativeLocaleUrl(lang, 'restaurante')}
        class="inline-flex items-center gap-2 px-8 py-4 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium transition-colors duration-300 shadow-lg mt-2"
      >
        {t('home.restaurant_cta')}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>        
        </svg>
      </a>
    </div>

    <div class="absolute bottom-0 left-0 w-full translate-y-1/2 z-10">
      <GarlandDivider />
    </div>
  </section>

  <!-- SECTION 3: THE HOTEL -->
  <section
    id="hotel"
    class="bg-brand-cream min-h-screen flex items-center py-24 md:py-32"
    aria-labelledby="hotel-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="flex flex-col gap-6">
          <span class="font-body text-xs uppercase tracking-[0.35em] text-brand-gold">       
            {t('home.hotel_label')}
          </span>
          <h2
            id="hotel-heading"
            class="font-display font-light text-5xl md:text-6xl text-brand-blue leading-tight"
          >
            {t('home.hotel_heading')}
          </h2>
          <GarlandDivider />
          <p class="font-body text-brand-stone text-lg leading-relaxed max-w-md">
            {t('home.hotel_body')}
          </p>
          <div class="mt-2">
            <a
              https://www.booking.com/hotel/es/porta-d-irta.es.html" target="_blank" rel="noopener noreferrer
              class="inline-flex items-center gap-2 px-8 py-4 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium transition-colors duration-300 shadow-md"
            >
              {t('home.hotel_cta')}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>  
              </svg>
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="overflow-hidden rounded-sm">
            <img src={t('home.img_url_room1')} alt={t('home.img_alt_room1')} class="w-full h-48 md:h-56 object-cover transition-transform duration-500 hover:scale-105" loading="lazy" decoding="async" />
          </div>
          <div class="overflow-hidden rounded-sm">
            <img src={t('home.img_url_room2')} alt={t('home.img_alt_room2')} class="w-full h-48 md:h-56 object-cover transition-transform duration-500 hover:scale-105" loading="lazy" decoding="async" />
          </div>
          <div class="overflow-hidden rounded-sm">
            <img src={t('home.img_url_room3')} alt={t('home.img_alt_room3')} class="w-full h-48 md:h-56 object-cover transition-transform duration-500 hover:scale-105" loading="lazy" decoding="async" />
          </div>
          <div class="overflow-hidden rounded-sm">
            <img src={t('home.img_url_room4')} alt={t('home.img_alt_room4')} class="w-full h-48 md:h-56 object-cover transition-transform duration-500 hover:scale-105" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4 — EXPERIENCES -->
  <section
    class="bg-brand-cream py-24 md:py-32"
    aria-labelledby="experiencias-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center flex flex-col items-center gap-4 mb-16">
        <span class="font-body text-xs uppercase tracking-[0.35em] text-brand-gold">
          {t('home.experiences_label')}
        </span>
        <h2 id="experiencias-heading" class="font-display font-light text-5xl md:text-6xl text-brand-blue leading-tight">
          {t('home.experiences_heading')}
        </h2>
        <GarlandDivider />
        <p class="font-body text-brand-stone text-lg leading-relaxed max-w-lg">
          {t('home.experiences_body')}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <article class="group bg-white rounded-sm shadow-md overflow-hidden border border-transparent hover:border-brand-gold transition-colors duration-300">
          <div class="overflow-hidden">
            <img src={t('home.exp1_img_url')} alt={t('home.exp1_img_alt')} class="w-full h-52 object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
          </div>
          <div class="p-6 flex flex-col gap-3">
            <h3 class="font-display font-light text-2xl text-brand-blue leading-snug">{t('home.exp1_title')}</h3>
            <p class="font-body text-brand-stone text-sm leading-relaxed">{t('home.exp1_body')}</p>
          </div>
        </article>

        <article class="group bg-white rounded-sm shadow-md overflow-hidden border border-transparent hover:border-brand-gold transition-colors duration-300">
          <div class="overflow-hidden">
            <img src={t('home.exp2_img_url')} alt={t('home.exp2_img_alt')} class="w-full h-52 object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
          </div>
          <div class="p-6 flex flex-col gap-3">
            <h3 class="font-display font-light text-2xl text-brand-blue leading-snug">{t('home.exp2_title')}</h3>
            <p class="font-body text-brand-stone text-sm leading-relaxed">{t('home.exp2_body')}</p>
          </div>
        </article>

        <article class="group bg-white rounded-sm shadow-md overflow-hidden border border-transparent hover:border-brand-gold transition-colors duration-300">
          <div class="overflow-hidden">
            <img src={t('home.exp3_img_url')} alt={t('home.exp3_img_alt')} class="w-full h-52 object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
          </div>
          <div class="p-6 flex flex-col gap-3">
            <h3 class="font-display font-light text-2xl text-brand-blue leading-snug">{t('home.exp3_title')}</h3>
            <p class="font-body text-brand-stone text-sm leading-relaxed">{t('home.exp3_body')}</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- SECTION 5: FINAL CTA -->
  <section
    class="bg-brand-blue py-24 md:py-32"
    aria-labelledby="cta-heading"
  >
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center gap-8">
      <h2 id="cta-heading" class="font-display font-light italic text-5xl md:text-7xl text-white leading-tight">
        {t('home.cta_heading')}
      </h2>
      <GarlandDivider light />
      <p class="font-body text-white/70 text-lg leading-relaxed max-w-lg">
        {t('home.cta_body')}
      </p>

            <div class="flex flex-col sm:flex-row items-center gap-4 mt-2">
        <a
          href={getRelativeLocaleUrl(lang, 'restaurante') + '#reservar'}
          class="inline-flex items-center gap-2 px-8 py-4 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-bold transition-all shadow-lg"
        >
          {t('home.cta_restaurant')}
        </a>
        <a
          href="https://www.booking.com/hotel/es/porta-d-irta.es.html"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-sm border border-white/60 hover:border-white text-white font-body text-sm uppercase tracking-widest font-medium transition-all"
        >
          {t('home.cta_hotel')}
          <img src="https://upload.wikimedia.org/wikipedia/commons/b/be/Booking.com_logo.svg" class="h-3.5 invert brightness-0 invert" alt="Booking" />
        </a>
      </div>
    </div>
  </section>
</Layout>