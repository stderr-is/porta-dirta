---
/**
 * src/pages/[lang]/reservar.astro — Dynamic reservations page for all locales
 */

import Layout from '../../layouts/Layout.astro';
import GarlandDivider from '../../components/GarlandDivider.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

export async function getStaticPaths() {
  return ['en', 'fr', 'de'].map((lang) => {
    return {
      params: { lang },
    };
  });
}
---

<Layout
  title={t('reservar.meta_title')}
  description={t('reservar.meta_description')}
  lang={lang}
  noindex={true}
>

  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.portadirta.com/en/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Book",
        "item": "https://www.portadirta.com/en/reservar"
      }
    ]
  })} />

  <!-- ── Page header ─────────────────────────────────────────────── -->
  <section class="bg-brand-blue py-20 md:py-32 pb-10 text-center">

    <p class="text-brand-gold font-body tracking-[0.25em] text-sm uppercase mb-4">
      {t('reservar.hero_label')}
    </p>

    <h1 class="font-display italic text-5xl md:text-6xl text-white leading-tight mb-3">
      {t('reservar.hero_heading')}
    </h1>

    <div class="flex justify-center mb-6"><GarlandDivider /></div>

    <!-- Summary strip — filled by JS from URL params -->
    <div
      id="booking-summary"
      class="hidden max-w-xl mx-auto px-6 py-3 rounded-xl bg-white/10 border border-white/20 backdrop-blur-sm
             font-body text-sm text-white/80 flex flex-wrap items-center justify-center gap-x-5 gap-y-1 mb-6"
    >
      <span id="summary-dates" class="flex items-center gap-2">
        <svg class="w-4 h-4 text-brand-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
        </svg>
        <span id="summary-dates-text"></span>
      </span>
      <span id="summary-guests" class="flex items-center gap-2">
        <svg class="w-4 h-4 text-brand-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <span id="summary-guests-text"></span>
      </span>
      <a href={getRelativeLocaleUrl(lang, 'hotel') + '#reservar'} class="text-brand-gold/80 hover:text-brand-gold underline text-xs transition-colors">Modify</a>
    </div>

    <p class="font-body text-white/60 text-sm max-w-md mx-auto">
      {t('reservar.booking_guarantee')}
    </p>

  </section>

  <!-- ── Booking iframe ──────────────────────────────────────────── -->
  <section class="bg-brand-cream min-h-screen">

    <!-- Loading state shown until iframe fires load event -->
    <div id="booking-loader" class="flex flex-col items-center justify-center py-24 gap-4">
      <div class="w-8 h-8 border-2 border-brand-gold border-t-transparent rounded-full animate-spin"></div>
      <p class="font-body text-brand-stone text-sm">Loading availability…</p>
    </div>

    <iframe
      id="beds24-iframe"
      src=""
      width="100%"
      style="min-height: 85vh; border: none; display: none;"
      title="Book a room at Porta D'irta"
      loading="eager"
    ></iframe>

  </section>

  <script is:inline define:vars={{
    translatedNight: t('reservar.night'),
    translatedNights: t('reservar.nights'),
    translatedAdult: t('reservar.adult'),
    translatedAdults: t('reservar.adults'),
    translatedChild: t('reservar.child'),
    translatedChildren: t('reservar.children'),
  }}>
    (function () {
      const PROP_ID = '318433';
      const BASE    = 'https://beds24.com/booking2.php';

      const incoming = new URLSearchParams(window.location.search);
      const out      = new URLSearchParams();

      out.set('propid', PROP_ID);

      // Forward params — Beds24 booking2.php uses checkin/checkout/numadult/numchild/lang
      ['checkin', 'checkout', 'numadult', 'numchild', 'room', 'lang'].forEach(function (key) {
        if (incoming.has(key)) out.set(key, incoming.get(key));
      });

      // Fallback: if no lang param, use the page's HTML lang attribute
      if (!incoming.has('lang')) {
        var pageLang = document.documentElement.lang;
        if (pageLang) out.set('lang', pageLang);
      }

      // ── Booking summary strip ──────────────────────────────────
      var checkin  = incoming.get('checkin');
      var checkout = incoming.get('checkout');
      var adults   = incoming.get('numadult') || '2';
      var children = incoming.get('numchild') || '0';

      if (checkin && checkout) {
        var fmt = new Intl.DateTimeFormat(document.documentElement.lang || 'en-GB', { day: 'numeric', month: 'short' });
        var ci  = new Date(checkin  + 'T00:00:00');
        var co  = new Date(checkout + 'T00:00:00');
        var nights = Math.round((co - ci) / 86400000);

        document.getElementById('summary-dates-text').textContent =
          fmt.format(ci) + ' → ' + fmt.format(co) + ' · ' + nights + (nights === 1 ? ' ' + translatedNight : ' ' + translatedNights);

        var guestParts = [adults + (adults === '1' ? ' ' + translatedAdult : ' ' + translatedAdults)];
        if (parseInt(children) > 0) guestParts.push(children + (children === '1' ? ' ' + translatedChild : ' ' + translatedChildren));
        document.getElementById('summary-guests-text').textContent = guestParts.join(' · ');

        var summary = document.getElementById('booking-summary');
        summary.classList.remove('hidden');
        summary.classList.add('flex');
      }

      // ── Load iframe ────────────────────────────────────────────
      const iframe = document.getElementById('beds24-iframe');
      const loader = document.getElementById('booking-loader');

      iframe.src = BASE + '?' + out.toString();

      iframe.addEventListener('load', function () {
        loader.style.display = 'none';
        iframe.style.display = 'block';
      });
    })();
  </script>

</Layout>
