---
import Layout from '../../layouts/Layout.astro';
import GarlandDivider from '../../components/GarlandDivider.astro';
import FormHandler from '../../components/FormHandler.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dateFormatter = new Intl.DateTimeFormat(lang, { day: 'numeric', month: 'short', year: 'numeric' });

export async function getStaticPaths() {
  return ['en', 'fr', 'de'].map((lang) => ({ params: { lang } }));
}

const eventosLocales = (await getCollection('eventos-locales'))
  .filter((e) => e.data.fecha >= new Date(new Date().setHours(0, 0, 0, 0)))
  .sort((a, b) => a.data.fecha.getTime() - b.data.fecha.getTime());

const formWebhookUrl = import.meta.env.PUBLIC_N8N_EVENTOS_WEBHOOK ?? import.meta.env.PUBLIC_N8N_WEBHOOK ?? 'REPLACE_WITH_N8N_WEBHOOK_URL';
---

<Layout
  title={t('eventos.meta_title')}
  description={t('eventos.meta_description')}
  lang={lang}
  ogImage="/assets/images/property-aerial-pool.jpg"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": lang === 'es' ? 'Inicio' : lang === 'fr' ? 'Accueil' : lang === 'de' ? 'Startseite' : 'Home',
        "item": `https://www.portadirta.com/${lang === 'es' ? '' : lang + '/'}`
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": t('nav.eventos'),
        "item": `https://www.portadirta.com/${lang === 'es' ? '' : lang + '/'}eventos`
      }
    ]
  })} />

  <section class="relative flex items-center justify-center min-h-screen w-full overflow-hidden" aria-label={t('eventos.hero_label')}>
    <img src="/assets/images/property-aerial-dusk.jpg" alt={t('eventos.intro_img1_alt')} class="absolute inset-0 w-full h-full object-cover" loading="eager" decoding="async" />
    <div class="absolute inset-0 bg-brand-forest/52" aria-hidden="true"></div>
    <div class="relative z-10 flex flex-col items-center gap-6 px-4 text-center max-w-4xl mx-auto">
      <p class="font-body uppercase tracking-[0.3em] text-brand-gold text-sm font-medium">{t('eventos.hero_label')}</p>
      <h1 class="font-display italic text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-white leading-tight">
        {t('eventos.hero_heading')}
      </h1>
      <GarlandDivider light />
      <p class="font-body text-base sm:text-lg text-white/80 max-w-xl leading-relaxed">
        {t('eventos.hero_body')}
      </p>
      <div class="flex flex-wrap justify-center gap-3 mt-2">
        <span class="bg-white/20 backdrop-blur-sm border border-white/30 text-white font-body text-sm px-5 py-2 rounded-full">{t('eventos.hero_pill1')}</span>
        <span class="bg-white/20 backdrop-blur-sm border border-white/30 text-white font-body text-sm px-5 py-2 rounded-full">{t('eventos.hero_pill2')}</span>
        <span class="bg-white/20 backdrop-blur-sm border border-white/30 text-white font-body text-sm px-5 py-2 rounded-full">{t('eventos.hero_pill3')}</span>
      </div>
      <a href="#espacio" class="mt-6 inline-flex items-center gap-2 font-body text-white/70 text-xs uppercase tracking-widest hover:text-white transition-colors duration-300" aria-label={t('eventos.hero_scroll_aria')}>
        {t('eventos.hero_scroll_aria')}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </a>
    </div>
  </section>

  <section id="espacio" class="bg-brand-cream py-24 md:py-32 px-4" aria-labelledby="eventos-intro-heading">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="flex flex-col gap-6">
          <p class="font-body uppercase tracking-[0.3em] text-brand-gold text-xs font-medium">{t('eventos.intro_label')}</p>
          <h2 id="eventos-intro-heading" class="font-display font-light text-3xl sm:text-4xl md:text-5xl text-brand-blue leading-tight">
            {t('eventos.intro_heading')}
          </h2>
          <GarlandDivider />
          <p class="font-body text-brand-stone text-lg leading-relaxed">{t('eventos.intro_body1')}</p>
          <p class="font-body text-brand-stone text-lg leading-relaxed">{t('eventos.intro_body2')}</p>
        </div>
        <div class="flex flex-col gap-4">
          <img src="/assets/images/property-aerial-twilight.jpg" alt={t('eventos.intro_img1_alt')} class="w-full h-64 object-cover rounded-xl shadow-md" loading="lazy" decoding="async" />
          <img src="/assets/images/property-aerial-pool.jpg" alt={t('eventos.intro_img2_alt')} class="w-full h-64 object-cover rounded-xl shadow-md" loading="lazy" decoding="async" />
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-20 pt-12 border-t border-brand-sand/40">
        <div class="flex flex-col items-center text-center gap-3">
          <div class="w-12 h-12 rounded-full bg-brand-blue/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0D2B45" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <p class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">{t('eventos.feature1_label')}</p>
          <p class="font-display text-2xl text-brand-blue font-light">{t('eventos.feature1_value')}</p>
        </div>
        <div class="flex flex-col items-center text-center gap-3">
          <div class="w-12 h-12 rounded-full bg-brand-blue/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0D2B45" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <p class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">{t('eventos.feature2_label')}</p>
          <p class="font-display text-2xl text-brand-blue font-light">{t('eventos.feature2_value')}</p>
        </div>
        <div class="flex flex-col items-center text-center gap-3">
          <div class="w-12 h-12 rounded-full bg-brand-blue/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0D2B45" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
          </div>
          <p class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">{t('eventos.feature3_label')}</p>
          <p class="font-display text-2xl text-brand-blue font-light">{t('eventos.feature3_value')}</p>
        </div>
        <div class="flex flex-col items-center text-center gap-3">
          <div class="w-12 h-12 rounded-full bg-brand-blue/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0D2B45" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
          </div>
          <p class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">{t('eventos.feature4_label')}</p>
          <p class="font-display text-2xl text-brand-blue font-light">{t('eventos.feature4_value')}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-brand-blue py-24 md:py-32 px-4" aria-labelledby="eventos-types-heading">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <p class="font-body uppercase tracking-[0.3em] text-brand-gold text-xs font-medium mb-4">{t('eventos.types_label')}</p>
        <h2 id="eventos-types-heading" class="font-display font-light italic text-3xl sm:text-4xl md:text-5xl text-white">
          {t('eventos.types_heading')}
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <article class="backdrop-blur-sm bg-white/10 border border-white/20 rounded-xl overflow-hidden flex flex-col">
          <div class="relative">
            <img src="/assets/images/property-aerial-dusk.jpg" alt={t('eventos.card1_title')} class="w-full h-56 object-cover" loading="lazy" decoding="async" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-forest/45 to-transparent"></div>
          </div>
          <div class="flex flex-col gap-4 p-7 flex-1">
            <h3 class="font-display text-3xl text-white font-light">{t('eventos.card1_title')}</h3>
            <p class="font-body text-white/80 text-base leading-relaxed">{t('eventos.card1_body')}</p>
            <div class="mt-auto pt-4">
              <a href={getRelativeLocaleUrl(lang, 'contacto')} class="inline-flex items-center justify-center w-full px-6 py-3 bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium rounded-lg transition-colors duration-300">
                {t('eventos.card1_cta')}
              </a>
            </div>
          </div>
        </article>
        <article class="backdrop-blur-sm bg-white/10 border border-white/20 rounded-xl overflow-hidden flex flex-col">
          <div class="relative">
            <img src="/assets/images/property-aerial-pool.jpg" alt={t('eventos.card2_title')} class="w-full h-56 object-cover" loading="lazy" decoding="async" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-forest/45 to-transparent"></div>
          </div>
          <div class="flex flex-col gap-4 p-7 flex-1">
            <h3 class="font-display text-3xl text-white font-light">{t('eventos.card2_title')}</h3>
            <p class="font-body text-white/80 text-base leading-relaxed">{t('eventos.card2_body')}</p>
            <div class="mt-auto pt-4">
              <a href={getRelativeLocaleUrl(lang, 'contacto')} class="inline-flex items-center justify-center w-full px-6 py-3 bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium rounded-lg transition-colors duration-300">
                {t('eventos.card2_cta')}
              </a>
            </div>
          </div>
        </article>
        <article class="backdrop-blur-sm bg-white/10 border border-white/20 rounded-xl overflow-hidden flex flex-col">
          <div class="relative">
            <img src="/assets/images/property-aerial-twilight.jpg" alt={t('eventos.card3_title')} class="w-full h-56 object-cover" loading="lazy" decoding="async" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-forest/45 to-transparent"></div>
          </div>
          <div class="flex flex-col gap-4 p-7 flex-1">
            <h3 class="font-display text-3xl text-white font-light">{t('eventos.card3_title')}</h3>
            <p class="font-body text-white/80 text-base leading-relaxed">{t('eventos.card3_body')}</p>
            <div class="mt-auto pt-4">
              <a href={getRelativeLocaleUrl(lang, 'contacto')} class="inline-flex items-center justify-center w-full px-6 py-3 bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium rounded-lg transition-colors duration-300">
                {t('eventos.card3_cta')}
              </a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="bg-brand-cream py-24 md:py-32 px-4" aria-labelledby="eventos-agenda-heading">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <p class="font-body uppercase tracking-[0.3em] text-brand-gold text-xs font-medium mb-4">{t('eventos.agenda_label')}</p>
        <h2 id="eventos-agenda-heading" class="font-display font-light text-3xl sm:text-4xl md:text-5xl text-brand-blue">
          {t('eventos.agenda_heading')}
        </h2>
      </div>

      {eventosLocales.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {eventosLocales.map((ev) => (
            <article class="bg-white rounded-xl overflow-hidden shadow-md flex flex-col">
              <div class="relative">
                <img src={ev.data.imagen ?? '/assets/images/property-aerial-pool.jpg'} alt={ev.data.titulo} class="w-full h-48 object-cover" loading="lazy" decoding="async" />
                <div class="absolute top-4 left-4">
                  <span class="bg-brand-gold text-white font-body text-xs font-medium uppercase tracking-wide px-3 py-1 rounded-full shadow">
                    {dateFormatter.format(ev.data.fecha)}
                    {ev.data.fechaFin && ` – ${dateFormatter.format(ev.data.fechaFin)}`}
                  </span>
                </div>
              </div>
              <div class="flex flex-col gap-3 p-6 flex-1">
                <h3 class="font-display text-2xl text-brand-blue font-light leading-snug">{ev.data.titulo}</h3>
                <p class="font-body text-brand-stone text-sm leading-relaxed">{ev.data.descripcion}</p>
                <div class="flex items-center justify-between mt-auto pt-4 border-t border-brand-cream">
                  {ev.data.precio ? (
                    <span class="font-display text-xl text-brand-blue">€{ev.data.precio}<span class="font-body text-sm text-brand-stone font-normal"> / persona</span></span>
                  ) : (
                    <span class="font-body text-sm text-brand-stone italic">{t('eventos.agenda_free')}</span>
                  )}
                  {ev.data.ticketsUrl ? (
                    <a href={ev.data.ticketsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-body text-xs uppercase tracking-widest text-brand-gold hover:text-brand-stone font-medium transition-colors duration-300" aria-label={`${t('eventos.agenda_buy')} ${ev.data.titulo}`}>
                      {t('eventos.agenda_buy')}
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                  ) : (
                    <a href={getRelativeLocaleUrl(lang, 'contacto')} class="inline-flex items-center gap-1 font-body text-xs uppercase tracking-widest text-brand-gold hover:text-brand-stone font-medium transition-colors duration-300">
                      {t('eventos.agenda_more')}
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </a>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="text-center font-body text-brand-stone">{t('eventos.agenda_empty')}</p>
      )}
    </div>
  </section>

  <section id="contacto" class="bg-brand-blue py-24 md:py-32 px-4" aria-labelledby="eventos-contact-heading">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <p class="font-body uppercase tracking-[0.3em] text-brand-gold text-xs font-medium mb-4">{t('eventos.contact_label')}</p>
        <h2 id="eventos-contact-heading" class="font-display font-light italic text-3xl sm:text-4xl md:text-5xl text-white leading-tight">
          {t('eventos.contact_heading')}
        </h2>
        <p class="font-body text-white/60 text-base mt-4 leading-relaxed">{t('eventos.contact_body')}</p>
      </div>

      <div class="backdrop-blur-sm bg-white/10 border border-white/20 rounded-2xl p-4 sm:p-8 md:p-12">
        <FormHandler
          formId="eventos-form"
          webhookUrl={formWebhookUrl}
          successMessage={t('eventos.form_success')}
          sendingText={lang === 'es' ? 'Enviando...' : lang === 'fr' ? 'Envoi en cours...' : lang === 'de' ? 'Wird gesendet...' : 'Sending...'}
          errorMessage={t('eventos.form_error')}
        >
          <input type="hidden" name="source" value="eventos" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="nombre" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{t('eventos.form_name_label')}</label>
              <input type="text" id="nombre" name="nombre" required placeholder={t('eventos.form_name_placeholder')} class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="email" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{t('eventos.form_email_label')}</label>
              <input type="email" id="email" name="email" required placeholder={t('eventos.form_email_placeholder')} class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="telefono" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{t('eventos.form_phone_label')}</label>
              <input type="tel" id="telefono" name="telefono" placeholder={t('eventos.form_phone_placeholder')} class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="tipo-evento" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{t('eventos.form_type_label')}</label>
              <select id="tipo-evento" name="tipo-evento" required class="bg-white/20 border border-white/30 text-white rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200 appearance-none">
                <option value="" disabled selected class="text-brand-blue">{t('eventos.form_type_placeholder')}</option>
                <option value="boda" class="text-brand-blue">{t('eventos.form_type_opt1')}</option>
                <option value="comunion" class="text-brand-blue">{t('eventos.form_type_opt2')}</option>
                <option value="cumpleanos" class="text-brand-blue">{t('eventos.form_type_opt3')}</option>
                <option value="corporativo" class="text-brand-blue">{t('eventos.form_type_opt4')}</option>
                <option value="otro" class="text-brand-blue">{t('eventos.form_type_opt5')}</option>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="fecha" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{t('eventos.form_date_label')}</label>
              <input type="date" id="fecha" name="fecha" class="bg-white/20 border border-white/30 text-white rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200 [color-scheme:dark]" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="invitados" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{t('eventos.form_guests_label')}</label>
              <input type="number" id="invitados" name="invitados" min="1" max="120" placeholder={t('eventos.form_guests_placeholder')} class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200" />
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="mensaje" class="font-body text-xs uppercase tracking-widest text-white/70 font-medium">{t('eventos.form_message_label')}</label>
            <textarea id="mensaje" name="mensaje" rows="5" placeholder={t('eventos.form_message_placeholder')} class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold focus:bg-white/25 transition-colors duration-200 resize-y"></textarea>
          </div>

          <div class="flex items-start gap-3">
            <input type="checkbox" id="rgpd" name="rgpd" required class="mt-1 h-4 w-4 flex-shrink-0 rounded border-white/40 bg-white/20 text-brand-gold focus:ring-brand-gold" />
            <label for="rgpd" class="font-body text-xs text-white/70 leading-relaxed">
              {t('contacto.rgpd_text_part1')}
              <a href="/privacidad" target="_blank" class="underline hover:text-brand-gold">{t('contacto.rgpd_privacy_policy')}</a>
              {t('contacto.rgpd_text_part2')}
            </label>
          </div>

          <div class="flex flex-col items-center gap-4 pt-2">
            <button type="submit" class="inline-flex items-center justify-center px-10 py-4 bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium rounded-lg transition-colors duration-300 shadow-lg w-full sm:w-auto">
              {t('eventos.form_submit')}
            </button>
            <p class="font-body text-white/50 text-xs text-center">info@portadirta.com</p>
          </div>
        </FormHandler>
      </div>
    </div>
  </section>

  <section class="bg-brand-cream py-24 md:py-32 px-4 border-t border-brand-sand/30" aria-labelledby="eventos-more-heading">
    <div class="max-w-5xl mx-auto">
      <p id="eventos-more-heading" class="font-body text-center uppercase tracking-[0.3em] text-brand-stone text-xs font-medium mb-12">
        {t('eventos.more_label')}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
