---
/**
 * src/pages/[lang]/mesa.astro — QR table hub (multilingual)
 */

import fs from 'node:fs';
import Layout from '../../layouts/Layout.astro';
import menuFallback from '../../data/menu.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'de' } },
  ];
}

const { lang } = Astro.params;
const langParam = lang as string;
if (!langParam || !['en', 'fr', 'de'].includes(langParam)) {
  return new Response(null, { status: 404 });
}

const ui = {
  en: {
    subtitle: 'Restaurant',
    description: "View all menus for the Porta D'irta restaurant.",
    desayuno_title: 'Breakfast',
    desayuno_desc: 'Mediterranean breakfast',
    taperia_title: 'The Tapas Bar',
    taperia_desc: 'Tapas · 10:00 \u2013 13:00',
    menu_title: 'Holy Week Menu',
    menu_desc: 'Special Menu',
    streetfood_title: 'Street Food',
    streetfood_desc: 'by Fifty-Five · 18:00 \u2013 22:00',
    bebidas_title: 'Drinks',
    bebidas_desc: 'Wines · Beers · Cocktails',
    reservar: 'Book a table',
  },
  fr: {
    subtitle: 'Restaurant',
    description: "Consultez tous les menus du restaurant Porta D'irta.",
    desayuno_title: 'Petit d\u00e9jeuner',
    desayuno_desc: 'Petit-d\u00e9jeuner m\u00e9diterran\u00e9en',
    taperia_title: 'Le bar \u00e0 tapas',
    taperia_desc: 'Tapas · 10h00 \u2013 13h00',
    menu_title: 'Menu de Semaine Sainte',
    menu_desc: 'Menu Sp\u00e9cial',
    streetfood_title: 'Cuisine de rue',
    streetfood_desc: 'by Fifty-Five · 18h00 \u2013 22h00',
    bebidas_title: 'Boissons',
    bebidas_desc: 'Vins · Bi\u00e8res · Cocktails',
    reservar: 'R\u00e9server une table',
  },
  de: {
    subtitle: 'Restaurant',
    description: "Alle Men\u00fcs des Restaurants Porta D'irta einsehen.",
    desayuno_title: 'Fr\u00fchst\u00fcck',
    desayuno_desc: 'Mediterranes Fr\u00fchst\u00fcck',
    taperia_title: 'Die Tapas-Bar',
    taperia_desc: 'Tapas · 10:00 \u2013 13:00',
    menu_title: 'Men\u00fc Karwoche',
    menu_desc: 'Spezielles Men\u00fc',
    streetfood_title: 'Straßenessen',
    streetfood_desc: 'by Fifty-Five · 18:00 \u2013 22:00',
    bebidas_title: 'Getr\u00e4nke',
    bebidas_desc: 'Weine · Biere · Cocktails',
    reservar: 'Tisch reservieren',
  },
};

const t = ui[langParam as keyof typeof ui];

let menu: typeof menuFallback = menuFallback;
const menuDataPath = process.env.MENU_DATA_PATH;
if (menuDataPath) {
  try { menu = JSON.parse(fs.readFileSync(`${menuDataPath}/menu.json`, 'utf-8')); } catch {}
}
---

<Layout
  title={`${t.subtitle} \u2014 Mesa`}
  description={t.description}
  noindex={true}
>

  <div class="min-h-screen bg-brand-blue flex flex-col">

    <!-- \u2500\u2500 Brand header \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 -->
    <header class="py-20 md:py-32 pb-6 text-center px-4">
      <img src="/assets/logos/logo-negativo.png" alt="Porta D'irta" class="h-10 w-auto mx-auto mb-4" loading="eager" />
      <p class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">{t.subtitle}</p>
    </header>

    <!-- \u2500\u2500 Menu cards \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 -->
    <main class="flex-1 flex flex-col justify-center px-4 sm:px-6 pb-8 max-w-lg mx-auto w-full gap-3">

      <!-- Desayuno -->
      <a
        href={`/${langParam}/desayuno`}
        class="group flex items-center justify-between gap-4 bg-white/10 hover:bg-white/15 active:bg-white/20 border border-white/20 hover:border-brand-gold/50 rounded-2xl px-6 py-5 transition-all duration-200"
      >
        <div class="flex items-center gap-4">
          <div class="shrink-0 w-10 h-10 rounded-full bg-brand-gold/15 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-xl text-white group-hover:text-brand-gold transition-colors duration-200 leading-tight">{t.desayuno_title}</p>
            <p class="font-body text-xs text-white/50 mt-0.5">{t.desayuno_desc}</p>
          </div>
        </div>
        <svg class="w-5 h-5 text-brand-gold/50 group-hover:text-brand-gold group-hover:translate-x-0.5 transition-all duration-200 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- La Taperia -->
      <a
        href={`/${langParam}/taperia`}
        class="group flex items-center justify-between gap-4 bg-white/10 hover:bg-white/15 active:bg-white/20 border border-white/20 hover:border-brand-gold/50 rounded-2xl px-6 py-5 transition-all duration-200"
      >
        <div class="flex items-center gap-4">
          <div class="shrink-0 w-10 h-10 rounded-full bg-brand-gold/15 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-xl text-white group-hover:text-brand-gold transition-colors duration-200 leading-tight">{t.taperia_title}</p>
            <p class="font-body text-xs text-white/50 mt-0.5">{t.taperia_desc}</p>
          </div>
        </div>
        <svg class="w-5 h-5 text-brand-gold/50 group-hover:text-brand-gold group-hover:translate-x-0.5 transition-all duration-200 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- Menu Semana Santa (highlighted) -->
      <a
        href={`/${langParam}/menu`}
        class="group flex items-center justify-between gap-4 bg-brand-gold/10 hover:bg-brand-gold/15 active:bg-brand-gold/20 border border-brand-gold/30 hover:border-brand-gold/60 rounded-2xl px-6 py-5 transition-all duration-200"
      >
        <div class="flex items-center gap-4">
          <div class="shrink-0 w-10 h-10 rounded-full bg-brand-gold/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-xl text-white group-hover:text-brand-gold transition-colors duration-200 leading-tight">{t.menu_title}</p>
            <p class="font-body text-xs text-brand-gold/60 mt-0.5">{t.menu_desc} · {menu.price.toFixed(0)}€/persona</p>
          </div>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <span class="font-display text-lg text-brand-gold leading-none">{menu.price.toFixed(0)}€</span>
          <svg class="w-5 h-5 text-brand-gold/50 group-hover:text-brand-gold group-hover:translate-x-0.5 transition-all duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      </a>

      <!-- Street Food -->
      <a
        href={`/${langParam}/streetfood`}
        class="group flex items-center justify-between gap-4 bg-white/10 hover:bg-white/15 active:bg-white/20 border border-white/20 hover:border-brand-gold/50 rounded-2xl px-6 py-5 transition-all duration-200"
      >
        <div class="flex items-center gap-4">
          <div class="shrink-0 w-10 h-10 rounded-full bg-brand-gold/15 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-xl text-white group-hover:text-brand-gold transition-colors duration-200 leading-tight">{t.streetfood_title}</p>
            <p class="font-body text-xs text-white/50 mt-0.5">{t.streetfood_desc}</p>
          </div>
        </div>
        <svg class="w-5 h-5 text-brand-gold/50 group-hover:text-brand-gold group-hover:translate-x-0.5 transition-all duration-200 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- Bebidas -->
      <a
        href={`/${langParam}/bebidas`}
        class="group flex items-center justify-between gap-4 bg-white/10 hover:bg-white/15 active:bg-white/20 border border-white/20 hover:border-brand-gold/50 rounded-2xl px-6 py-5 transition-all duration-200"
      >
        <div class="flex items-center gap-4">
          <div class="shrink-0 w-10 h-10 rounded-full bg-brand-gold/15 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3h4.5M8.25 3l.94 7.515A6 6 0 0 0 12 21a6 6 0 0 0 2.81-10.485L15.75 3M12 21v-3.75M9 17.25h6"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-xl text-white group-hover:text-brand-gold transition-colors duration-200 leading-tight">{t.bebidas_title}</p>
            <p class="font-body text-xs text-white/50 mt-0.5">{t.bebidas_desc}</p>
          </div>
        </div>
        <svg class="w-5 h-5 text-brand-gold/50 group-hover:text-brand-gold group-hover:translate-x-0.5 transition-all duration-200 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- Divider -->
      <div class="border-t border-white/10 my-1"></div>

      <!-- Reservar -->
      <a
        href={`/${langParam}/restaurante#reservar`}
        class="flex items-center justify-center gap-2 px-6 py-4 rounded-2xl bg-brand-gold hover:bg-brand-stone active:scale-[0.98] text-brand-blue font-body text-sm uppercase tracking-widest font-semibold transition-all duration-200"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/>
        </svg>
        {t.reservar}
      </a>

    </main>

    <!-- \u2500\u2500 Footer note \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 -->
    <footer class="pb-8 text-center">
      <p class="font-body text-[11px] text-white/25 uppercase tracking-widest">
        portadirta.com
      </p>
    </footer>

  </div>

</Layout>
