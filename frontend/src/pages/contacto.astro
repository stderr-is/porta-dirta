---
/**
 * src/pages/contacto.astro — Contact page for default locale (es)
 */

import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations();
const contactUrl = import.meta.env.PUBLIC_TASTYIGNITER_URL ?? 'http://localhost:8081';
---

<Layout
  titleKey="contacto.meta_title"
  descriptionKey="contacto.meta_description"
>

  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inicio",
        "item": "https://www.portadirta.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Contacto",
        "item": "https://www.portadirta.com/contacto"
      }
    ]
  })} />

  <!-- SECTION 1 — HERO -->
  <section class="min-h-[50vh] bg-brand-blue flex items-center justify-center py-24 md:py-32">
    <div class="text-center px-4">
      <p class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold mb-6" data-i18n="contacto.hero_label">
        {t('contacto.hero_label')}
      </p>
      <h1 class="font-display italic text-4xl sm:text-5xl md:text-6xl text-white leading-tight mb-6" data-i18n="contacto.hero_heading">
        {t('contacto.hero_heading')}
      </h1>
      <p class="font-body text-brand-sand text-lg tracking-wide" data-i18n="contacto.hero_body">
        {t('contacto.hero_body')}
      </p>
    </div>
  </section>

  <!-- SECTION 2 — CONTACT CARDS + FORM -->
  <section class="bg-brand-cream py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

        <!-- LEFT COLUMN: Contact info cards -->
        <div class="flex flex-col gap-6">

          <!-- Card 1: Hotel Bookings -->
          <div class="bg-white rounded-xl shadow-sm p-6 flex gap-4 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-blue/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-blue" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.4 2 2 0 0 1 3.56 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.13 6.13l.81-.81a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.73 16.92z"/>
              </svg>
            </div>
            <div class="flex flex-col gap-1">
              <h3 class="font-body text-sm uppercase tracking-widest text-brand-gold font-medium" data-i18n="contacto.hotel_bookings_label">
                {t('contacto.hotel_bookings_label')}
              </h3>
              <a href={'tel:' + t('contacto.hotel_phone')} class="font-display text-xl text-brand-blue hover:text-brand-gold transition-colors duration-200" data-i18n="contacto.hotel_phone">
                {t('contacto.hotel_phone')}
              </a>
              <a href={'mailto:' + t('contacto.hotel_email')} class="font-body text-sm text-brand-stone hover:text-brand-blue transition-colors duration-200" data-i18n="contacto.hotel_email">
                {t('contacto.hotel_email')}
              </a>
              <p class="font-body text-xs text-brand-stone/70 mt-1" data-i18n="contacto.hotel_hours">
                {t('contacto.hotel_hours')}
              </p>
            </div>
          </div>

          <!-- Card 2: Restaurant -->
          <div class="bg-white rounded-xl shadow-sm p-6 flex gap-4 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-blue/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-blue" aria-hidden="true">
                <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/>
                <path d="M7 2v20"/>
                <path d="M21 15V2a5 5 0 0 0-5 5v6h3.5a1.5 1.5 0 0 1 1.5 1.5v.5"/>
                <path d="M18 22v-7"/>
              </svg>
            </div>
            <div class="flex flex-col gap-1">
              <h3 class="font-body text-sm uppercase tracking-widest text-brand-gold font-medium" data-i18n="contacto.restaurant_label">
                {t('contacto.restaurant_label')}
              </h3>
              <a href={'tel:' + t('contacto.restaurant_phone')} class="font-display text-xl text-brand-blue hover:text-brand-gold transition-colors duration-200" data-i18n="contacto.restaurant_phone">
                {t('contacto.restaurant_phone')}
              </a>
              <a href={'mailto:' + t('contacto.restaurant_email')} class="font-body text-sm text-brand-stone hover:text-brand-blue transition-colors duration-200" data-i18n="contacto.restaurant_email">
                {t('contacto.restaurant_email')}
              </a>
              <p class="font-body text-xs text-brand-stone/70 mt-1" data-i18n="contacto.restaurant_hours">
                {t('contacto.restaurant_hours')}
              </p>
            </div>
          </div>

          <!-- Card 3: Events & Celebrations -->
          <div class="bg-white rounded-xl shadow-sm p-6 flex gap-4 items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-blue/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-blue" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </div>
            <div class="flex flex-col gap-1">
              <h3 class="font-body text-sm uppercase tracking-widest text-brand-gold font-medium" data-i18n="contacto.events_label">
                {t('contacto.events_label')}
              </h3>
              <a href={'mailto:' + t('contacto.events_email')} class="font-body text-sm text-brand-stone hover:text-brand-blue transition-colors duration-200" data-i18n="contacto.events_email">
                {t('contacto.events_email')}
              </a>
              <p class="font-body text-xs text-brand-stone/70 mt-1" data-i18n="contacto.events_response_time">
                {t('contacto.events_response_time')}
              </p>
            </div>
          </div>

          <div class="rounded-xl overflow-hidden h-48 border border-brand-stone/10">
            <iframe
              src={t('contacto.map_url')}
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación de Porta D'irta en Peñíscola"
            ></iframe>
          </div>
        </div>

        <!-- RIGHT COLUMN: General contact form -->
        <div>
          <div class="bg-white rounded-xl shadow-sm p-8" id="form-container">

            <!-- Form -->
            <div id="form-wrapper">
              <h2 class="font-display text-3xl text-brand-blue mb-8" data-i18n="contacto.form_heading">
                {t('contacto.form_heading')}
              </h2>

              <form
                id="contacto-form"
                method="POST"
                action="#"
                class="flex flex-col gap-5"
                aria-label="Formulario de contacto general"
              >
                <input type="hidden" name="source" value="contacto" />

                <!-- Nombre -->
                <div class="flex flex-col gap-2">
                  <label for="nombre" class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">
                    <span data-i18n="contacto.form_name_label">{t('contacto.form_name_label')}</span> *
                  </label>
                  <input
                    type="text"
                    id="nombre"
                    name="nombre"
                    required
                    autocomplete="name"
                    placeholder={t('contacto.form_name_placeholder')}
                    data-i18n-placeholder="contacto.form_name_placeholder"
                    class="border border-brand-stone/30 text-brand-blue placeholder-brand-stone/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-blue transition-colors duration-200 bg-white"
                  />
                </div>

                <!-- Email -->
                <div class="flex flex-col gap-2">
                  <label for="email" class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">
                    <span data-i18n="contacto.form_email_label">{t('contacto.form_email_label')}</span> *
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
                    placeholder="tu@email.com"
                    class="border border-brand-stone/30 text-brand-blue placeholder-brand-stone/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-blue transition-colors duration-200 bg-white"
                  />
                </div>

                <!-- Teléfono -->
                <div class="flex flex-col gap-2">
                  <label for="telefono" class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium" data-i18n="contacto.form_phone_label">
                    {t('contacto.form_phone_label')}
                  </label>
                  <input
                    type="tel"
                    id="telefono"
                    name="telefono"
                    placeholder="+34 600 000 000"
                    class="border border-brand-stone/30 text-brand-blue placeholder-brand-stone/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-blue transition-colors duration-200 bg-white"
                  />
                </div>

                <!-- Asunto -->
                <div class="flex flex-col gap-2">
                  <label for="asunto" class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">
                    <span data-i18n="contacto.form_subject_label">{t('contacto.form_subject_label')}</span> *
                  </label>
                  <select
                    id="asunto"
                    name="asunto"
                    required
                    class="border border-brand-stone/30 text-brand-blue rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-blue transition-colors duration-200 bg-white appearance-none"
                  >
                    <option value="" disabled selected data-i18n="contacto.form_subject_placeholder">{t('contacto.form_subject_placeholder')}</option>
                    <option value="reserva" data-i18n="contacto.form_option_mesa">Reserva de mesa</option>
                    <option value="alergenos" data-i18n="contacto.form_option_alergenos">Alérgenos e intolerancias</option>
                    <option value="eventos" data-i18n="contacto.form_option_eventos">Eventos y celebraciones</option>
                    <option value="grupos" data-i18n="contacto.form_option_grupos">Grupos y catering</option>
                    <option value="otro" data-i18n="contacto.form_option_otro">Otro</option>
                  </select>
                </div>

                <!-- Mensaje -->
                <div class="flex flex-col gap-2">
                  <label for="mensaje" class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">
                    <span data-i18n="contacto.form_message_label">{t('contacto.form_message_label')}</span> *
                  </label>
                  <textarea
                    id="mensaje"
                    name="mensaje"
                    rows="5"
                    required
                    placeholder={t('contacto.form_message_placeholder')}
                    data-i18n-placeholder="contacto.form_message_placeholder"
                    class="border border-brand-stone/30 text-brand-blue placeholder-brand-stone/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-blue transition-colors duration-200 bg-white resize-y"
                  ></textarea>
                </div>

                <!-- RGPD -->
                <div class="flex items-start gap-3">
                  <input
                    type="checkbox"
                    id="rgpd"
                    name="rgpd"
                    required
                    class="mt-1 h-4 w-4 flex-shrink-0 rounded border-brand-stone/40 text-brand-blue focus:ring-brand-blue"
                  />
                  <label for="rgpd" class="font-body text-xs text-brand-stone/80 leading-relaxed">
                    <span data-i18n="contacto.rgpd_text_part1">{t('contacto.rgpd_text_part1')}</span>
                    <a href="/privacidad" target="_blank" class="underline hover:text-brand-blue" data-i18n="contacto.rgpd_privacy_policy">{t('contacto.rgpd_privacy_policy')}</a>.
                    <span data-i18n="contacto.rgpd_text_part2">{t('contacto.rgpd_text_part2')}</span> *
                  </label>
                </div>

                <!-- Inline error message (hidden by default) -->
                <p
                  id="form-error"
                  class="hidden font-body text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg p-3"
                  role="alert"
                  data-i18n="contacto.form_error_message"
                >
                  {t('contacto.form_error_message')}
                </p>

                <!-- Submit -->
                <button
                  type="submit"
                  id="submit-btn"
                  class="w-full bg-brand-blue text-white font-body text-sm uppercase tracking-widest font-medium rounded-lg px-8 py-4 hover:bg-brand-blue-light transition-colors duration-200 mt-2"
                  data-i18n="contacto.form_submit_button"
                >
                  {t('contacto.form_submit_button')}
                </button>

              </form>
            </div>

            <!-- Success state (hidden until form submits successfully) -->
            <div id="form-success" class="hidden flex flex-col items-center justify-center gap-6 py-16 text-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-gold" aria-hidden="true">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              <h3 class="font-display italic text-3xl text-brand-blue" data-i18n="contacto.form_success_heading">¡Mensaje enviado!</h3>
              <p class="font-body text-brand-stone text-base max-w-sm" data-i18n="contacto.form_success_body">
                Gracias por ponerte en contacto con nosotros. Te responderemos en menos de 48 horas.
              </p>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3 — LOCATION STRIP -->
  <section class="bg-brand-blue py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-12 sm:gap-16 lg:gap-24">

        <!-- Item 1: Location -->
        <div class="flex flex-col items-center gap-3 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-gold" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <p class="font-body text-white text-sm tracking-wide" data-i18n="contacto.location_text">
            {t('contacto.location_text')}
          </p>
        </div>

        <!-- Item 2: Car distance -->
        <div class="flex flex-col items-center gap-3 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-gold" aria-hidden="true">
            <rect x="1" y="3" width="15" height="13" rx="1"/>
            <path d="M16 8h4l3 3v5h-7V8z"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          <p class="font-body text-white text-sm tracking-wide" data-i18n="contacto.drive_text">
            {t('contacto.drive_text')}
          </p>
        </div>

        <!-- Item 3: Airport -->
        <div class="flex flex-col items-center gap-3 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-gold" aria-hidden="true">
            <path d="M17.8 19.2 16 11l3.5-3.5C21 6 21 4 21 4s-2 0-3.5 1.5L14 9 5.8 6.2l-1.9 1.9 6.5 3.7-2.5 2.5-2.4-.4L4 15l2 2 2 2 1.3-1.5-.4-2.4 2.5-2.5 3.7 6.5z"/>
          </svg>
          <p class="font-body text-white text-sm tracking-wide" data-i18n="contacto.airport_text">
            {t('contacto.airport_text')}
          </p>
        </div>

      </div>
    </div>
  </section>

  <script is:inline define:vars={{ contactUrl }}>
    (function () {
      var form = document.getElementById('contacto-form');
      var submitBtn = document.getElementById('submit-btn');
      var errorMsg = document.getElementById('form-error');
      var formWrapper = document.getElementById('form-wrapper');
      var formSuccess = document.getElementById('form-success');

      if (!form || !submitBtn || !errorMsg || !formWrapper || !formSuccess) return;

      form.addEventListener('submit', async function (e) {
        e.preventDefault();

        submitBtn.disabled = true;
        submitBtn.textContent = 'Enviando\u2026';
        errorMsg.classList.add('hidden');

        var raw = Object.fromEntries(new FormData(form).entries());
        var data = Object.assign({}, raw, { experiencia: raw.asunto });

        try {
          var response = await fetch(contactUrl + '/api/public/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          if (!response.ok) {
            throw new Error('Server error: ' + response.status);
          }

          formWrapper.classList.add('hidden');
          formSuccess.classList.remove('hidden');
          formSuccess.classList.add('flex');

        } catch (err) {
          errorMsg.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Enviar Mensaje';
        }
      });
    })();
  </script>

</Layout>
