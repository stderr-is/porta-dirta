---
/**
 * streetfood.astro — Street Food by Fifty-Five evening menu (18:00–22:00)
 * SSR · Mobile-first · QR table destination
 */

import fs from 'node:fs';
import Layout from '../layouts/Layout.astro';
import GarlandDivider from '../components/GarlandDivider.astro';
import streetfoodFallback from '../data/streetfood.json';

let streetfood: typeof streetfoodFallback = streetfoodFallback;
const menuDataPath = process.env.MENU_DATA_PATH;
if (menuDataPath) {
  try { streetfood = JSON.parse(fs.readFileSync(`${menuDataPath}/streetfood.json`, 'utf-8')); } catch {}
}

const ALLERGENS: Record<string, { label: string; bg: string; text: string }> = {
  'gluten':       { label: 'Gluten',       bg: 'bg-amber-100',   text: 'text-amber-800'  },
  'lácteos':      { label: 'Lácteos',      bg: 'bg-sky-100',     text: 'text-sky-800'    },
  'huevo':        { label: 'Huevo',        bg: 'bg-yellow-100',  text: 'text-yellow-800' },
  'pescado':      { label: 'Pescado',      bg: 'bg-blue-100',    text: 'text-blue-800'   },
  'crustáceos':   { label: 'Crustáceos',   bg: 'bg-orange-100',  text: 'text-orange-800' },
  'moluscos':     { label: 'Moluscos',     bg: 'bg-violet-100',  text: 'text-violet-800' },
  'frutos secos': { label: 'Frutos secos', bg: 'bg-green-100',   text: 'text-green-800'  },
  'cacahuetes':   { label: 'Cacahuetes',   bg: 'bg-lime-100',    text: 'text-lime-800'   },
  'soja':         { label: 'Soja',         bg: 'bg-emerald-100', text: 'text-emerald-800'},
  'sulfitos':     { label: 'Sulfitos',     bg: 'bg-rose-100',    text: 'text-rose-800'   },
  'mostaza':      { label: 'Mostaza',      bg: 'bg-yellow-50',   text: 'text-yellow-700' },
  'sésamo':       { label: 'Sésamo',       bg: 'bg-stone-100',   text: 'text-stone-700'  },
  'apio':         { label: 'Apio',         bg: 'bg-teal-100',    text: 'text-teal-800'   },
  'altramuces':   { label: 'Altramuces',   bg: 'bg-pink-100',    text: 'text-pink-800'   },
};
---

<Layout
  title="Street Food by Fifty-Five — Restaurante"
  description="Menú nocturno Street Food by Fifty-Five en Porta D'irta, Peñíscola. Burgers, pizzas y snacks de 18:00 a 22:00."
  ogImage="/assets/images/streetfood-fifty-five.png"
>

  <!-- ── Header ───────────────────────────────────────────────────── -->
  <section class="bg-brand-blue pt-28 pb-10">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center flex flex-col items-center gap-3">
      <p class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">Restaurante Porta D'irta</p>
      <h1 class="font-display font-light italic text-5xl sm:text-6xl text-white leading-tight">Street Food</h1>
      <p class="font-body text-sm text-white/60 -mt-1">by Fifty-Five</p>
      <GarlandDivider light />
      <p class="font-body text-white/50 text-xs tracking-widest">18:00 – 22:00</p>
    </div>
  </section>

  <!-- ── Sections ─────────────────────────────────────────────────── -->
  <section class="bg-brand-cream py-10">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 flex flex-col gap-10">

      {streetfood.sections.map(section => (
        <div>
          <div class="flex items-center gap-3 mb-1">
            <h2 class="font-display text-2xl sm:text-3xl text-brand-blue shrink-0">{section.name}</h2>
            <div class="flex-1 h-px bg-brand-blue/15"></div>
          </div>
          {section.note && (
            <p class="font-body text-[11px] text-brand-stone/70 uppercase tracking-widest mb-3">{section.note}</p>
          )}
          <ul class="flex flex-col divide-y divide-brand-sand/40">
            {section.items.map(item => (
              <li class="py-3.5 flex items-start justify-between gap-3">
                <div class="flex flex-col gap-1.5 min-w-0">
                  <span class="font-body font-medium text-brand-blue text-[15px] leading-snug">{item.name}</span>
                  {item.description && (
                    <span class="font-body text-brand-stone text-[13px] leading-relaxed">{item.description}</span>
                  )}
                  {item.allergens && item.allergens.length > 0 && (
                    <div class="flex flex-wrap gap-1 mt-0.5">
                      {item.allergens.map((a: string) => {
                        const info = ALLERGENS[a.toLowerCase()] ?? { label: a, bg: 'bg-gray-100', text: 'text-gray-700' };
                        return (
                          <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold leading-none ${info.bg} ${info.text}`}>
                            {info.label}
                          </span>
                        );
                      })}
                    </div>
                  )}
                </div>
                <span class="font-body font-medium text-brand-gold text-[15px] shrink-0 tabular-nums pt-0.5">
                  {item.price.toFixed(2)} €
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Allergen legend -->
      <div class="border-t border-brand-sand/40 pt-6 flex flex-col gap-3">
        <p class="font-body text-[11px] uppercase tracking-widest text-brand-stone/60">Alérgenos</p>
        <div class="flex flex-wrap gap-2">
          {Object.values(ALLERGENS).map(a => (
            <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold ${a.bg} ${a.text}`}>{a.label}</span>
          ))}
        </div>
        <p class="font-body text-[11px] text-brand-stone/50 italic mt-1">
          Intolerancia o alergia grave? Indícalo a nuestro equipo y lo gestionamos con todo el cuidado.
        </p>
      </div>

    </div>
  </section>

  <!-- ── Bottom nav ────────────────────────────────────────────────── -->
  <section class="bg-brand-blue py-10">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="/mesa" class="font-body text-sm uppercase tracking-widest text-white/60 hover:text-brand-gold transition-colors duration-200">← Todos los menús</a>
      <span class="hidden sm:block text-white/20">|</span>
      <a href="/bebidas" class="font-body text-sm uppercase tracking-widest text-white/60 hover:text-brand-gold transition-colors duration-200">Bebidas →</a>
      <span class="hidden sm:block text-white/20">|</span>
      <a href="/reservar" class="inline-flex items-center px-6 py-3 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium transition-colors duration-200">
        Reservar mesa
      </a>
    </div>
  </section>

</Layout>
