---
/**
 * Nav.astro — Glassmorphism top navigation for Porta D'irta
 *
 * Design:
 *   - Fixed top, full-width, z-50.
 *   - Glassmorphism base: backdrop-blur-md + translucent white border.
 *   - On scroll, a small inline <script> adds `.nav-scrolled` to the <nav>
 *     element, increasing background opacity. Uses a passive scroll listener.
 *
 * Mobile menu — pure CSS checkbox trick:
 *   A hidden <input type="checkbox"> with id="nav-toggle" is rendered inside
 *   the nav wrapper. A <label for="nav-toggle"> acts as the hamburger button.
 *   The mobile menu uses the CSS general sibling combinator (~) via a
 *   <style> block below — Tailwind peer-checked can't cross arbitrary DOM
 *   distances, so we use a scoped <style> here instead.
 *
 * No JavaScript framework. No icon libraries.
 *
 * Wave 2 notes:
 *   - Wire up language switcher hrefs to Astro i18n routing helpers.
 *   - Active link state: pass `currentPath` prop and compare.
 *   - Consider replacing checkbox trick with Astro's View Transitions API.
 */
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// Normalise pathname: build.format:'file' sets Astro.url.pathname to file paths
// like /index.html, /hotel.html, /en.html, /en/hotel.html.
// Strip .html, collapse /index to /, and remove any trailing slash.
const _pathname = (Astro.url.pathname
  .replace(/\.html$/, '')   // /index.html → /index, /en/hotel.html → /en/hotel
  .replace(/\/index$/, '/') // /index → /, /en/index → /en/
  .replace(/\/$/, '')       // /en/ → /en  (root / → '' handled below)
) || '/';
// Strip locale prefix, then remove leading slash → '' | 'hotel' | 'restaurante' | …
const _stripped = _pathname.replace(/^\/(en|fr|de)(\/|$)/, '');
const canonPath = _stripped.replace(/^\//, '');
// Language switcher hrefs — clean URLs, no .html, no trailing slash
const esHref = canonPath ? `/${canonPath}` : '/';
const enHref = canonPath ? `/en/${canonPath}` : '/en';
const frHref = canonPath ? `/fr/${canonPath}` : '/fr';
const deHref = canonPath ? `/de/${canonPath}` : '/de';
// Logo href — locale home
const homeHref = lang === 'es' ? '/' : `/${lang}`;
---

<div class="nav-root">

  <!-- ── Hidden checkbox — drives mobile menu open/close ─── -->
  <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-hidden="true" />

  <!-- ── NAV BAR ─────────────────────────────────────────── -->
  <nav
    id="main-nav"
    class="
      fixed top-0 left-0 right-0 z-50
      backdrop-blur-md bg-white/10 border-b border-white/20
      transition-colors duration-300
    "
    aria-label="Navegación principal"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- ── LEFT: Logo ───────────────────────────────── -->
        <a href={homeHref} class="flex-shrink-0" aria-label="Porta D'irta — inicio">
          <img
            src="/assets/logos/logo-negativo.png"
            alt="Porta D'irta"
            class="h-12 w-auto object-contain"
            loading="eager"
            decoding="async"
          />
        </a>

        <!-- ── CENTER: Desktop nav links ────────────────── -->
        <ul class="hidden sm:flex items-center gap-3 lg:gap-8 list-none m-0 p-0">
          <li>
            <a href={getRelativeLocaleUrl(lang, 'hotel')} class="font-body text-sm uppercase tracking-wide lg:tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              {t('nav.hotel')}
            </a>
          </li>
          <li>
            <a href={getRelativeLocaleUrl(lang, 'restaurante')} class="font-body text-sm uppercase tracking-wide lg:tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              {t('nav.restaurante')}
            </a>
          </li>
          <li>
            <a href={getRelativeLocaleUrl(lang, 'eventos')} class="font-body text-sm uppercase tracking-wide lg:tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              {t('nav.eventos')}
            </a>
          </li>
          <li>
            <a href={getRelativeLocaleUrl(lang, 'experiencias')} class="font-body text-sm uppercase tracking-wide lg:tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              {t('nav.experiencias')}
            </a>
          </li>
          <li>
            <a href={getRelativeLocaleUrl(lang, 'contacto')} class="font-body text-sm uppercase tracking-wide lg:tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              {t('nav.contacto')}
            </a>
          </li>
        </ul>

        <!-- ── RIGHT: Lang switcher + CTA + hamburger ───── -->
        <div class="flex items-center gap-4">

          <!-- Language switcher — full inline at lg+ -->
          <div class="hidden lg:flex items-center gap-2" aria-label="Seleccionar idioma">
            <a href={esHref} class={`font-body text-xs uppercase tracking-widest ${!["en","fr","de"].includes(Astro.currentLocale ?? "") ? "font-semibold text-brand-gold" : "text-white"} hover:text-brand-gold transition-colors duration-200`}>ES</a>
            <span class="text-white/30 text-xs" aria-hidden="true">|</span>
            <a href={enHref} class={`font-body text-xs uppercase tracking-widest ${Astro.currentLocale === "en" ? "font-semibold text-brand-gold" : "text-white/70"} hover:text-brand-gold transition-colors duration-200`}>EN</a>
            <span class="text-white/30 text-xs" aria-hidden="true">|</span>
            <a href={frHref} class={`font-body text-xs uppercase tracking-widest ${Astro.currentLocale === "fr" ? "font-semibold text-brand-gold" : "text-white/70"} hover:text-brand-gold transition-colors duration-200`}>FR</a>
            <span class="text-white/30 text-xs" aria-hidden="true">|</span>
            <a href={deHref} class={`font-body text-xs uppercase tracking-widest ${Astro.currentLocale === "de" ? "font-semibold text-brand-gold" : "text-white/70"} hover:text-brand-gold transition-colors duration-200`}>DE</a>
          </div>

          <!-- Language switcher — compact dropdown at sm–lg -->
          <details class="hidden sm:block lg:hidden relative lang-details" aria-label="Seleccionar idioma">
            <summary class="flex items-center gap-1 font-body text-xs uppercase tracking-wide text-white hover:text-brand-gold cursor-pointer select-none transition-colors duration-200">
              ES
              <svg class="w-3 h-3 opacity-60 transition-transform duration-200 lang-chevron" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="absolute right-0 top-full mt-2 bg-brand-blue/95 backdrop-blur-md rounded-lg py-1 border border-white/10 shadow-xl z-[70] min-w-[72px]">
              <a href={esHref} class={`block px-4 py-2 font-body text-xs uppercase tracking-wide ${!["en","fr","de"].includes(Astro.currentLocale ?? "") ? "font-semibold text-brand-gold" : "text-white"} hover:text-brand-gold transition-colors duration-200`}>ES</a>
              <a href={enHref} class={`block px-4 py-2 font-body text-xs uppercase tracking-wide ${Astro.currentLocale === "en" ? "font-semibold text-brand-gold" : "text-white/60"} hover:text-brand-gold transition-colors duration-200`}>EN</a>
              <a href={frHref} class={`block px-4 py-2 font-body text-xs uppercase tracking-wide ${Astro.currentLocale === "fr" ? "font-semibold text-brand-gold" : "text-white/60"} hover:text-brand-gold transition-colors duration-200`}>FR</a>
              <a href={deHref} class={`block px-4 py-2 font-body text-xs uppercase tracking-wide ${Astro.currentLocale === "de" ? "font-semibold text-brand-gold" : "text-white/60"} hover:text-brand-gold transition-colors duration-200`}>DE</a>
            </div>
          </details>

          <!-- CTA — tablet and desktop -->
          <a
            href={getRelativeLocaleUrl(lang, 'reservar')}
            class="
              hidden sm:inline-flex items-center
              px-3 lg:px-5 py-2 rounded-sm
              bg-brand-gold hover:bg-brand-stone
              text-brand-blue font-body text-sm uppercase tracking-wide lg:tracking-widest font-medium
              transition-colors duration-200
            "
          >
            {t('nav.reservar')}
          </a>

          <!-- Hamburger label — small mobile only -->
          <label
            for="nav-toggle"
            class="hamburger sm:hidden flex flex-col justify-center gap-[5px] w-8 h-8 cursor-pointer"
            aria-label="Abrir menú de navegación"
            role="button"
            aria-expanded="false"
          >
            <span class="bar block h-[2px] w-full bg-white rounded transition-all duration-300"></span>
            <span class="bar block h-[2px] w-full bg-white rounded transition-all duration-300"></span>
            <span class="bar block h-[2px] w-full bg-white rounded transition-all duration-300"></span>
          </label>

        </div>
      </div>
    </div>

    <!-- ── Mobile dropdown menu ─────────────────────────────
         Visibility is toggled via the CSS sibling rule in <style>
         below: #nav-toggle:checked ~ nav .mobile-menu { max-height: ... }
         ─────────────────────────────────────────────────── -->
    <div
      class="mobile-menu sm:hidden overflow-hidden backdrop-blur-md bg-brand-blue/90 border-t border-white/10"
      aria-label="Menú móvil"
    >
      <ul class="list-none m-0 p-0 flex flex-col py-4">
        <li>
          <a href={getRelativeLocaleUrl(lang, 'hotel')} class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">{t('nav.hotel')}</a>
        </li>
        <li>
          <a href={getRelativeLocaleUrl(lang, 'restaurante')} class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">{t('nav.restaurante')}</a>
        </li>
        <li>
          <a href={getRelativeLocaleUrl(lang, 'eventos')} class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">{t('nav.eventos')}</a>
        </li>
        <li>
          <a href={getRelativeLocaleUrl(lang, 'experiencias')} class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">{t('nav.experiencias')}</a>
        </li>
        <li>
          <a href={getRelativeLocaleUrl(lang, 'contacto')} class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">{t('nav.contacto')}</a>
        </li>

        <!-- Language switcher — mobile -->
        <li class="px-6 pt-4 pb-2 flex gap-3 border-t border-white/10 mt-2" aria-label="Seleccionar idioma">
          <a href={esHref} class={`font-body text-xs uppercase tracking-widest ${!["en","fr","de"].includes(Astro.currentLocale ?? "") ? "font-semibold text-brand-gold" : "text-white"} hover:text-brand-gold transition-colors duration-200`}>ES</a>
          <span class="text-white/30 text-xs" aria-hidden="true">|</span>
          <a href={enHref} class={`font-body text-xs uppercase tracking-widest ${Astro.currentLocale === "en" ? "font-semibold text-brand-gold" : "text-white/70"} hover:text-brand-gold transition-colors duration-200`}>EN</a>
          <span class="text-white/30 text-xs" aria-hidden="true">|</span>
          <a href={frHref} class={`font-body text-xs uppercase tracking-widest ${Astro.currentLocale === "fr" ? "font-semibold text-brand-gold" : "text-white/70"} hover:text-brand-gold transition-colors duration-200`}>FR</a>
          <span class="text-white/30 text-xs" aria-hidden="true">|</span>
          <a href={deHref} class={`font-body text-xs uppercase tracking-widest ${Astro.currentLocale === "de" ? "font-semibold text-brand-gold" : "text-white/70"} hover:text-brand-gold transition-colors duration-200`}>DE</a>
        </li>

        <!-- CTA — mobile -->
        <li class="px-6 pt-2 pb-4">
          <a
            href={getRelativeLocaleUrl(lang, 'reservar')}
            class="
              block w-full text-center
              px-5 py-3 rounded-sm
              bg-brand-gold hover:bg-brand-stone
              text-brand-blue font-body text-sm uppercase tracking-widest font-medium
              transition-colors duration-200
            "
          >
            {t('nav.reservar')}
          </a>
        </li>
      </ul>
    </div>

  </nav>
</div>

<!-- ============================================================
     SCROLL SCRIPT
     Adds/removes a class on #main-nav to increase bg opacity
     after the user scrolls past 40 px. Passive listener for
     smooth 60 fps performance.
     ============================================================ -->
<script>
  (function () {
    const nav = document.getElementById('main-nav');
    const navToggle = document.getElementById('nav-toggle');
    const hamburger = document.querySelector('label[for="nav-toggle"]');
    if (!nav) return;

    function onScroll() {
      if (window.scrollY > 40) {
        // More opaque — brand blue tint becomes visible
        nav.style.backgroundColor = 'rgba(13, 43, 69, 0.85)';
      } else {
        // Default glassmorphism — nearly transparent
        nav.style.backgroundColor = 'rgba(255, 255, 255, 0.10)';
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // Initialise on page load

    if (navToggle instanceof HTMLInputElement && hamburger instanceof HTMLLabelElement) {
      const syncExpanded = () => {
        hamburger.setAttribute('aria-expanded', navToggle.checked ? 'true' : 'false');
      };
      navToggle.addEventListener('change', syncExpanded);
      syncExpanded();
    }

    // Close lang dropdown when clicking outside
    document.addEventListener('click', (e) => {
      document.querySelectorAll('.lang-details').forEach((d) => {
        if (!d.contains(e.target)) d.removeAttribute('open');
      });
    });
  })();
</script>

<!-- ============================================================
     SCOPED STYLES — mobile menu toggle + hamburger animation
     Using plain CSS sibling combinator because Tailwind peer-checked
     doesn't work across the DOM distance required here.
     ============================================================ -->
<style>
  /* Lang dropdown — remove native disclosure triangle */
  .lang-details > summary {
    list-style: none;
  }
  .lang-details > summary::-webkit-details-marker {
    display: none;
  }

  /* Rotate chevron when dropdown is open */
  .lang-details[open] .lang-chevron {
    transform: rotate(180deg);
  }

  /* Hide the checkbox visually but keep it in the DOM */
  .nav-toggle-input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  /* Mobile menu: collapsed by default */
  .mobile-menu {
    max-height: 0;
    transition: max-height 0.4s ease-in-out;
  }

  /* When checkbox is checked, expand the mobile menu */
  .nav-toggle-input:checked ~ nav .mobile-menu {
    max-height: 600px;
  }

  /* Hamburger bar animations when menu is open */
  .nav-toggle-input:checked ~ nav .hamburger .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle-input:checked ~ nav .hamburger .bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle-input:checked ~ nav .hamburger .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>
