---
/**
 * Nav.astro — Glassmorphism top navigation for Porta D'irta
 *
 * Design:
 *   - Fixed top, full-width, z-50.
 *   - Glassmorphism base: backdrop-blur-md + translucent white border.
 *   - On scroll, a small inline <script> adds `.nav-scrolled` to the <nav>
 *     element, increasing background opacity. Uses a passive scroll listener.
 *
 * Mobile menu — pure CSS checkbox trick:
 *   A hidden <input type="checkbox"> with id="nav-toggle" is rendered inside
 *   the nav wrapper. A <label for="nav-toggle"> acts as the hamburger button.
 *   The mobile menu uses the CSS general sibling combinator (~) via a
 *   <style> block below — Tailwind peer-checked can't cross arbitrary DOM
 *   distances, so we use a scoped <style> here instead.
 *
 * No JavaScript framework. No icon libraries.
 *
 * Wave 2 notes:
 *   - Wire up language switcher hrefs to Astro i18n routing helpers.
 *   - Active link state: pass `currentPath` prop and compare.
 *   - Consider replacing checkbox trick with Astro's View Transitions API.
 */
import { useTranslations } from '../i18n/utils';

const t = useTranslations();
---

<div class="nav-root">

  <!-- ── Hidden checkbox — drives mobile menu open/close ─── -->
  <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-hidden="true" />

  <!-- ── NAV BAR ─────────────────────────────────────────── -->
  <nav
    id="main-nav"
    class="
      fixed top-0 left-0 right-0 z-50
      backdrop-blur-md bg-white/10 border-b border-white/20
      transition-colors duration-300
    "
    aria-label="Navegación principal"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- ── LEFT: Logo ───────────────────────────────── -->
        <a href="/" class="flex-shrink-0" aria-label="Porta D'irta — inicio">
          <img
            src="/assets/logos/logo-negativo.png"
            alt="Porta D'irta"
            class="h-12 w-auto object-contain"
            loading="eager"
            decoding="async"
          />
        </a>

        <!-- ── CENTER: Desktop nav links ────────────────── -->
        <ul class="hidden sm:flex items-center gap-3 lg:gap-8 list-none m-0 p-0">
          <li>
            <a href="/hotel" data-i18n="nav.hotel" class="font-body text-sm uppercase tracking-wide lg:tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              {t('nav.hotel')}
            </a>
          </li>
          <li>
            <a href="/restaurante" data-i18n="nav.restaurante" class="font-body text-sm uppercase tracking-wide lg:tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              {t('nav.restaurante')}
            </a>
          </li>
          <li>
            <a href="/eventos" data-i18n="nav.eventos" class="font-body text-sm uppercase tracking-wide lg:tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              {t('nav.eventos')}
            </a>
          </li>
          <li>
            <a href="/experiencias" data-i18n="nav.experiencias" class="font-body text-sm uppercase tracking-wide lg:tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              {t('nav.experiencias')}
            </a>
          </li>
          <li>
            <a href="/contacto" data-i18n="nav.contacto" class="font-body text-sm uppercase tracking-wide lg:tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              {t('nav.contacto')}
            </a>
          </li>
        </ul>

        <!-- ── RIGHT: Lang switcher + CTA + hamburger ───── -->
        <div class="flex items-center gap-4">

          <!-- Language switcher — full inline at lg+ -->
          <div class="hidden lg:flex items-center gap-2" aria-label="Seleccionar idioma">
            <button data-lang-btn="es" onclick="window.setLang('es')" class="font-body text-xs uppercase tracking-widest font-semibold text-brand-gold hover:text-brand-gold transition-colors duration-200 cursor-pointer bg-transparent border-none p-0">ES</button>
            <span class="text-white/30 text-xs" aria-hidden="true">|</span>
            <button data-lang-btn="en" onclick="window.setLang('en')" class="font-body text-xs uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200 cursor-pointer bg-transparent border-none p-0">EN</button>
            <span class="text-white/30 text-xs" aria-hidden="true">|</span>
            <button data-lang-btn="fr" onclick="window.setLang('fr')" class="font-body text-xs uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200 cursor-pointer bg-transparent border-none p-0">FR</button>
            <span class="text-white/30 text-xs" aria-hidden="true">|</span>
            <button data-lang-btn="de" onclick="window.setLang('de')" class="font-body text-xs uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200 cursor-pointer bg-transparent border-none p-0">DE</button>
          </div>

          <!-- Language switcher — compact dropdown at sm–lg -->
          <details class="hidden sm:block lg:hidden relative lang-details" aria-label="Seleccionar idioma">
            <summary class="flex items-center gap-1 font-body text-xs uppercase tracking-wide text-white hover:text-brand-gold cursor-pointer select-none transition-colors duration-200">
              <span id="lang-summary-current">ES</span>
              <svg class="w-3 h-3 opacity-60 transition-transform duration-200 lang-chevron" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="absolute right-0 top-full mt-2 bg-brand-blue/95 backdrop-blur-md rounded-lg py-1 border border-white/10 shadow-xl z-[70] min-w-[72px]">
              <button data-lang-btn="es" onclick="window.setLang('es')" class="block w-full text-left px-4 py-2 font-body text-xs uppercase tracking-wide font-semibold text-brand-gold hover:text-brand-gold transition-colors duration-200 bg-transparent border-none cursor-pointer">ES</button>
              <button data-lang-btn="en" onclick="window.setLang('en')" class="block w-full text-left px-4 py-2 font-body text-xs uppercase tracking-wide text-white/60 hover:text-brand-gold transition-colors duration-200 bg-transparent border-none cursor-pointer">EN</button>
              <button data-lang-btn="fr" onclick="window.setLang('fr')" class="block w-full text-left px-4 py-2 font-body text-xs uppercase tracking-wide text-white/60 hover:text-brand-gold transition-colors duration-200 bg-transparent border-none cursor-pointer">FR</button>
              <button data-lang-btn="de" onclick="window.setLang('de')" class="block w-full text-left px-4 py-2 font-body text-xs uppercase tracking-wide text-white/60 hover:text-brand-gold transition-colors duration-200 bg-transparent border-none cursor-pointer">DE</button>
            </div>
          </details>

          <!-- CTA — tablet and desktop -->
          <a
            href="/reservar"
            class="
              hidden sm:inline-flex items-center
              px-3 lg:px-5 py-2 rounded-sm
              bg-brand-gold hover:bg-brand-stone
              text-brand-blue font-body text-sm uppercase tracking-wide lg:tracking-widest font-medium
              transition-colors duration-200
            "
            data-i18n="nav.reservar"
          >
            {t('nav.reservar')}
          </a>

          <!-- Hamburger label — small mobile only -->
          <label
            for="nav-toggle"
            class="hamburger sm:hidden flex flex-col justify-center gap-[5px] w-8 h-8 cursor-pointer"
            aria-label="Abrir menú de navegación"
          >
            <span class="bar block h-[2px] w-full bg-white rounded transition-all duration-300"></span>
            <span class="bar block h-[2px] w-full bg-white rounded transition-all duration-300"></span>
            <span class="bar block h-[2px] w-full bg-white rounded transition-all duration-300"></span>
          </label>

        </div>
      </div>
    </div>

    <!-- ── Mobile dropdown menu ─────────────────────────────
         Visibility is toggled via the CSS sibling rule in <style>
         below: #nav-toggle:checked ~ nav .mobile-menu { max-height: ... }
         ─────────────────────────────────────────────────── -->
    <div
      class="mobile-menu sm:hidden overflow-hidden backdrop-blur-md bg-brand-blue/90 border-t border-white/10"
      aria-label="Menú móvil"
    >
      <ul class="list-none m-0 p-0 flex flex-col py-4">
        <li>
          <a href="/hotel" data-i18n="nav.hotel" class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">{t('nav.hotel')}</a>
        </li>
        <li>
          <a href="/restaurante" data-i18n="nav.restaurante" class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">{t('nav.restaurante')}</a>
        </li>
        <li>
          <a href="/eventos" data-i18n="nav.eventos" class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">{t('nav.eventos')}</a>
        </li>
        <li>
          <a href="/experiencias" data-i18n="nav.experiencias" class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">{t('nav.experiencias')}</a>
        </li>
        <li>
          <a href="/contacto" data-i18n="nav.contacto" class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">{t('nav.contacto')}</a>
        </li>

        <!-- Language switcher — mobile -->
        <li class="px-6 pt-4 pb-2 flex gap-3 border-t border-white/10 mt-2" aria-label="Seleccionar idioma">
          <button data-lang-btn="es" onclick="window.setLang('es')" class="font-body text-xs uppercase tracking-widest font-semibold text-brand-gold hover:text-brand-gold transition-colors duration-200 bg-transparent border-none cursor-pointer p-0">ES</button>
          <span class="text-white/30 text-xs" aria-hidden="true">|</span>
          <button data-lang-btn="en" onclick="window.setLang('en')" class="font-body text-xs uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200 bg-transparent border-none cursor-pointer p-0">EN</button>
          <span class="text-white/30 text-xs" aria-hidden="true">|</span>
          <button data-lang-btn="fr" onclick="window.setLang('fr')" class="font-body text-xs uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200 bg-transparent border-none cursor-pointer p-0">FR</button>
          <span class="text-white/30 text-xs" aria-hidden="true">|</span>
          <button data-lang-btn="de" onclick="window.setLang('de')" class="font-body text-xs uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200 bg-transparent border-none cursor-pointer p-0">DE</button>
        </li>

        <!-- CTA — mobile -->
        <li class="px-6 pt-2 pb-4">
          <a
            href="/reservar"
            data-i18n="nav.reservar"
            class="
              block w-full text-center
              px-5 py-3 rounded-sm
              bg-brand-gold hover:bg-brand-stone
              text-brand-blue font-body text-sm uppercase tracking-widest font-medium
              transition-colors duration-200
            "
          >
            {t('nav.reservar')}
          </a>
        </li>
      </ul>
    </div>

  </nav>
</div>

<!-- ============================================================
     SCROLL SCRIPT
     Adds/removes a class on #main-nav to increase bg opacity
     after the user scrolls past 40 px. Passive listener for
     smooth 60 fps performance.
     ============================================================ -->
<script>
  (function () {
    const nav = document.getElementById('main-nav');
    if (!nav) return;

    function onScroll() {
      if (window.scrollY > 40) {
        // More opaque — brand blue tint becomes visible
        nav.style.backgroundColor = 'rgba(13, 43, 69, 0.85)';
      } else {
        // Default glassmorphism — nearly transparent
        nav.style.backgroundColor = 'rgba(255, 255, 255, 0.10)';
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // Initialise on page load

    // Close lang dropdown when clicking outside
    document.addEventListener('click', (e) => {
      document.querySelectorAll('.lang-details').forEach((d) => {
        if (!d.contains(e.target)) d.removeAttribute('open');
      });
    });
  })();
</script>

<!-- ============================================================
     SCOPED STYLES — mobile menu toggle + hamburger animation
     Using plain CSS sibling combinator because Tailwind peer-checked
     doesn't work across the DOM distance required here.
     ============================================================ -->
<style>
  /* Lang dropdown — remove native disclosure triangle */
  .lang-details > summary {
    list-style: none;
  }
  .lang-details > summary::-webkit-details-marker {
    display: none;
  }

  /* Rotate chevron when dropdown is open */
  .lang-details[open] .lang-chevron {
    transform: rotate(180deg);
  }

  /* Hide the checkbox visually but keep it in the DOM */
  .nav-toggle-input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  /* Mobile menu: collapsed by default */
  .mobile-menu {
    max-height: 0;
    transition: max-height 0.4s ease-in-out;
  }

  /* When checkbox is checked, expand the mobile menu */
  .nav-toggle-input:checked ~ nav .mobile-menu {
    max-height: 600px;
  }

  /* Hamburger bar animations when menu is open */
  .nav-toggle-input:checked ~ nav .hamburger .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle-input:checked ~ nav .hamburger .bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle-input:checked ~ nav .hamburger .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>
