---
/**
 * Nav.astro — Glassmorphism top navigation for Porta D'irta
 */
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const _pathname = (Astro.url.pathname
  .replace(/\.html$/, '')   
  .replace(/\/index$/, '/') 
  .replace(/\/$/, '')       
) || '/';

const _stripped = _pathname.replace(/^\/(en|fr|de)(\/|$)/, '');
const canonPath = _stripped.replace(/^\//, '');

const esHref = canonPath ? `/${canonPath}` : '/';
const enHref = canonPath ? `/en/${canonPath}` : '/en';

const homeHref = lang === 'es' ? '/' : `/${lang}`;
---

<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300..700&display=swap" rel="stylesheet">

<div class="nav-root">
  <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-hidden="true" />

  <nav
    id="main-nav"
    class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-white/10 border-b border-white/20 transition-colors duration-300"
    aria-label="Navegación principal"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-20">

        <a href={homeHref} class="flex-shrink-0" aria-label="Porta D'irta — inicio">
          <img src="/assets/logos/logo-negativo.png" alt="Porta D'irta" class="h-12 lg:h-14 w-auto object-contain" loading="eager" />
        </a>

        <!-- Menú Central -->
        <ul class="hidden xl:flex items-center gap-8 list-none m-0 p-0">
          <li><a href={getRelativeLocaleUrl(lang, 'hotel')} class="font-body text-xs uppercase tracking-widest text-white hover:text-brand-gold transition-colors">{t('nav.hotel')}</a></li>
          <li><a href={getRelativeLocaleUrl(lang, 'restaurante')} class="font-body text-xs uppercase tracking-widest text-white hover:text-brand-gold transition-colors">{t('nav.restaurante')}</a></li>
          <li><a href={getRelativeLocaleUrl(lang, 'eventos')} class="font-body text-xs uppercase tracking-widest text-white hover:text-brand-gold transition-colors">{t('nav.eventos')}</a></li>
          <li><a href={getRelativeLocaleUrl(lang, 'experiencias')} class="font-body text-xs uppercase tracking-widest text-white hover:text-brand-gold transition-colors">{t('nav.experiencias')}</a></li>
        </ul>

        <div class="flex items-center gap-4">
          <!-- BOTONES DE ACCIÓN -->
          <div class="flex items-center gap-2">
            
            <!-- BOTÓN MESA -->
            <a href={getRelativeLocaleUrl(lang, 'restaurante') + '#reservar'} class="inline-flex items-center px-4 py-2 border border-white/30 rounded-sm text-white font-body text-[10px] uppercase tracking-widest hover:bg-white/10 transition-all font-bold">
              {lang === 'es' ? 'Reservar Mesa' : 'Book a Table'}
            </a>

            <!-- BOTÓN IRTA PARK JUNIOR -->
            <a href={getRelativeLocaleUrl(lang, 'irta-park-junior')} class="inline-flex items-center px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white rounded-full font-['Fredoka'] text-[10px] sm:text-[11px] uppercase tracking-wider font-bold transition-all shadow-lg animate-pulse hover:animate-none">
              Irta Park Junior
            </a>
          </div>

          <label for="nav-toggle" class="hamburger xl:hidden flex flex-col justify-center gap-1.5 w-8 h-8 cursor-pointer ml-2">
            <span class="bar block h-0.5 w-full bg-white rounded transition-all"></span>
            <span class="bar block h-0.5 w-full bg-white rounded transition-all"></span>
            <span class="bar block h-0.5 w-full bg-white rounded transition-all"></span>
          </label>
        </div>
      </div>
    </div>

    <!-- Menú móvil -->
    <div class="mobile-menu xl:hidden overflow-hidden bg-brand-blue/98 border-t border-white/10">
      <ul class="list-none m-0 p-0 flex flex-col py-8 px-8 gap-5">
        <li><a href={getRelativeLocaleUrl(lang, 'hotel')} class="text-white text-lg uppercase tracking-widest">Hotel</a></li>
        <li><a href={getRelativeLocaleUrl(lang, 'restaurante')} class="text-white text-lg uppercase tracking-widest">Restaurante</a></li>
        <li><a href={getRelativeLocaleUrl(lang, 'experiencias')} class="text-white text-lg uppercase tracking-widest">Experiencias</a></li>
        <li class="pt-4 border-t border-white/10">
           <a href={getRelativeLocaleUrl(lang, 'restaurante') + '#reservar'} class="block text-center border border-white/30 text-white px-6 py-4 rounded-sm font-bold uppercase tracking-widest">
            Reservar Mesa
           </a>
        </li>
        <li>
           <a href={getRelativeLocaleUrl(lang, 'irta-park-junior')} class="block text-center bg-orange-500 text-white px-6 py-4 rounded-full font-['Fredoka'] font-bold uppercase tracking-widest text-lg">
            Irta Park Junior
           </a>
        </li>
      </ul>
    </div>
  </nav>
</div>

<script>
  (function () {
    const nav = document.getElementById('main-nav');
    if (!nav) return;
    function onScroll() {
      if (window.scrollY > 40) { nav.style.backgroundColor = 'rgba(13, 43, 69, 0.98)'; } 
      else { nav.style.backgroundColor = 'rgba(255, 255, 255, 0.05)'; }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>

<style>
  .nav-toggle-input { position: absolute; opacity: 0; pointer-events: none; }
  .mobile-menu { max-height: 0; transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
  .nav-toggle-input:checked ~ nav .mobile-menu { max-height: 100vh; }
  
  @keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }
  .animate-pulse {
    animation: pulse 3s infinite ease-in-out;
  }
</style>