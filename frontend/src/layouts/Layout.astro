---
/**
 * Layout.astro — Base shell for all Porta D'irta pages
 *
 * Props:
 *   title       — Page <title> and og:title (required)
 *   description — Meta description and og:description (required)
 *   lang        — HTML lang attribute; defaults to 'es' (Spanish)
 *   ogImage     — Open Graph image URL; defaults to a brand placeholder
 *
 * Structure:
 *   <head> — Google Fonts, SEO meta tags, global CSS
 *   <body> — <Nav /> · <slot /> · <Footer />
 *
 * Wave 2 notes:
 *   - Replace ogImage default with a real hosted image.
 *   - Add canonical URL once domain is confirmed.
 *   - Consider adding structured data (JSON-LD) for the hotel/restaurant.
 */

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FloatingActions from '../components/FloatingActions.astro';
import '../styles/global.css';

const {
  title,
  description,
  titleKey,
  descriptionKey,
  ogImage = 'https://www.portadirta.com/assets/images/property-aerial-pool.jpg',
  googleSiteVerification,
  noindex = false,
} = Astro.props;

const fullTitle = `${title} | Porta D'irta`;
const canonicalUrl = new URL(Astro.url.pathname, 'https://www.portadirta.com').href;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `https://www.portadirta.com${ogImage}`;
---

<!doctype html>
<html lang="es" class="scroll-smooth" translate="no"
  data-i18n-title={titleKey}
  data-i18n-desc={descriptionKey}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!--
      Early locale bootstrap — runs synchronously before any paint.
      1. Reads the saved language from localStorage.
      2. Validates it is one of the four supported locales; clears
         invalid / corrupted values (e.g. 'it' from browser auto-detect).
      3. Sets <html lang> immediately so SEO/AT tools see the right value.
      4. Hides the page briefly for non-Spanish users to prevent a flash
         of untranslated Spanish content (FOUC) before the module script
         applies the correct translations.  The module script re-shows the
         page inside applyLang() once translations are in place.
    -->
    <script is:inline>
      (function () {
        var VALID = { es: 1, en: 1, fr: 1, de: 1 };
        var saved;
        try { saved = localStorage.getItem('porta-lang'); } catch (e) { saved = null; }
        if (!saved || !VALID[saved]) {
          saved = 'es';
          try { localStorage.removeItem('porta-lang'); } catch (e) {}
        }
        document.documentElement.lang = saved;
        if (saved !== 'es') {
          // Hide page until i18n-client.ts applies translations.
          // Safety timeout: reveal after 2 s even if the module script fails
          // to load (e.g. network error). Typical reveal happens in < 100 ms.
          document.documentElement.style.visibility = 'hidden';
          setTimeout(function () {
            document.documentElement.style.visibility = '';
          }, 2000);
        }
      })();
    </script>

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />

    <!-- Astro generator tag -->
    <meta name="generator" content={Astro.generator} />

    <!-- ── SEO ────────────────────────────────────────────────── -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Porta D'irta" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- ── Google Fonts ───────────────────────────────────────── -->
    <!-- Preconnect for faster font loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!--
      Cormorant Garamond — display / headings (300, 400, 600, 700)
      Inter             — body / UI (300, 400, 500)
    -->
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Global styles (Tailwind + design tokens) are imported in the
         frontmatter above via `import '../styles/global.css'` —
         Astro injects the compiled stylesheet automatically. -->

    <!-- Per-page <head> injections (JSON-LD, canonical, etc.) -->
    <slot name="head" />

  </head>

  <body class="bg-brand-cream font-body text-brand-blue antialiased">

    <!-- Fixed navigation — sits above all content via z-50 -->
    <Nav />

    <!-- Page-specific content injected here -->
    <main>
      <slot />
    </main>

    <!-- Site footer -->
    <Footer />

    <!-- Floating CTAs (Booking bar + WhatsApp) -->
    <FloatingActions />

    <!-- Client-side i18n engine — swaps data-i18n attributes based on localStorage preference -->
    <script>
      import '../scripts/i18n-client';
    </script>

  </body>
</html>
