---
/**
 * Layout.astro — Base shell for all Porta D'irta pages
 *
 * Props:
 *   title       — Page <title> and og:title (required)
 *   description — Meta description and og:description (required)
 *   lang        — HTML lang attribute; defaults to 'es' (Spanish)
 *   ogImage     — Open Graph image URL; defaults to a brand placeholder
 *
 * Structure:
 *   <head> — Google Fonts, SEO meta tags, global CSS
 *   <body> — <Nav /> · <slot /> · <Footer />
 *
 * Wave 2 notes:
 *   - Replace ogImage default with a real hosted image.
 *   - Add canonical URL once domain is confirmed.
 *   - Consider adding structured data (JSON-LD) for the hotel/restaurant.
 */

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FloatingActions from '../components/FloatingActions.astro';
import '../styles/global.css';
import '@fontsource-variable/cormorant-garamond';
import '@fontsource-variable/inter';

import { getLangFromUrl } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const {
  title,
  description,
  ogImage = 'https://www.portadirta.com/assets/images/property-aerial-pool.jpg',
  googleSiteVerification,
  noindex = false,
} = Astro.props;

const fullTitle = `${title} | Porta D'irta`;
const canonicalUrl = new URL(Astro.url.pathname, 'https://www.portadirta.com').href;
// Ensure og:image is always an absolute URL (Facebook/WhatsApp reject relative paths)
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `https://www.portadirta.com${ogImage}`;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />

    <!-- Astro generator tag -->
    <meta name="generator" content={Astro.generator} />

    <!-- ── SEO ────────────────────────────────────────────────── -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {(() => {
      const purePath = Astro.url.pathname.replace(/^\/(en|fr|de)(\/|$)/, "/");
      const baseUrl = "https://www.portadirta.com";
      return (
        <>
          <link rel="alternate" hreflang="es" href={`${baseUrl}${purePath}`} />
          <link rel="alternate" hreflang="en" href={`${baseUrl}/en${purePath === '/' ? '' : purePath}`} />
          <link rel="alternate" hreflang="fr" href={`${baseUrl}/fr${purePath === '/' ? '' : purePath}`} />
          <link rel="alternate" hreflang="de" href={`${baseUrl}/de${purePath === '/' ? '' : purePath}`} />
          <link rel="alternate" hreflang="x-default" href={`${baseUrl}${purePath}`} />
        </>
      );
    })()}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : lang === 'en' ? 'en_GB' : lang === 'fr' ? 'fr_FR' : 'de_DE'} />
    <meta property="og:site_name" content="Porta D'irta" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Global styles (Tailwind + design tokens) are imported in the
         frontmatter above via `import '../styles/global.css'` —
         Astro injects the compiled stylesheet automatically. -->

    <!-- Per-page <head> injections (JSON-LD, canonical, etc.) -->
    <slot name="head" />

  </head>

  <body class="bg-brand-cream font-body text-brand-blue antialiased">

    <!-- Fixed navigation — sits above all content via z-50 -->
    <Nav />

    <!-- Page-specific content injected here -->
    <main>
      <slot />
    </main>

    <!-- Site footer -->
    <Footer />

    <!-- Floating CTAs (Booking bar + WhatsApp) -->
    <FloatingActions />

  </body>
</html>
