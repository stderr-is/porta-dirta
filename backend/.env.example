# n8n core
N8N_ENCRYPTION_KEY=replace-with-strong-hex-key

# Internal auth
INTERNAL_API_TOKEN=replace-with-internal-shared-secret

# AI Automation Layer
DEEPSEEK_API_KEY=replace-with-deepseek-api-key
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_ADMIN_ID=replace-with-telegram-admin-id
TELEGRAM_COLLAB_ID=replace-with-telegram-collaborator-id

# Beds24 API V2
BEDS24_API_TOKEN=replace-with-beds24-api-token
BEDS24_PROP_ID=replace-with-beds24-property-id

# Business Info
BUSINESS_EMAIL=info@example.com

# Menu System Google Doc IDs
MENU_CARTA_DOC_ID=replace-with-carta-doc-id
MENU_TAPERIA_DOC_ID=replace-with-taperia-doc-id
MENU_MENU_DOC_ID=replace-with-menu-doc-id
MENU_BEBIDAS_DOC_ID=replace-with-bebidas-doc-id
MENU_DESAYUNO_DOC_ID=replace-with-desayuno-doc-id
MENU_STREETFOOD_DOC_ID=replace-with-streetfood-doc-id

# Database — Restaurant (MySQL)
MYSQL_RESTAURANT_PASSWORD=replace-with-mysql-user-password
MYSQL_ROOT_PASSWORD=replace-with-mysql-root-password

# Database — Hi.Events (PostgreSQL)
POSTGRES_HIEVENTS_PASSWORD=replace-with-hievents-postgres-password

# Database — n8n (PostgreSQL)
POSTGRES_N8N_PASSWORD=replace-with-n8n-postgres-password
