---
/**
 * Nav.astro — Glassmorphism top navigation for Porta D'irta
 *
 * Design:
 *   - Fixed top, full-width, z-50.
 *   - Glassmorphism base: backdrop-blur-md + translucent white border.
 *   - On scroll, a small inline <script> adds `.nav-scrolled` to the <nav>
 *     element, increasing background opacity. Uses a passive scroll listener.
 *
 * Mobile menu — pure CSS checkbox trick:
 *   A hidden <input type="checkbox"> with id="nav-toggle" is rendered inside
 *   the nav wrapper. A <label for="nav-toggle"> acts as the hamburger button.
 *   The mobile menu uses the CSS general sibling combinator (~) via a
 *   <style> block below — Tailwind peer-checked can't cross arbitrary DOM
 *   distances, so we use a scoped <style> here instead.
 *
 * No JavaScript framework. No icon libraries.
 *
 * Wave 2 notes:
 *   - Wire up language switcher hrefs to Astro i18n routing helpers.
 *   - Active link state: pass `currentPath` prop and compare.
 *   - Consider replacing checkbox trick with Astro's View Transitions API.
 */
---

<div class="nav-root">

  <!-- ── Hidden checkbox — drives mobile menu open/close ─── -->
  <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-hidden="true" />

  <!-- ── NAV BAR ─────────────────────────────────────────── -->
  <nav
    id="main-nav"
    class="
      fixed top-0 left-0 right-0 z-50
      backdrop-blur-md bg-white/10 border-b border-white/20
      transition-colors duration-300
    "
    aria-label="Navegación principal"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- ── LEFT: Logo ───────────────────────────────── -->
        <a href="/" class="flex-shrink-0" aria-label="Porta D'irta — inicio">
          <img
            src="/assets/logos/logo-negativo.png"
            alt="Porta D'irta"
            class="h-12 w-auto object-contain"
            loading="eager"
            decoding="async"
          />
        </a>

        <!-- ── CENTER: Desktop nav links ────────────────── -->
        <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
          <li>
            <a href="/hotel" class="font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              Hotel
            </a>
          </li>
          <li>
            <a href="/restaurante" class="font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              Restaurante
            </a>
          </li>
          <li>
            <a href="/eventos" class="font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              Eventos
            </a>
          </li>
          <li>
            <a href="/experiencias" class="font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              Experiencias
            </a>
          </li>
          <li>
            <a href="/contacto" class="font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">
              Contacto
            </a>
          </li>
        </ul>

        <!-- ── RIGHT: Lang switcher + CTA + hamburger ───── -->
        <div class="flex items-center gap-4">

          <!-- Language switcher — desktop only -->
          <!-- Wave 2: replace hrefs with Astro i18n locale paths -->
          <div class="hidden md:flex items-center gap-2" aria-label="Seleccionar idioma">
            <a href="/" class="font-body text-xs uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">ES</a>
            <span class="text-white/30 text-xs" aria-hidden="true">|</span>
            <a href="/en" class="font-body text-xs uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200">EN</a>
            <span class="text-white/30 text-xs" aria-hidden="true">|</span>
            <a href="/fr" class="font-body text-xs uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200">FR</a>
            <span class="text-white/30 text-xs" aria-hidden="true">|</span>
            <a href="/de" class="font-body text-xs uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200">DE</a>
          </div>

          <!-- CTA — desktop only -->
          <a
            href="/reservar"
            class="
              hidden md:inline-flex items-center
              px-5 py-2 rounded-sm
              bg-brand-gold hover:bg-brand-stone
              text-brand-blue font-body text-sm uppercase tracking-widest font-medium
              transition-colors duration-200
            "
          >
            Reservar
          </a>

          <!-- Hamburger label — mobile only -->
          <label
            for="nav-toggle"
            class="hamburger md:hidden flex flex-col justify-center gap-[5px] w-8 h-8 cursor-pointer"
            aria-label="Abrir menú de navegación"
          >
            <span class="bar block h-[2px] w-full bg-white rounded transition-all duration-300"></span>
            <span class="bar block h-[2px] w-full bg-white rounded transition-all duration-300"></span>
            <span class="bar block h-[2px] w-full bg-white rounded transition-all duration-300"></span>
          </label>

        </div>
      </div>
    </div>

    <!-- ── Mobile dropdown menu ─────────────────────────────
         Visibility is toggled via the CSS sibling rule in <style>
         below: #nav-toggle:checked ~ nav .mobile-menu { max-height: ... }
         ─────────────────────────────────────────────────── -->
    <div
      class="mobile-menu md:hidden overflow-hidden backdrop-blur-md bg-brand-blue/90 border-t border-white/10"
      aria-label="Menú móvil"
    >
      <ul class="list-none m-0 p-0 flex flex-col py-4">
        <li>
          <a href="/hotel" class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">Hotel</a>
        </li>
        <li>
          <a href="/restaurante" class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">Restaurante</a>
        </li>
        <li>
          <a href="/eventos" class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">Eventos</a>
        </li>
        <li>
          <a href="/experiencias" class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">Experiencias</a>
        </li>
        <li>
          <a href="/contacto" class="block px-6 py-3 font-body text-sm uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">Contacto</a>
        </li>

        <!-- Language switcher — mobile -->
        <li class="px-6 pt-4 pb-2 flex gap-3 border-t border-white/10 mt-2" aria-label="Seleccionar idioma">
          <a href="/" class="font-body text-xs uppercase tracking-widest text-white hover:text-brand-gold transition-colors duration-200">ES</a>
          <span class="text-white/30 text-xs" aria-hidden="true">|</span>
          <a href="/en" class="font-body text-xs uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200">EN</a>
          <span class="text-white/30 text-xs" aria-hidden="true">|</span>
          <a href="/fr" class="font-body text-xs uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200">FR</a>
          <span class="text-white/30 text-xs" aria-hidden="true">|</span>
          <a href="/de" class="font-body text-xs uppercase tracking-widest text-white/70 hover:text-brand-gold transition-colors duration-200">DE</a>
        </li>

        <!-- CTA — mobile -->
        <li class="px-6 pt-2 pb-4">
          <a
            href="/reservar"
            class="
              block w-full text-center
              px-5 py-3 rounded-sm
              bg-brand-gold hover:bg-brand-stone
              text-brand-blue font-body text-sm uppercase tracking-widest font-medium
              transition-colors duration-200
            "
          >
            Reservar
          </a>
        </li>
      </ul>
    </div>

  </nav>
</div>

<!-- ============================================================
     SCROLL SCRIPT
     Adds/removes a class on #main-nav to increase bg opacity
     after the user scrolls past 40 px. Passive listener for
     smooth 60 fps performance.
     ============================================================ -->
<script>
  (function () {
    const nav = document.getElementById('main-nav');
    if (!nav) return;

    function onScroll() {
      if (window.scrollY > 40) {
        // More opaque — brand blue tint becomes visible
        nav.style.backgroundColor = 'rgba(13, 43, 69, 0.85)';
      } else {
        // Default glassmorphism — nearly transparent
        nav.style.backgroundColor = 'rgba(255, 255, 255, 0.10)';
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // Initialise on page load
  })();
</script>

<!-- ============================================================
     SCOPED STYLES — mobile menu toggle + hamburger animation
     Using plain CSS sibling combinator because Tailwind peer-checked
     doesn't work across the DOM distance required here.
     ============================================================ -->
<style>
  /* Hide the checkbox visually but keep it in the DOM */
  .nav-toggle-input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  /* Mobile menu: collapsed by default */
  .mobile-menu {
    max-height: 0;
    transition: max-height 0.4s ease-in-out;
  }

  /* When checkbox is checked, expand the mobile menu */
  .nav-toggle-input:checked ~ nav .mobile-menu {
    max-height: 600px;
  }

  /* Hamburger bar animations when menu is open */
  .nav-toggle-input:checked ~ nav .hamburger .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle-input:checked ~ nav .hamburger .bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle-input:checked ~ nav .hamburger .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>
