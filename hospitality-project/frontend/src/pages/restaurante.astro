---
/**
 * restaurante.astro — Restaurant page for Porta D'irta
 *
 * Sections:
 *   1. Hero          — Full-viewport, bg image + brand-blue overlay
 *   2. Philosophy    — Two-column: text + portrait image
 *   3. Menus         — 3 glassmorphism cards on brand-blue
 *   4. Gallery strip — 4 images with hover zoom
 *   5. Table Booking — Frosted glass form
 *   6. Hours & Map   — Two-column: hours table + map placeholder
 */

import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Restaurante"
  description="Sabores del Mediterráneo en Peñíscola. Cocina de temporada, producto local y vistas al mar en el restaurante de Porta D'irta."
  ogImage="https://picsum.photos/1200/630?random=20"
>

  <!-- ================================================================
       SECTION 1 — HERO
       ================================================================ -->
  <section
    class="relative min-h-screen flex flex-col items-center justify-center text-center overflow-hidden"
    aria-label="Hero del restaurante"
  >
    <!-- REPLACE: real restaurant hero photo -->
    <img
      src="https://picsum.photos/1920/1080?random=20"
      alt="Terraza del restaurante Porta D'irta frente al mar"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      decoding="async"
    />
    <!-- REPLACE: real restaurant hero photo -->

    <!-- Brand-blue overlay -->
    <div class="absolute inset-0 bg-brand-blue/70"></div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center gap-6 px-4">
      <!-- Eyebrow label -->
      <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
        Restaurante
      </span>

      <!-- Main heading -->
      <h1 class="font-display italic text-7xl text-white leading-tight max-w-3xl">
        Sabores del Mediterráneo
      </h1>

      <!-- Tagline -->
      <p class="font-body text-lg text-white/80 max-w-xl leading-relaxed">
        Cocina de temporada, producto local y el mar como horizonte.<br />
        Una experiencia gastronómica única en Peñíscola.
      </p>
    </div>

    <!-- Scroll chevron -->
    <a
      href="#filosofia"
      class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 text-white/60 hover:text-brand-gold transition-colors duration-300 animate-bounce"
      aria-label="Desplazarse hacia abajo"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </a>
  </section>

  <!-- ================================================================
       SECTION 2 — PHILOSOPHY / ABOUT
       ================================================================ -->
  <section
    id="filosofia"
    class="bg-brand-cream py-24 md:py-32"
    aria-label="Nuestra filosofía"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center min-h-[60vh]">

        <!-- Left: text -->
        <div class="flex flex-col gap-6">
          <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
            Nuestra Filosofía
          </span>
          <h2 class="font-display text-5xl text-brand-blue leading-tight">
            El sabor auténtico de la Costa del Azahar
          </h2>
          <p class="font-body text-base text-brand-stone leading-relaxed">
            En el restaurante de Porta D'irta creemos que la gastronomía es un
            reflejo del territorio. Por eso trabajamos mano a mano con
            productores locales de Castellón para ofrecer una carta de temporada
            que honra los ingredientes de nuestra tierra: el arroz de los
            arrozales del Maestrazgo, el pescado fresco de la lonja de
            Peñíscola y las verduras de huerta cultivadas a escasos kilómetros.
          </p>
          <p class="font-body text-base text-brand-stone leading-relaxed">
            Nuestra cocina fusiona la tradición mediterránea con técnicas
            contemporáneas, buscando siempre la sencillez con elegancia. Cada
            plato es una invitación a descubrir los sabores que han definido
            esta costa durante siglos, elaborados con mimo y respeto por el
            producto. Comer en Porta D'irta es, ante todo, una experiencia de
            lugar.
          </p>
        </div>

        <!-- Right: image -->
        <div>
          <!-- REPLACE: real photo -->
          <img
            src="https://picsum.photos/600/700?random=21"
            alt="Chef preparando un plato mediterráneo en la cocina"
            class="w-full h-auto rounded-sm shadow-xl object-cover"
            loading="lazy"
            decoding="async"
          />
          <!-- REPLACE: real photo -->
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================================
       SECTION 3 — MENUS
       ================================================================ -->
  <section
    class="bg-brand-blue py-24 md:py-32"
    aria-label="Nuestra carta"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section heading -->
      <div class="text-center mb-16">
        <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
          Gastronomía
        </span>
        <h2 class="font-display text-5xl text-white mt-3">
          Nuestra Carta
        </h2>
      </div>

      <!-- REPLACE: real menu data -->
      <!-- 3 cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Card 1: Menú del Día -->
        <article class="backdrop-blur-sm bg-white/10 border border-white/20 rounded-xl p-8 flex flex-col gap-6">
          <div>
            <h3 class="font-display text-2xl text-white">Menú del Día</h3>
            <p class="font-body text-xs uppercase tracking-widest text-brand-sand mt-1">
              De lunes a viernes al mediodía
            </p>
          </div>
          <p class="font-display italic text-4xl text-brand-gold">€15</p>
          <p class="font-body text-sm text-white/70 leading-relaxed">
            El menú del día reúne lo mejor de la temporada en tres pasos, con
            bebida incluida. Cambia cada semana según el mercado local.
          </p>
          <ul class="flex flex-col gap-3 list-none m-0 p-0">
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1 h-1 rounded-full bg-brand-gold flex-shrink-0"></span>
              <span class="font-body text-sm text-white/80">
                <strong class="font-medium text-white">Primer plato</strong> — Ensalada de tomate de temporada con aceite de oliva virgen extra
              </span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1 h-1 rounded-full bg-brand-gold flex-shrink-0"></span>
              <span class="font-body text-sm text-white/80">
                <strong class="font-medium text-white">Segundo plato</strong> — Arroz a banda con alioli casero y gambas de la lonja
              </span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1 h-1 rounded-full bg-brand-gold flex-shrink-0"></span>
              <span class="font-body text-sm text-white/80">
                <strong class="font-medium text-white">Postre</strong> — Flan de huevo con caramelo o fruta del tiempo
              </span>
            </li>
          </ul>
        </article>

        <!-- Card 2: Carta de Temporada -->
        <article class="backdrop-blur-sm bg-white/10 border border-white/20 rounded-xl p-8 flex flex-col gap-6">
          <div>
            <h3 class="font-display text-2xl text-white">Carta de Temporada</h3>
            <p class="font-body text-xs uppercase tracking-widest text-brand-sand mt-1">
              Producto local y km 0
            </p>
          </div>
          <p class="font-display italic text-2xl text-brand-gold">Bajo petición</p>
          <p class="font-body text-sm text-white/70 leading-relaxed">
            Una selección de platos elaborados con ingredientes de proximidad,
            renovada según la estación. Perfecta para compartir y descubrir
            los sabores más auténticos de la costa.
          </p>
          <ul class="flex flex-col gap-3 list-none m-0 p-0">
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1 h-1 rounded-full bg-brand-gold flex-shrink-0"></span>
              <span class="font-body text-sm text-white/80">Croquetas de bacallà con romesco suave</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1 h-1 rounded-full bg-brand-gold flex-shrink-0"></span>
              <span class="font-body text-sm text-white/80">Pulpo a la brasa con parmentier de patata ahumada</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1 h-1 rounded-full bg-brand-gold flex-shrink-0"></span>
              <span class="font-body text-sm text-white/80">Lubina salvaje al horno con hinojo y cítricos</span>
            </li>
          </ul>
        </article>

        <!-- Card 3: Menú de Degustación -->
        <article class="backdrop-blur-sm bg-white/10 border border-white/20 rounded-xl p-8 flex flex-col gap-6">
          <div>
            <h3 class="font-display text-2xl text-white">Menú de Degustación</h3>
            <p class="font-body text-xs uppercase tracking-widest text-brand-sand mt-1">
              Experiencia gastronómica premium
            </p>
          </div>
          <p class="font-display italic text-4xl text-brand-gold">€45<span class="text-xl font-body font-light text-white/60">/persona</span></p>
          <p class="font-body text-sm text-white/70 leading-relaxed">
            Un recorrido por nuestra cocina en siete tiempos, con maridaje de
            vinos valencianos disponible a precio adicional. Reserva previa
            obligatoria con 24 horas de antelación.
          </p>
          <ul class="flex flex-col gap-3 list-none m-0 p-0">
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1 h-1 rounded-full bg-brand-gold flex-shrink-0"></span>
              <span class="font-body text-sm text-white/80">Snacks de bienvenida y aperitivo de la casa</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1 h-1 rounded-full bg-brand-gold flex-shrink-0"></span>
              <span class="font-body text-sm text-white/80">Cinco pases de temporada con producto de la lonja</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1 h-1 rounded-full bg-brand-gold flex-shrink-0"></span>
              <span class="font-body text-sm text-white/80">Petit fours y selección de postres de autor</span>
            </li>
          </ul>
        </article>

      </div>
      <!-- REPLACE: real menu data -->

    </div>
  </section>

  <!-- ================================================================
       SECTION 4 — GALLERY STRIP
       ================================================================ -->
  <section
    class="bg-brand-cream py-24 md:py-32"
    aria-label="Galería de imágenes"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- 4-image strip -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 overflow-hidden">

        <!-- Image 1 -->
        <div class="overflow-hidden rounded-sm">
          <!-- REPLACE: real photo -->
          <img
            src="https://picsum.photos/400/400?random=22"
            alt="Terraza del restaurante con vistas al mar"
            class="w-full h-64 object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <!-- REPLACE: real photo -->
        </div>

        <!-- Image 2 -->
        <div class="overflow-hidden rounded-sm">
          <!-- REPLACE: real photo -->
          <img
            src="https://picsum.photos/400/400?random=23"
            alt="Jardín del restaurante al atardecer"
            class="w-full h-64 object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <!-- REPLACE: real photo -->
        </div>

        <!-- Image 3 -->
        <div class="overflow-hidden rounded-sm">
          <!-- REPLACE: real photo -->
          <img
            src="https://picsum.photos/400/400?random=24"
            alt="Interior elegante del salón principal"
            class="w-full h-64 object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <!-- REPLACE: real photo -->
        </div>

        <!-- Image 4 -->
        <div class="overflow-hidden rounded-sm">
          <!-- REPLACE: real photo -->
          <img
            src="https://picsum.photos/400/400?random=25"
            alt="Detalle de un plato del menú de degustación"
            class="w-full h-64 object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <!-- REPLACE: real photo -->
        </div>

      </div>

      <!-- Caption -->
      <p class="text-center font-body text-sm text-brand-stone tracking-wider mt-8">
        La terraza, el jardín y el interior
      </p>

    </div>
  </section>

  <!-- ================================================================
       SECTION 5 — TABLE BOOKING
       ================================================================ -->
  <section
    class="bg-brand-blue py-24 md:py-32"
    aria-label="Reserva tu mesa"
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Heading -->
      <div class="text-center mb-12">
        <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
          Reservas
        </span>
        <h2 class="font-display text-5xl text-white mt-3">
          Reserva tu Mesa
        </h2>
      </div>

      <!-- REPLACE: TastyIgniter booking widget -->
      <!-- Frosted glass form card -->
      <div class="backdrop-blur-md bg-white/10 border border-white/20 rounded-xl p-8">
        <form
          id="restaurant-form"
          method="POST"
          action="/api/reservas"
          novalidate
          class="flex flex-col gap-5"
          aria-label="Formulario de reserva de mesa"
        >
          <input type="hidden" name="source" value="restaurante" />

          <!-- Row 1: Nombre + Email -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-2">
              <label for="nombre" class="font-body text-xs uppercase tracking-widest text-white/70">
                Nombre *
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                autocomplete="name"
                placeholder="Tu nombre completo"
                class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label for="email" class="font-body text-xs uppercase tracking-widest text-white/70">
                Email *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder="tu@email.com"
                class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200"
              />
            </div>
          </div>

          <!-- Row 2: Teléfono + Nº personas -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-2">
              <label for="telefono" class="font-body text-xs uppercase tracking-widest text-white/70">
                Teléfono *
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                required
                autocomplete="tel"
                placeholder="+34 600 000 000"
                class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label for="personas" class="font-body text-xs uppercase tracking-widest text-white/70">
                Nº Personas *
              </label>
              <input
                type="number"
                id="personas"
                name="personas"
                required
                min="1"
                max="20"
                placeholder="2"
                class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200"
              />
            </div>
          </div>

          <!-- Row 3: Fecha + Hora -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-2">
              <label for="fecha" class="font-body text-xs uppercase tracking-widest text-white/70">
                Fecha *
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                required
                class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label for="hora" class="font-body text-xs uppercase tracking-widest text-white/70">
                Hora *
              </label>
              <select
                id="hora"
                name="hora"
                required
                class="bg-white/20 border border-white/30 text-white rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200 appearance-none"
              >
                <option value="" disabled selected class="text-brand-blue">Selecciona un turno</option>
                <optgroup label="Mediodía" class="text-brand-blue">
                  <option value="13:00" class="text-brand-blue">13:00</option>
                  <option value="13:30" class="text-brand-blue">13:30</option>
                  <option value="14:00" class="text-brand-blue">14:00</option>
                  <option value="14:30" class="text-brand-blue">14:30</option>
                  <option value="15:00" class="text-brand-blue">15:00</option>
                  <option value="15:30" class="text-brand-blue">15:30</option>
                </optgroup>
                <optgroup label="Noche" class="text-brand-blue">
                  <option value="20:00" class="text-brand-blue">20:00</option>
                  <option value="20:30" class="text-brand-blue">20:30</option>
                  <option value="21:00" class="text-brand-blue">21:00</option>
                  <option value="21:30" class="text-brand-blue">21:30</option>
                  <option value="22:00" class="text-brand-blue">22:00</option>
                  <option value="22:30" class="text-brand-blue">22:30</option>
                </optgroup>
              </select>
            </div>
          </div>

          <!-- Observaciones -->
          <div class="flex flex-col gap-2">
            <label for="observaciones" class="font-body text-xs uppercase tracking-widest text-white/70">
              Observaciones
            </label>
            <textarea
              id="observaciones"
              name="observaciones"
              rows="4"
              placeholder="Alergias, celebraciones especiales, preferencias de mesa..."
              class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200 resize-none"
            ></textarea>
          </div>

          <!-- Submit CTA -->
          <button
            type="submit"
            class="w-full px-8 py-4 bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium rounded-lg transition-colors duration-200 mt-2"
          >
            Confirmar Reserva
          </button>

        </form>

        <!-- Phone fallback -->
        <p class="text-center font-body text-sm text-white/50 mt-6">
          O llámanos al
          <a href="tel:+34964000000" class="text-white/80 hover:text-brand-gold transition-colors duration-200">
            +34 964 00 00 00
          </a>
        </p>
      </div>
      <!-- REPLACE: TastyIgniter booking widget -->

    </div>
  </section>

  <script>
    document.getElementById('restaurant-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const btn = form.querySelector('button[type="submit"]');
      const originalText = btn.textContent;
      btn.textContent = 'Enviando...';
      btn.disabled = true;

      try {
        const data = Object.fromEntries(new FormData(form));
        const res = await fetch('REPLACE_WITH_N8N_RESTAURANT_WEBHOOK', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error('Error en el servidor');
        form.innerHTML = '<div class="text-center py-8"><p class="text-brand-gold font-display text-2xl italic">¡Gracias! Nos pondremos en contacto pronto.</p></div>';
      } catch (err) {
        btn.textContent = originalText;
        btn.disabled = false;
        let errDiv = form.querySelector('.form-error');
        if (!errDiv) {
          errDiv = document.createElement('p');
          errDiv.className = 'form-error text-red-400 text-sm text-center mt-2';
          form.appendChild(errDiv);
        }
        errDiv.textContent = 'Ha ocurrido un error. Por favor inténtalo de nuevo o llámanos directamente.';
      }
    });
  </script>

  <!-- ================================================================
       SECTION 6 — HOURS & LOCATION
       ================================================================ -->
  <section
    class="bg-brand-cream py-24 md:py-32"
    aria-label="Horarios y ubicación"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">

        <!-- Left: Opening hours -->
        <div class="flex flex-col gap-8">
          <div>
            <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
              Horarios
            </span>
            <h2 class="font-display text-4xl text-brand-blue mt-3">
              Cuándo nos puedes visitar
            </h2>
          </div>

          <table class="w-full font-body text-sm" aria-label="Horario del restaurante">
            <tbody class="divide-y divide-brand-stone/20">
              <tr>
                <td class="py-4 pr-6 text-brand-stone font-medium">Martes – Viernes</td>
                <td class="py-4 text-brand-blue">
                  13:00 – 16:00
                  <span class="mx-2 text-brand-stone/40" aria-hidden="true">·</span>
                  20:00 – 23:00
                </td>
              </tr>
              <tr>
                <td class="py-4 pr-6 text-brand-stone font-medium">Sábado – Domingo</td>
                <td class="py-4 text-brand-blue">
                  Todo el día — 12:30 – 23:30
                </td>
              </tr>
              <tr>
                <td class="py-4 pr-6 text-brand-stone font-medium">Lunes</td>
                <td class="py-4 text-brand-stone italic">Cerrado</td>
              </tr>
            </tbody>
          </table>

          <p class="font-body text-xs text-brand-stone/70 leading-relaxed">
            Los horarios pueden variar en festivos y temporada baja.<br />
            Recomendamos reservar con antelación, especialmente en fin de semana.
          </p>
        </div>

        <!-- Right: Map placeholder -->
        <div class="flex flex-col gap-6">
          <div>
            <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
              Ubicación
            </span>
            <h2 class="font-display text-4xl text-brand-blue mt-3">
              Cómo llegar
            </h2>
          </div>

          <!-- REPLACE: Google Maps embed -->
          <div class="bg-brand-stone/20 rounded-xl h-64 flex flex-col items-center justify-center gap-3 border border-brand-stone/10">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-brand-stone/50"
              aria-hidden="true"
            >
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <p class="font-body text-sm text-brand-stone/60 tracking-wider">
