---
/**
 * restaurante.astro — Restaurant page for Porta D'irta
 *
 * Sections:
 *   1. Hero          — Full-viewport, bg image + brand-blue overlay
 *   2. Philosophy    — Two-column: text + portrait image
 *   3. Menus         — 3 glassmorphism cards on brand-blue
 *   4. Gallery strip — 4 images with hover zoom
 *   5. Table Booking — Frosted glass form
 *   6. Hours & Map   — Two-column: hours table + map placeholder
 */

import Layout from '../layouts/Layout.astro';
import GarlandDivider from '../components/GarlandDivider.astro';
---

<Layout
  title="Restaurante"
  description="Sabores del Mediterráneo en Peñíscola. Cocina de temporada, producto local y vistas al mar en el restaurante de Porta D'irta."
  ogImage="/assets/images/food-paella-wine.jpg"
>

  <script type="application/ld+json" slot="head" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "Restaurant",
      "name": "Restaurante Porta D'irta",
      "description": "Porta D'irta is a Mediterranean restaurant in Peñíscola, Castellón, specialized in seasonal local products, Maestrazgo rice, and fresh fish from the local market.",
      "url": "https://www.portadirta.com/restaurante",
      "telephone": "+34644026066",
      "servesCuisine": ["Mediterránea", "Española", "Arroces"],
      "priceRange": "€€€",
      "acceptsReservations": "true",
      "menu": "https://www.portadirta.com/carta",
      "currenciesAccepted": "EUR",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Camí del Pebret, s/n",
        "addressLocality": "Peñíscola",
        "addressRegion": "Castellón",
        "postalCode": "12598",
        "addressCountry": "ES"
      },
      "image": "https://www.portadirta.com/assets/images/food-paella-wine.jpg",
      "isContainedInPlace": {
        "@type": "LodgingBusiness",
        "name": "Porta D'irta",
        "url": "https://www.portadirta.com/hotel"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "13:00",
          "closes": "16:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "20:00",
          "closes": "22:00"
        }
      ],
      "hasMap": "https://maps.google.com/?q=Porta+D%27irta+Pe%C3%B1%C3%ADscola"
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": "https://www.portadirta.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Restaurante",
          "item": "https://www.portadirta.com/restaurante"
        }
      ]
    }
  ])} />

  <!-- ================================================================
       SECTION 1 — HERO
       ================================================================ -->
  <section
    class="relative min-h-screen flex flex-col items-center justify-center text-center overflow-hidden"
    aria-label="Hero del restaurante"
  >
    <!-- REPLACE: real restaurant hero photo -->
    <img
      src="/assets/images/restaurant-terrace.jpg"
      alt="Terraza del restaurante Porta D'irta frente al mar"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      decoding="async"
    />
    <!-- REPLACE: real restaurant hero photo -->

    <!-- Brand-blue overlay -->
    <div class="absolute inset-0 bg-brand-forest/52"></div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center gap-6 px-4">
      <!-- Eyebrow label -->
      <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
        Restaurante
      </span>

      <!-- Main heading -->
      <h1 class="font-display italic text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-white leading-tight max-w-3xl">
        Sabores del Mediterráneo
      </h1>

      <!-- Tagline -->
      <p class="font-body text-base sm:text-lg text-white/80 max-w-xl leading-relaxed">
        Cocina de temporada, producto local y el mar como horizonte.
        Una experiencia gastronómica única en Peñíscola.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row items-center gap-4 mt-2">
        <a
          href="#reservar"
          class="inline-flex items-center px-8 py-4 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium transition-colors duration-300 shadow-lg"
        >
          Reservar Mesa
        </a>
        <a
          href="#filosofia"
          class="inline-flex items-center px-8 py-4 rounded-sm border border-white/60 hover:border-white text-white font-body text-sm uppercase tracking-widest font-medium transition-colors duration-300"
        >
          Descubrir
        </a>
      </div>
    </div>

    <!-- Scroll chevron -->
    <a
      href="#filosofia"
      class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 text-white/60 hover:text-brand-gold transition-colors duration-300 animate-bounce"
      aria-label="Desplazarse hacia abajo"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </a>
  </section>

  <!-- ================================================================
       SECTION 2 — PHILOSOPHY / ABOUT
       ================================================================ -->
  <section
    id="filosofia"
    class="bg-brand-cream py-24 md:py-32"
    aria-label="Nuestra filosofía"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center min-h-[60vh]">

        <!-- Left: text -->
        <div class="flex flex-col gap-6">
          <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
            Nuestra Filosofía
          </span>
          <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-brand-blue leading-tight">
            El sabor auténtico de la Costa del Azahar
          </h2>
          <p class="font-body text-base text-brand-stone leading-relaxed">
            En el restaurante de Porta D'irta creemos que la gastronomía es un
            reflejo del territorio. Por eso trabajamos mano a mano con
            productores locales de Castellón para ofrecer una carta de temporada
            que honra los ingredientes de nuestra tierra: el arroz de los
            arrozales del Maestrazgo, el pescado fresco de la lonja de
            Peñíscola y las verduras de huerta cultivadas a escasos kilómetros.
          </p>
          <p class="font-body text-base text-brand-stone leading-relaxed">
            Nuestra cocina fusiona la tradición mediterránea con técnicas
            contemporáneas, buscando siempre la sencillez con elegancia. Cada
            plato es una invitación a descubrir los sabores que han definido
            esta costa durante siglos, elaborados con mimo y respeto por el
            producto. Comer en Porta D'irta es, ante todo, una experiencia de
            lugar.
          </p>
        </div>

        <!-- Right: image -->
        <div>
          <!-- REPLACE: real photo -->
          <img
            src="/assets/images/food-paella-serving.jpg"
            alt="Chef preparando un plato mediterráneo en la cocina"
            width="800" height="600"
            class="w-full h-auto rounded-sm shadow-xl object-cover"
            loading="lazy"
            decoding="async"
          />
          <!-- REPLACE: real photo -->
        </div>

      </div>
    </div>
  </section>

  <!-- ================================================================
       SECTION 3 — MENUS
       ================================================================ -->
  <section
    class="bg-brand-blue py-24 md:py-32"
    aria-label="Nuestra carta"
  >
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section heading -->
      <div id="carta" class="text-center mb-16">
        <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
          Gastronomía
        </span>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-white mt-3">
          Nuestra Carta
        </h2>
        <p class="font-body text-sm text-white/60 mt-4 max-w-2xl mx-auto">
          Descubre una propuesta culinaria que rinde homenaje al producto local de Castellón,
          desde los pescados de la lonja hasta los arroces de la huerta valenciana.
        </p>
      </div>

      <!-- Two CTA cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

        <!-- Card: La Carta -->
        <a
          href="/carta"
          class="group backdrop-blur-sm bg-white/10 hover:bg-white/15 border border-white/20 hover:border-brand-gold/40 rounded-xl p-8 flex flex-col gap-5 transition-all duration-300"
        >
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-display text-2xl text-white group-hover:text-brand-gold transition-colors duration-200">
                La Carta
              </h3>
              <p class="font-body text-xs uppercase tracking-widest text-brand-sand/70 mt-1">
                Tapas · Arroces · Platos · Postres
              </p>
            </div>
            <span class="text-brand-gold/60 group-hover:text-brand-gold group-hover:translate-x-1 transition-all duration-200 text-xl mt-1">→</span>
          </div>
          <p class="font-body text-sm text-white/65 leading-relaxed">
            Nuestra carta completa à la carte. Desde tapas para compartir
            hasta arroces valencianos y platos principales con producto de temporada.
          </p>
          <span class="font-body text-xs uppercase tracking-widest text-brand-gold mt-auto">
            Ver carta completa →
          </span>
        </a>

        <!-- Card: Menú Especial -->
        <a
          href="/menu"
          class="group backdrop-blur-sm bg-white/10 hover:bg-white/15 border border-white/20 hover:border-brand-gold/40 rounded-xl p-8 flex flex-col gap-5 transition-all duration-300"
        >
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-display text-2xl text-white group-hover:text-brand-gold transition-colors duration-200">
                Menú Especial
              </h3>
              <p class="font-body text-xs uppercase tracking-widest text-brand-sand/70 mt-1">
                Precio fijo · Todo incluido
              </p>
            </div>
            <span class="text-brand-gold/60 group-hover:text-brand-gold group-hover:translate-x-1 transition-all duration-200 text-xl mt-1">→</span>
          </div>
          <p class="font-body text-sm text-white/65 leading-relaxed">
            Un menú cerrado a precio fijo con entrantes, plato principal a elegir
            y postre casero. Pan y agua incluidos.
          </p>
          <span class="font-body text-xs uppercase tracking-widest text-brand-gold mt-auto">
            Ver menú especial →
          </span>
        </a>

      </div>

    </div>
  </section>

  <!-- ================================================================
       SECTION 4 — GALLERY STRIP
       ================================================================ -->
  <section
    class="bg-brand-cream py-24 md:py-32"
    aria-label="Galería de imágenes"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- 4-image strip -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 overflow-hidden">

        <!-- Image 1 -->
        <div class="overflow-hidden rounded-sm">
          <!-- REPLACE: real photo -->
          <img
            src="/assets/images/food-paella-close.jpg"
            alt="Terraza del restaurante con vistas al mar"
            class="w-full h-64 object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <!-- REPLACE: real photo -->
        </div>

        <!-- Image 2 -->
        <div class="overflow-hidden rounded-sm">
          <!-- REPLACE: real photo -->
          <img
            src="/assets/images/food-paella-wine.jpg"
            alt="Jardín del restaurante al atardecer"
            class="w-full h-64 object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <!-- REPLACE: real photo -->
        </div>

        <!-- Image 3 -->
        <div class="overflow-hidden rounded-sm">
          <!-- REPLACE: real photo -->
          <img
            src="/assets/images/restaurant-aerial.jpg"
            alt="Interior elegante del salón principal"
            class="w-full h-64 object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <!-- REPLACE: real photo -->
        </div>

        <!-- Image 4 -->
        <div class="overflow-hidden rounded-sm">
          <!-- REPLACE: real photo -->
          <img
            src="/assets/images/restaurant-terrace.jpg"
            alt="Detalle de un plato del menú de degustación"
            class="w-full h-64 object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <!-- REPLACE: real photo -->
        </div>

      </div>

      <!-- Caption -->
      <p class="text-center font-body text-sm text-brand-stone tracking-wider mt-8">
        La terraza, el jardín y el interior
      </p>

    </div>
  </section>

  <!-- ================================================================
       SECTION 5 — TABLE BOOKING
       ================================================================ -->
  <section
    id="reservar"
    class="bg-brand-blue py-24 md:py-32"
    aria-label="Reserva tu mesa"
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- TODO: REMOVE BEFORE LAUNCH — beta disclaimer -->
      <div class="mb-10 bg-amber-400/90 border border-amber-300 text-amber-950 font-body text-sm px-4 py-3 rounded-lg text-center">
        ⚠️ Sistema en fase de pruebas. Para reservas, contacta directamente por teléfono:
        <a href="tel:+34644026066" class="font-semibold underline">+34 644 026 066</a>
      </div>

      <!-- Heading -->
      <div class="text-center mb-12">
        <span class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">
          Reservas
        </span>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-white mt-3">
          Reserva tu Mesa
        </h2>
      </div>

      <!-- REPLACE: TastyIgniter booking widget -->
      <!-- Frosted glass form card -->
      <div class="backdrop-blur-md bg-white/10 border border-white/20 rounded-xl p-4 sm:p-6 lg:p-8">
        <form
          id="restaurant-form"
          method="POST"
          action="/api/reservas"
          novalidate
          class="flex flex-col gap-5"
          aria-label="Formulario de reserva de mesa"
        >
          <input type="hidden" name="source" value="restaurante" />

          <!-- Row 1: Nombre + Email -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-2">
              <label for="nombre" class="font-body text-xs uppercase tracking-widest text-white/70">
                Nombre *
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                autocomplete="name"
                placeholder="Tu nombre completo"
                class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label for="email" class="font-body text-xs uppercase tracking-widest text-white/70">
                Email *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder="tu@email.com"
                class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200"
              />
            </div>
          </div>

          <!-- Row 2: Teléfono + Nº personas -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-2">
              <label for="telefono" class="font-body text-xs uppercase tracking-widest text-white/70">
                Teléfono *
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                required
                autocomplete="tel"
                placeholder="+34 600 000 000"
                class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label for="personas" class="font-body text-xs uppercase tracking-widest text-white/70">
                Nº Personas *
              </label>
              <input
                type="number"
                id="personas"
                name="personas"
                required
                min="1"
                max="20"
                placeholder="2"
                class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200"
              />
            </div>
          </div>

          <!-- Row 3: Fecha + Hora -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-2">
              <label for="fecha" class="font-body text-xs uppercase tracking-widest text-white/70">
                Fecha *
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                required
                class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label for="hora" class="font-body text-xs uppercase tracking-widest text-white/70">
                Hora *
              </label>
              <select
                id="hora"
                name="hora"
                required
                class="bg-white/20 border border-white/30 text-white rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200 appearance-none"
              >
                <option value="" disabled selected class="text-brand-blue">Selecciona un turno</option>
                <optgroup label="Mediodía" class="text-brand-blue">
                  <option value="13:00" class="text-brand-blue">13:00</option>
                  <option value="13:30" class="text-brand-blue">13:30</option>
                  <option value="14:00" class="text-brand-blue">14:00</option>
                  <option value="14:30" class="text-brand-blue">14:30</option>
                  <option value="15:00" class="text-brand-blue">15:00</option>
                  <option value="15:30" class="text-brand-blue">15:30</option>
                </optgroup>
                <optgroup label="Noche" class="text-brand-blue">
                  <option value="20:00" class="text-brand-blue">20:00</option>
                  <option value="20:30" class="text-brand-blue">20:30</option>
                  <option value="21:00" class="text-brand-blue">21:00</option>
                  <option value="21:30" class="text-brand-blue">21:30</option>
                  <option value="22:00" class="text-brand-blue">22:00</option>
                  <option value="22:30" class="text-brand-blue">22:30</option>
                </optgroup>
              </select>
            </div>
          </div>

          <!-- Observaciones -->
          <div class="flex flex-col gap-2">
            <label for="observaciones" class="font-body text-xs uppercase tracking-widest text-white/70">
              Observaciones
            </label>
            <textarea
              id="observaciones"
              name="observaciones"
              rows="4"
              placeholder="Alergias, celebraciones especiales, preferencias de mesa..."
              class="bg-white/20 border border-white/30 text-white placeholder-white/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-gold transition-colors duration-200 resize-none"
            ></textarea>
          </div>

          <!-- RGPD: Consentimiento (Art. 6.1.a RGPD) -->
          <div class="flex items-start gap-3">
            <input
              type="checkbox"
              id="rgpd"
              name="rgpd"
              required
              class="mt-1 h-4 w-4 flex-shrink-0 rounded border-white/40 bg-white/20 text-brand-gold focus:ring-brand-gold"
            />
            <label for="rgpd" class="font-body text-xs text-white/70 leading-relaxed">
              He leído y acepto la
              <a href="/privacidad" target="_blank" class="underline hover:text-brand-gold">Política de Privacidad</a>.
              Consiento el tratamiento de mis datos para gestionar mi reserva. *
            </label>
          </div>

          <!-- Submit CTA -->
          <button
            type="submit"
            class="w-full px-8 py-4 bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium rounded-lg transition-colors duration-200 mt-2"
          >
            Confirmar Reserva
          </button>

        </form>

        <!-- Phone fallback -->
        <p class="text-center font-body text-sm text-white/50 mt-6">
          O llámanos al
          <a href="tel:+34644026066" class="text-white/80 hover:text-brand-gold transition-colors duration-200">
            +34 644 026 066
          </a>
        </p>
      </div>
      <!-- REPLACE: TastyIgniter booking widget -->

    </div>
  </section>

  <!-- Pre-fill form from URL params sent by Beds24 confirmation emails.
       Supported params: fecha (YYYY-MM-DD), personas, nombre, email, telefono
       Example: /restaurante?fecha=2026-07-15&personas=2&nombre=John+Doe&email=john@example.com -->
  <script is:inline>
    (function () {
      var p = new URLSearchParams(window.location.search);
      var map = {
        fecha:    'fecha',
        personas: 'personas',
        nombre:   'nombre',
        email:    'email',
        telefono: 'telefono',
      };
      Object.entries(map).forEach(function(entry) {
        var param = entry[0], fieldId = entry[1];
        var val = p.get(param);
        if (val) {
          var el = document.getElementById(fieldId);
          if (el) el.value = val;
        }
      });
    })();
  </script>

  <script is:inline define:vars={{ tastyigniterUrl: import.meta.env.PUBLIC_TASTYIGNITER_URL ?? 'https://restaurant.portadirta.com' }}>
    document.getElementById('restaurant-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      var form = e.target;
      var btn = form.querySelector('button[type="submit"]');
      var originalText = btn.textContent;
      btn.textContent = 'Enviando...';
      btn.disabled = true;

      try {
        var formData = new FormData(form);
        var data = {
          nombre:        formData.get('nombre'),
          email:         formData.get('email'),
          telefono:      formData.get('telefono'),
          personas:      parseInt(formData.get('personas'), 10),
          fecha:         formData.get('fecha'),
          hora:          formData.get('hora'),
          observaciones: formData.get('observaciones') || '',
        };
        var res = await fetch(tastyigniterUrl + '/api/public/reservations', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) {
          var errBody = await res.json().catch(function() { return {}; });
          throw new Error(errBody.message || 'Error en el servidor');
        }
        form.innerHTML = '<div class="text-center py-8"><p class="text-brand-gold font-display text-2xl italic">¡Reserva confirmada! Nos pondremos en contacto pronto.</p></div>';
      } catch (err) {
        btn.textContent = originalText;
        btn.disabled = false;
        var errDiv = form.querySelector('.form-error');
        if (!errDiv) {
          errDiv = document.createElement('p');
          errDiv.className = 'form-error text-red-400 text-sm text-center mt-2';
          form.appendChild(errDiv);
        }
        errDiv.textContent = 'Ha ocurrido un error. Por favor inténtalo de nuevo o llámanos directamente.';
      }
