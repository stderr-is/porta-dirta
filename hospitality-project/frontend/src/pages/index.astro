---
/**
 * index.astro — Full "Scroll Journey" homepage for Porta D'irta
 *
 * Sections:
 *   1. Hero          — Full-viewport video background, booking widget placeholder
 *   2. El Hotel      — Rooms overview, editorial split layout
 *   3. El Restaurante— Dark dramatic full-width section
 *   4. Experiencias  — Card grid, cream background
 *   5. Final CTA     — Dark full-width call to action
 */

import Layout from '../layouts/Layout.astro';
import GarlandDivider from '../components/GarlandDivider.astro';
import BookingSearchForm from '../components/BookingSearchForm.astro';
---

<Layout
  title="Villa & Restaurante en Peñíscola"
  description="Porta D'irta — Villa boutique y restaurante de cocina mediterránea frente al mar en Peñíscola, Costa del Azahar."
  lang="es"
>

  <!-- ============================================================
       SECTION 1: HERO
       Full-viewport video background with dark overlay.
       Centered brand name + CTAs. Booking bar pinned to bottom.
       ============================================================ -->
  <section
    class="relative flex flex-col items-center justify-center min-h-screen w-full overflow-hidden"
    aria-label="Hero — Porta D'irta"
  >

    <!-- Background video — drone aerial of the property -->
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
      poster="/assets/video/hero-poster.jpg"
      aria-hidden="true"
    >
      <source src="/assets/video/hero.mp4" type="video/mp4" />
    </video>

    <!-- Forest green overlay -->
    <div class="absolute inset-0 bg-brand-forest/55 pointer-events-none" aria-hidden="true"></div>

    <!-- Hero content — centered with booking form -->
    <div class="relative z-10 flex flex-col items-center gap-6 px-4 text-center w-full max-w-3xl mx-auto">

      <!-- Property name -->
      <h1 class="font-display font-light italic text-8xl md:text-9xl text-white leading-none tracking-tight">
        Porta D'irta
      </h1>

      <!-- Location subtitle -->
      <p class="font-body uppercase tracking-[0.4em] text-brand-sand text-sm">
        Peñíscola &middot; Costa del Azahar
      </p>

      <!-- Garland divider -->
      <GarlandDivider light />

      <!-- Booking form — replaces CTA buttons -->
      <div class="w-full mt-2">
        <BookingSearchForm formId="home" />
      </div>

    </div>

    <!-- Scroll hint chevron -->
    <div
      class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40 animate-bounce z-10"
      aria-hidden="true"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
        fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </div>

  </section>


  <!-- ============================================================
       SECTION 2: EL HOTEL
       Cream background, editorial split layout — text left, image
       grid right. Anchored via id="hotel".
       ============================================================ -->
  <section
    id="hotel"
    class="bg-brand-cream min-h-screen flex items-center py-24 md:py-32"
    aria-labelledby="hotel-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Left: editorial text -->
        <div class="flex flex-col gap-6">

          <!-- Small label -->
          <span class="font-body text-xs uppercase tracking-[0.35em] text-brand-gold">
            Alojamiento
          </span>

          <!-- Display heading -->
          <h2
            id="hotel-heading"
            class="font-display font-light text-5xl md:text-6xl text-brand-blue leading-tight"
          >
            Despierta frente al<br />Mediterráneo
          </h2>

          <!-- Garland rule -->
          <GarlandDivider />

          <!-- Body paragraph -->
          <p class="font-body text-brand-stone text-lg leading-relaxed max-w-md">
            Nuestras habitaciones y suites fusionan la arquitectura histórica
            de Peñíscola con el confort contemporáneo. Cada estancia ofrece
            vistas al Mediterráneo, materiales nobles y una atención
            personalizada que convierte cada visita en un recuerdo imborrable.
          </p>

          <!-- CTA -->
          <div class="mt-2">
            <a
              href="/hotel"
              class="inline-flex items-center gap-2 px-8 py-4 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium transition-colors duration-300 shadow-md"
            >
              Ver Habitaciones
              <!-- Inline arrow SVG -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>

        </div>

        <!-- Right: 2x2 image grid -->
        <div class="grid grid-cols-2 gap-3">

          <div class="overflow-hidden rounded-sm">
            <!-- REPLACE: real photo -->
            <img
              src="/assets/images/room-1.jpg"
              alt="Habitación con vistas al mar"
              class="w-full h-48 md:h-56 object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="overflow-hidden rounded-sm">
            <!-- REPLACE: real photo -->
            <img
              src="/assets/images/room-2.jpg"
              alt="Suite mediterránea"
              class="w-full h-48 md:h-56 object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="overflow-hidden rounded-sm">
            <!-- REPLACE: real photo -->
            <img
              src="/assets/images/room-3.jpg"
              alt="Terraza con vistas"
              class="w-full h-48 md:h-56 object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="overflow-hidden rounded-sm">
            <!-- REPLACE: real photo -->
            <img
              src="/assets/images/room-4.jpg"
              alt="Detalle de habitación boutique"
              class="w-full h-48 md:h-56 object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>

        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 3: EL RESTAURANTE
       Dark dramatic section, full-width background image with
       dark overlay, centered text, feature pills, CTA.
       ============================================================ -->
  <section
    class="relative min-h-screen flex items-center bg-brand-blue py-24 md:py-32 overflow-hidden"
    aria-labelledby="restaurante-heading"
  >

    <!-- Background image with dark overlay -->
    <div class="absolute inset-0" aria-hidden="true">
      <!-- REPLACE: real photo -->
      <img
        src="/assets/images/food-paella-table.jpg"
        alt=""
        class="w-full h-full object-cover opacity-30"
        loading="lazy"
        decoding="async"
      />
      <!-- Extra gradient for depth -->
      <div class="absolute inset-0 bg-gradient-to-t from-brand-forest/80 via-brand-forest/45 to-brand-forest/20"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 w-full text-center flex flex-col items-center gap-8">

      <!-- Small label -->
      <span class="font-body text-xs uppercase tracking-[0.35em] text-brand-gold">
        Gastronomía
      </span>

      <!-- Display heading -->
      <h2
        id="restaurante-heading"
        class="font-display font-light italic text-5xl md:text-7xl text-white leading-tight"
      >
        Sabores del Mediterráneo
      </h2>

      <!-- Garland rule -->
      <GarlandDivider light />

      <!-- Body paragraph -->
      <p class="font-body text-white/75 text-lg leading-relaxed max-w-xl">
        Nuestra cocina celebra el producto local y la tradición levantina.
        Del mar a la mesa: arroces, pescados de lonja y tapas que capturan
        la esencia de la Costa del Azahar en cada bocado.
      </p>

      <!-- Feature pills -->
      <div class="flex flex-wrap justify-center gap-3">

        <span class="font-body text-xs uppercase tracking-widest text-white border border-white/30 rounded-full px-5 py-2">
          Menú del Día
        </span>

        <span class="font-body text-xs uppercase tracking-widest text-white border border-white/30 rounded-full px-5 py-2">
          Carta de Temporada
        </span>

        <span class="font-body text-xs uppercase tracking-widest text-white border border-white/30 rounded-full px-5 py-2">
          Eventos Privados
        </span>

      </div>

      <!-- CTA -->
      <a
        href="/restaurante"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium transition-colors duration-300 shadow-lg mt-2"
      >
        Reservar Mesa
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>

    </div>

  </section>


  <!-- ============================================================
       SECTION 4: EXPERIENCIAS
       Cream background, 3-column card grid, stacks on mobile.
       ============================================================ -->
  <section
    class="bg-brand-cream py-24 md:py-32"
    aria-labelledby="experiencias-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header -->
      <div class="text-center flex flex-col items-center gap-4 mb-16">
        <span class="font-body text-xs uppercase tracking-[0.35em] text-brand-gold">
          Descubrir
        </span>
        <h2
          id="experiencias-heading"
          class="font-display font-light text-5xl md:text-6xl text-brand-blue leading-tight"
        >
          Más allá del alojamiento
        </h2>
        <GarlandDivider />
        <p class="font-body text-brand-stone text-lg leading-relaxed max-w-lg">
          Peñíscola y sus alrededores ofrecen experiencias únicas que
          complementan tu estancia en Porta D'irta.
        </p>
      </div>

      <!-- 3-column card grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Card 1: Sierra de Irta -->
        <article class="group bg-white rounded-sm shadow-md overflow-hidden border border-transparent hover:border-brand-gold transition-colors duration-300">
          <div class="overflow-hidden">
            <!-- REPLACE: real photo -->
            <img
              src="/assets/images/sierra-tower-wide.jpg"
              alt="Sierra de Irta — parque natural"
              class="w-full h-52 object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="p-6 flex flex-col gap-3">
            <h3 class="font-display font-light text-2xl text-brand-blue leading-snug">
              Sierra de Irta
            </h3>
            <p class="font-body text-brand-stone text-sm leading-relaxed">
              Senderismo y naturaleza en el parque natural que rodea la villa.
              Rutas costeras con vistas incomparables al Mediterráneo.
            </p>
          </div>
        </article>

        <!-- Card 2: Gastronomía Local -->
        <article class="group bg-white rounded-sm shadow-md overflow-hidden border border-transparent hover:border-brand-gold transition-colors duration-300">
          <div class="overflow-hidden">
            <!-- REPLACE: real photo -->
            <img
              src="/assets/images/food-paella-close.jpg"
              alt="Gastronomía local — mercado y tapas"
              class="w-full h-52 object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="p-6 flex flex-col gap-3">
            <h3 class="font-display font-light text-2xl text-brand-blue leading-snug">
              Gastronomía Local
            </h3>
            <p class="font-body text-brand-stone text-sm leading-relaxed">
              Mercados de temporada, bodegas y restaurantes de la Costa del
              Azahar. Una ruta de sabores que no olvidarás.
            </p>
          </div>
        </article>

        <!-- Card 3: Eventos & Celebraciones -->
        <article class="group bg-white rounded-sm shadow-md overflow-hidden border border-transparent hover:border-brand-gold transition-colors duration-300">
          <div class="overflow-hidden">
            <!-- REPLACE: real photo -->
            <img
              src="/assets/images/property-aerial-pool.jpg"
              alt="Eventos y celebraciones privadas"
              class="w-full h-52 object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="p-6 flex flex-col gap-3">
            <h3 class="font-display font-light text-2xl text-brand-blue leading-snug">
              Eventos &amp; Celebraciones
            </h3>
            <p class="font-body text-brand-stone text-sm leading-relaxed">
              Bodas, aniversarios y reuniones privadas en un entorno único.
              Nuestro equipo cuida cada detalle para que sea perfecto.
            </p>
          </div>
        </article>

      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 5: FINAL CTA
       Dark full-width section, two buttons side by side.
       ============================================================ -->
  <section
    class="bg-brand-blue py-24 md:py-32"
    aria-labelledby="cta-heading"
  >
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center gap-8">

      <!-- Display heading -->
      <h2
        id="cta-heading"
        class="font-display font-light italic text-5xl md:text-7xl text-white leading-tight"
      >
        ¿Listo para escapar?
      </h2>

      <!-- Garland rule -->
      <GarlandDivider light />

      <!-- Subtitle -->
      <p class="font-body text-white/70 text-lg leading-relaxed max-w-lg">
        Reserva tu estancia o mesa en Porta D'irta y déjate envolver por
        el Mediterráneo. Te esperamos en Peñíscola.
      </p>

      <!-- Two CTAs side by side -->
      <div class="flex flex-col sm:flex-row items-center gap-4 mt-2">

        <!-- Primary gold — hotel booking -->
        <a
          href="/hotel"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-sm bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium transition-colors duration-300 shadow-lg"
        >
          Reservar Habitación
        </a>

        <!-- Ghost white — restaurant booking -->
        <a
          href="/restaurante"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-sm border border-white/60 hover:border-white hover:bg-white/10 text-white font-body text-sm uppercase tracking-widest font-medium transition-colors duration-300"
        >
          Reservar Mesa
        </a>

      </div>

    </div>
  </section>

</Layout>
