---
/**
 * contacto.astro — Contact page for Porta D'irta
 *
 * Sections:
 *   1. Hero — half-viewport, bg-brand-blue
 *   2. Contact cards + form — bg-brand-cream, two-column desktop
 *   3. Location strip — bg-brand-blue, three items
 *
 * Form posts to REPLACE_WITH_N8N_CONTACT_WEBHOOK via fetch.
 * On success, the form is replaced with a thank-you message.
 * On error, an inline error message is shown below the submit button.
 */

import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contacto"
  description="Contacta con Porta D'irta para reservas de hotel, restaurante, eventos y celebraciones en Peñíscola, Costa del Azahar."
>

  <!-- ============================================================
       SECTION 1 — HERO
       Half-viewport, brand-blue, centered label + heading + subtitle
       ============================================================ -->
  <section class="min-h-[50vh] bg-brand-blue flex items-center justify-center py-24 md:py-32">
    <div class="text-center px-4">

      <!-- Label -->
      <p class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold mb-6">
        Contacto
      </p>

      <!-- Heading -->
      <h1 class="font-display italic text-6xl text-white leading-tight mb-6">
        Estamos aquí para ayudarte
      </h1>

      <!-- Subtitle -->
      <p class="font-body text-brand-sand text-lg tracking-wide">
        Reservas, consultas y atención personalizada
      </p>

    </div>
  </section>


  <!-- ============================================================
       SECTION 2 — CONTACT CARDS + FORM
       bg-brand-cream, two columns desktop / stacked mobile
       ============================================================ -->
  <section class="bg-brand-cream py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

        <!-- ── LEFT COLUMN: Contact info cards ──────────────────── -->
        <div class="flex flex-col gap-6">

          <!-- Card 1: Reservas Hotel -->
          <div class="bg-white rounded-xl shadow-sm p-6 flex gap-4 items-start">

            <!-- Phone icon -->
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-blue/10 flex items-center justify-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand-blue"
                aria-hidden="true"
              >
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.4 2 2 0 0 1 3.56 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.13 6.13l.81-.81a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.73 16.92z"/>
              </svg>
            </div>

            <div class="flex flex-col gap-1">
              <h3 class="font-body text-sm uppercase tracking-widest text-brand-gold font-medium">
                Reservas Hotel
              </h3>
              <a href="tel:+34964000000" class="font-display text-xl text-brand-blue hover:text-brand-gold transition-colors duration-200">
                +34 964 00 00 00
              </a>
              <a href="mailto:reservas@portadirta.com" class="font-body text-sm text-brand-stone hover:text-brand-blue transition-colors duration-200">
                reservas@portadirta.com
              </a>
              <p class="font-body text-xs text-brand-stone/70 mt-1">
                Lun–Vie 9:00–19:00
              </p>
            </div>

          </div>

          <!-- Card 2: Restaurante -->
          <div class="bg-white rounded-xl shadow-sm p-6 flex gap-4 items-start">

            <!-- Fork/knife icon -->
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-blue/10 flex items-center justify-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand-blue"
                aria-hidden="true"
              >
                <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/>
                <path d="M7 2v20"/>
                <path d="M21 15V2a5 5 0 0 0-5 5v6h3.5a1.5 1.5 0 0 1 1.5 1.5v.5"/>
                <path d="M18 22v-7"/>
              </svg>
            </div>

            <div class="flex flex-col gap-1">
              <h3 class="font-body text-sm uppercase tracking-widest text-brand-gold font-medium">
                Restaurante
              </h3>
              <a href="tel:+34964000001" class="font-display text-xl text-brand-blue hover:text-brand-gold transition-colors duration-200">
                +34 964 00 00 01
              </a>
              <a href="mailto:restaurante@portadirta.com" class="font-body text-sm text-brand-stone hover:text-brand-blue transition-colors duration-200">
                restaurante@portadirta.com
              </a>
              <p class="font-body text-xs text-brand-stone/70 mt-1">
                Martes–Domingo 12:00–23:00
              </p>
            </div>

          </div>

          <!-- Card 3: Eventos & Celebraciones -->
          <div class="bg-white rounded-xl shadow-sm p-6 flex gap-4 items-start">

            <!-- Star icon -->
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-brand-blue/10 flex items-center justify-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand-blue"
                aria-hidden="true"
              >
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </div>

            <div class="flex flex-col gap-1">
              <h3 class="font-body text-sm uppercase tracking-widest text-brand-gold font-medium">
                Eventos &amp; Celebraciones
              </h3>
              <a href="mailto:eventos@portadirta.com" class="font-body text-sm text-brand-stone hover:text-brand-blue transition-colors duration-200">
                eventos@portadirta.com
              </a>
              <p class="font-body text-xs text-brand-stone/70 mt-1">
                Respuesta en menos de 48h
              </p>
            </div>

          </div>

          <div class="rounded-xl overflow-hidden h-48 border border-brand-stone/10">
            <iframe
              src="https://maps.google.com/maps?q=40.335276,0.374050&hl=es&z=15&output=embed"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación de Porta D'irta en Peñíscola"
            ></iframe>
          </div>

        </div>

        <!-- ── RIGHT COLUMN: General contact form ───────────────── -->
        <div>
          <div class="bg-white rounded-xl shadow-sm p-8" id="form-container">

            <h2 class="font-display text-3xl text-brand-blue mb-8">
              Envíanos un mensaje
            </h2>

            <form
              id="contacto-form"
              method="POST"
              action="#"
              class="flex flex-col gap-5"
              aria-label="Formulario de contacto general"
            >

              <!-- Hidden source field -->
              <input type="hidden" name="source" value="contacto" />

              <!-- Nombre -->
              <div class="flex flex-col gap-2">
                <label for="nombre" class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">
                  Nombre *
                </label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  required
                  placeholder="Tu nombre completo"
                  class="border border-brand-stone/30 text-brand-blue placeholder-brand-stone/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-blue transition-colors duration-200 bg-white"
                />
              </div>

              <!-- Email -->
              <div class="flex flex-col gap-2">
                <label for="email" class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">
                  Email *
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="tu@email.com"
                  class="border border-brand-stone/30 text-brand-blue placeholder-brand-stone/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-blue transition-colors duration-200 bg-white"
                />
              </div>

              <!-- Teléfono -->
              <div class="flex flex-col gap-2">
                <label for="telefono" class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">
                  Teléfono
                </label>
                <input
                  type="tel"
                  id="telefono"
                  name="telefono"
                  placeholder="+34 600 000 000"
                  class="border border-brand-stone/30 text-brand-blue placeholder-brand-stone/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-blue transition-colors duration-200 bg-white"
                />
              </div>

              <!-- Asunto -->
              <div class="flex flex-col gap-2">
                <label for="asunto" class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">
                  Asunto *
                </label>
                <select
                  id="asunto"
                  name="asunto"
                  required
                  class="border border-brand-stone/30 text-brand-blue rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-blue transition-colors duration-200 bg-white appearance-none"
                >
                  <option value="" disabled selected>Selecciona un asunto</option>
                  <option value="reserva-hotel">Reserva Hotel</option>
                  <option value="reserva-restaurante">Reserva Restaurante</option>
                  <option value="evento-celebracion">Evento o Celebración</option>
                  <option value="informacion-general">Información general</option>
                  <option value="otro">Otro</option>
                </select>
              </div>

              <!-- Mensaje -->
              <div class="flex flex-col gap-2">
                <label for="mensaje" class="font-body text-xs uppercase tracking-widest text-brand-stone font-medium">
                  Mensaje *
                </label>
                <textarea
                  id="mensaje"
                  name="mensaje"
                  rows="5"
                  required
                  placeholder="¿En qué podemos ayudarte?"
                  class="border border-brand-stone/30 text-brand-blue placeholder-brand-stone/50 rounded-lg p-3 w-full font-body text-sm focus:outline-none focus:border-brand-blue transition-colors duration-200 bg-white resize-y"
                ></textarea>
              </div>

              <!-- Inline error message (hidden by default) -->
              <p
                id="form-error"
                class="hidden font-body text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg p-3"
                role="alert"
              >
                Ha ocurrido un error al enviar el mensaje. Por favor, inténtalo de nuevo o escríbenos directamente a info@portadirta.com
              </p>

              <!-- Submit -->
              <button
                type="submit"
                id="submit-btn"
                class="w-full bg-brand-blue text-white font-body text-sm uppercase tracking-widest font-medium rounded-lg px-8 py-4 hover:bg-brand-blue-light transition-colors duration-200 mt-2"
              >
                Enviar Mensaje
              </button>

            </form>

          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       SECTION 3 — LOCATION STRIP
       bg-brand-blue, three items centered in a row
       ============================================================ -->
  <section class="bg-brand-blue py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-12 sm:gap-16 lg:gap-24">

        <!-- Item 1: Location -->
        <div class="flex flex-col items-center gap-3 text-center">
          <!-- Location pin SVG -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-brand-gold"
            aria-hidden="true"
          >
            <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <p class="font-body text-white text-sm tracking-wide">
            Peñíscola, Costa del Azahar, España
          </p>
        </div>

        <!-- Item 2: Car distance -->
        <div class="flex flex-col items-center gap-3 text-center">
          <!-- Car SVG -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-brand-gold"
            aria-hidden="true"
          >
            <rect x="1" y="3" width="15" height="13" rx="1"/>
            <path d="M16 8h4l3 3v5h-7V8z"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          <p class="font-body text-white text-sm tracking-wide">
            45 min desde Valencia, 1h desde Tarragona
          </p>
        </div>

        <!-- Item 3: Airport -->
        <div class="flex flex-col items-center gap-3 text-center">
          <!-- Plane SVG -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-brand-gold"
            aria-hidden="true"
          >
            <path d="M17.8 19.2 16 11l3.5-3.5C21 6 21 4 21 4s-2 0-3.5 1.5L14 9 5.8 6.2l-1.9 1.9 6.5 3.7-2.5 2.5-2.4-.4L4 15l2 2 2 2 1.3-1.5-.4-2.4 2.5-2.5 3.7 6.5z"/>
          </svg>
          <p class="font-body text-white text-sm tracking-wide">
            Aeropuerto de Valencia (VLC) &middot; 90 km
          </p>
        </div>

      </div>
    </div>
  </section>

</Layout>


<!-- ============================================================
     FORM SUBMIT SCRIPT
     POSTs form data to the n8n contact webhook as JSON.
     On success: replaces the form with a thank-you message.
     On error: shows inline error paragraph below the submit button.
     ============================================================ -->
<script>
  (function () {
    const form = document.getElementById('contacto-form');
    const submitBtn = document.getElementById('submit-btn');
    const errorMsg = document.getElementById('form-error');
    const formContainer = document.getElementById('form-container');

    if (!form || !submitBtn || !errorMsg || !formContainer) return;

    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      // Disable button and show loading state
      submitBtn.setAttribute('disabled', 'true');
      submitBtn.textContent = 'Enviando…';
      errorMsg.classList.add('hidden');

      // Collect form data
      const data = Object.fromEntries(new FormData(form).entries());

      try {
        const response = await fetch('REPLACE_WITH_N8N_CONTACT_WEBHOOK', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          throw new Error('Server error: ' + response.status);
        }

        // Success — replace form with thank-you message
        formContainer.innerHTML = `
          <div class="flex flex-col items-center justify-center gap-6 py-16 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand-gold" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <h3 class="font-display italic text-3xl text-brand-blue">¡Mensaje enviado!</h3>
            <p class="font-body text-brand-stone text-base max-w-sm">
              Gracias por ponerte en contacto con nosotros. Te responderemos en menos de 48 horas.
            </p>
          </div>
        `;

      } catch (err) {
        // Error — show inline error, re-enable button
        console.error('Contact form error:', err);
        errorMsg.classList.remove('hidden');
        submitBtn.removeAttribute('disabled');
        submitBtn.textContent = 'Enviar Mensaje';
      }
    });
  })();
</script>
