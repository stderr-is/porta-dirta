---
/**
 * hotel.astro — Hotel & Rooms page for Porta D'irta
 *
 * Sections:
 *   1. Hero              — Full-viewport with availability search bar
 *   2. Property intro    — Two-column villa introduction
 *   3. Room listings     — Three room cards
 *   4. Amenities grid    — 12-icon grid
 *   5. Booking anchor    — Beds24 placeholder form
 *   6. Cross-sell bar    — Links to Restaurant, Events, Experiences
 */

import Layout from '../layouts/Layout.astro';
import GarlandDivider from '../components/GarlandDivider.astro';
---

<Layout
  title="Hotel & Habitaciones"
  description="Descubre nuestras habitaciones y suites mediterráneas en Porta D'irta, una villa boutique a orillas del mar en Peñíscola. Reserva tu estancia perfecta."
  ogImage="/assets/images/property-aerial-twilight.jpg"
>

  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 1 · HERO
       Full-viewport background with availability search bar
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden">

    <!-- REPLACE: real villa hero photo -->
    <img
      src="/assets/images/property-aerial-twilight.jpg"
      alt="Porta D'irta — villa junto al mar en Peñíscola"
      class="absolute inset-0 w-full h-full object-cover"
    />

    <!-- Brand-blue overlay -->
    <div class="absolute inset-0 bg-brand-forest/50"></div>

    <!-- Hero content -->
    <div class="relative z-10 flex flex-col items-center text-center px-6 py-24 md:py-32 max-w-5xl mx-auto">

      <!-- Label -->
      <p class="text-brand-gold font-body tracking-[0.25em] text-sm uppercase mb-6">
        EL HOTEL
      </p>

      <!-- Main heading -->
      <h1 class="font-display italic text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-white leading-tight mb-10">
        Tu refugio mediterráneo
      </h1>

      <!-- TODO: REMOVE BEFORE LAUNCH — beta disclaimer -->
      <div class="w-full max-w-2xl mx-auto mb-4 bg-amber-50/90 border border-amber-300 text-amber-900 font-body text-sm px-4 py-3 rounded-lg text-center">
        ⚠️ Sistema en fase de pruebas. Para reservas, contacta directamente por teléfono:
        <a href="tel:+34644026066" class="font-semibold underline">+34 644 026 066</a>
      </div>

      <!-- Beds24 Booking Widget (hero instance) -->
      <!-- contain:layout style prevents widget's injected CSS from leaking into the page -->
      <div class="w-full max-w-2xl mx-auto" style="contain: layout style; isolation: isolate;">
        <div id="bookWidget-162526-318433-0-1773941182"></div>
        <script is:inline>
          jQuery(document).ready(function() {
            jQuery('#bookWidget-162526-318433-0-1773941182').bookWidget({
              propid: 318433,
              availableBackgroundColor: '#c9a84c',
              backgroundColor: '#0d2b45',
              borderColor: '#c9a84c',
              buttonBackgroundColor: '#c9a84c',
              buttonColor: '#0d2b45',
              color: '#ffffff',
              dateFormat: 'dd/mm/yy',
              dateSelection: 3,
              defaultNightsAdvance: 1,
              defaultNumAdult: 2,
              defaultNumNight: 2,
              formAction: '/reservar',
              peopleSelection: 1,
              unavailableBackgroundColor: '#8b7355',
              weekFirstDay: 1,
              widgetLang: 'es',
              widgetType: 'BookingBox',
              width: '100%'
            });
          });
        </script>
        <p class="text-white/50 text-xs text-center mt-2 font-body">Reserva segura · Confirmación inmediata</p>
      </div>
      <!-- end Beds24 booking widget -->

    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-70">
      <span class="text-white font-body text-xs tracking-widest uppercase">Descubrir</span>
      <svg class="w-5 h-5 text-brand-gold animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>

  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 2 · PROPERTY INTRO
       Two-column villa introduction
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="bg-brand-cream py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left: text content -->
      <div class="flex flex-col gap-8">

        <!-- Label -->
        <p class="text-brand-gold font-body tracking-[0.25em] text-sm uppercase">
          BIENVENIDOS
        </p>

        <!-- Heading -->
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-brand-blue leading-tight">
          La villa
        </h2>

        <!-- Paragraphs -->
        <p class="font-body text-brand-stone leading-relaxed text-base">
          Porta D'irta es una villa boutique enclavada entre el Parque Natural de la Irta y las aguas cristalinas del Mediterráneo. Cada rincón ha sido diseñado para que el tiempo se detenga: materiales naturales, luz generosa y el sonido del mar como banda sonora permanente de tu estancia.
        </p>
        <p class="font-body text-brand-stone leading-relaxed text-base">
          Nuestras habitaciones y suites conjugan el lujo contemporáneo con la calidez de la arquitectura levantina. Despierta con vistas al horizonte azul, disfruta del desayuno en nuestra terraza y deja que la brisa mediterránea dicte el ritmo de tus días. Aquí, el bienestar no es un servicio, es una forma de vida.
        </p>

        <!-- Feature icons row -->
        <div class="flex flex-wrap gap-6 md:gap-8 mt-4">

          <!-- Pool icon -->
          <div class="flex flex-col items-center gap-2 text-center">
            <div class="w-12 h-12 flex items-center justify-center rounded-full bg-brand-blue/10">
              <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <!-- Simple pool: wavy lines -->
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 17c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/>
                <rect x="8" y="5" width="3" height="5" rx="0.5" stroke-width="1.5"/>
                <circle cx="9.5" cy="4" r="1" fill="currentColor" stroke="none"/>
              </svg>
            </div>
            <span class="font-body text-xs text-brand-stone tracking-wide">Piscina privada</span>
          </div>

          <!-- Beach icon -->
          <div class="flex flex-col items-center gap-2 text-center">
            <div class="w-12 h-12 flex items-center justify-center rounded-full bg-brand-blue/10">
              <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <!-- Umbrella + horizon -->
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c-4.5 3-6 7-5 10"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c4.5 3 6 7 5 10"/>
                <line x1="12" y1="3" x2="11" y2="18" stroke-linecap="round"/>
                <path stroke-linecap="round" d="M3 20h18"/>
              </svg>
            </div>
            <span class="font-body text-xs text-brand-stone tracking-wide">A 200m del mar</span>
          </div>

          <!-- WiFi icon -->
          <div class="flex flex-col items-center gap-2 text-center">
            <div class="w-12 h-12 flex items-center justify-center rounded-full bg-brand-blue/10">
              <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12.55a11 11 0 0114.08 0"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M1.42 9a16 16 0 0121.16 0"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.53 16.11a6 6 0 016.95 0"/>
                <circle cx="12" cy="20" r="1" fill="currentColor" stroke="none"/>
              </svg>
            </div>
            <span class="font-body text-xs text-brand-stone tracking-wide">WiFi gratuito</span>
          </div>

          <!-- Parking icon -->
          <div class="flex flex-col items-center gap-2 text-center">
            <div class="w-12 h-12 flex items-center justify-center rounded-full bg-brand-blue/10">
              <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17V7h4a3 3 0 010 6H9"/>
              </svg>
            </div>
            <span class="font-body text-xs text-brand-stone tracking-wide">Parking</span>
          </div>

        </div>
        <!-- end feature icons -->

      </div>

      <!-- Right: stacked images -->
      <div class="flex flex-col gap-4">
        <!-- REPLACE: real photo -->
        <img
          src="/assets/images/room-1.jpg"
          alt="Interior de la villa Porta D'irta"
          class="w-full rounded-xl object-cover shadow-lg"
        />
        <!-- REPLACE: real photo -->
        <img
          src="/assets/images/terrace-breakfast.jpg"
          alt="Terraza y jardín de Porta D'irta"
          class="w-full rounded-xl object-cover shadow-lg"
        />
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 3 · ROOM LISTINGS
       Three room cards on brand-blue background
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="bg-brand-blue py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">

      <!-- Section heading -->
      <div class="text-center mb-16">
        <p class="text-brand-gold font-body tracking-[0.25em] text-sm uppercase mb-4">ALOJAMIENTO</p>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-white leading-tight">Nuestras Habitaciones</h2>
      </div>

      <!-- Cards grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Card 1 · Habitación Mediterránea -->
        <article class="bg-white shadow-xl rounded-xl overflow-hidden flex flex-col">
          <div class="relative overflow-hidden">
            <!-- REPLACE: real room photos -->
            <img
              src="/assets/images/room-2.jpg"
              alt="Habitación Mediterránea en Porta D'irta"
              class="w-full h-60 object-cover hover:scale-105 transition-transform duration-500"
            />
            <!-- Price badge -->
            <div class="absolute top-4 right-4 bg-brand-blue/90 backdrop-blur-sm text-white font-body text-xs px-3 py-1.5 rounded-full">
              desde €120/noche
            </div>
          </div>
          <div class="flex flex-col flex-1 p-6 gap-4">
            <h3 class="font-display text-2xl text-brand-blue">Habitación Mediterránea</h3>
            <ul class="flex flex-col gap-2 font-body text-sm text-brand-stone flex-1">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Cama doble king-size
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Baño privado con ducha
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Aire acondicionado y calefacción
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                WiFi de alta velocidad
              </li>
            </ul>
            <a
              href="#reservar"
              class="mt-2 block text-center bg-brand-gold hover:bg-brand-stone text-white font-body font-medium tracking-widest uppercase text-sm px-6 py-3 rounded-lg transition-colors duration-200"
            >
              Reservar
            </a>
          </div>
        </article>

        <!-- Card 2 · Suite Junior -->
        <article class="bg-white shadow-xl rounded-xl overflow-hidden flex flex-col">
          <div class="relative overflow-hidden">
            <!-- REPLACE: real room photos -->
            <img
              src="/assets/images/room-3.jpg"
              alt="Suite Junior en Porta D'irta"
              class="w-full h-60 object-cover hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute top-4 right-4 bg-brand-blue/90 backdrop-blur-sm text-white font-body text-xs px-3 py-1.5 rounded-full">
              desde €180/noche
            </div>
          </div>
          <div class="flex flex-col flex-1 p-6 gap-4">
            <h3 class="font-display text-2xl text-brand-blue">Suite Junior</h3>
            <ul class="flex flex-col gap-2 font-body text-sm text-brand-stone flex-1">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Cama doble extra grande
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Sala de estar independiente
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Baño con bañera y ducha
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Terraza privada
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Minibar y cafetera Nespresso
              </li>
            </ul>
            <a
              href="#reservar"
              class="mt-2 block text-center bg-brand-gold hover:bg-brand-stone text-white font-body font-medium tracking-widest uppercase text-sm px-6 py-3 rounded-lg transition-colors duration-200"
            >
              Reservar
            </a>
          </div>
        </article>

        <!-- Card 3 · Suite Panorámica -->
        <article class="bg-white shadow-xl rounded-xl overflow-hidden flex flex-col">
          <div class="relative overflow-hidden">
            <!-- REPLACE: real room photos -->
            <img
              src="/assets/images/room-4.jpg"
              alt="Suite Panorámica con vistas al mar en Porta D'irta"
              class="w-full h-60 object-cover hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute top-4 right-4 bg-brand-blue/90 backdrop-blur-sm text-white font-body text-xs px-3 py-1.5 rounded-full">
              desde €250/noche
            </div>
          </div>
          <div class="flex flex-col flex-1 p-6 gap-4">
            <h3 class="font-display text-2xl text-brand-blue">Suite Panorámica</h3>
            <ul class="flex flex-col gap-2 font-body text-sm text-brand-stone flex-1">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Vistas panorámicas al mar Mediterráneo
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Suite de 80 m² con salón privado
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Gran terraza con tumbonas y jacuzzi
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Desayuno incluido en habitación
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Servicio de mayordomo 24h
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-gold shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Transfer privado aeropuerto incluido
              </li>
            </ul>
            <a
              href="#reservar"
              class="mt-2 block text-center bg-brand-gold hover:bg-brand-stone text-white font-body font-medium tracking-widest uppercase text-sm px-6 py-3 rounded-lg transition-colors duration-200"
            >
              Reservar
            </a>
          </div>
        </article>

      </div>
      <!-- end cards grid -->

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 4 · AMENITIES GRID
       12-icon grid of hotel amenities
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="bg-brand-cream py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-6 lg:px-12">

      <!-- Heading -->
      <div class="text-center mb-16">
        <p class="text-brand-gold font-body tracking-[0.25em] text-sm uppercase mb-4">INSTALACIONES</p>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-brand-blue leading-tight">Todo lo que necesitas</h2>
      </div>

      <!-- 6-col grid (3 on mobile) -->
      <div class="grid grid-cols-3 md:grid-cols-6 gap-8">

        <!-- Piscina -->
        <div class="flex flex-col items-center gap-3 text-center">
          <div class="w-14 h-14 flex items-center justify-center rounded-2xl bg-brand-blue/8 border border-brand-blue/10">
            <svg class="w-7 h-7 text-brand-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" d="M3 17c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/>
              <path stroke-linecap="round" d="M3 13c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/>
              <rect x="9" y="5" width="2.5" height="5" rx="0.5"/>
              <circle cx="10.25" cy="4" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </div>
          <span class="font-body text-xs text-brand-stone leading-tight">Piscina</span>
        </div>

        <!-- Playa Cercana -->
        <div class="flex flex-col items-center gap-3 text-center">
          <div class="w-14 h-14 flex items-center justify-center rounded-2xl bg-brand-blue/8 border border-brand-blue/10">
            <svg class="w-7 h-7 text-brand-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" d="M12 3c-4 2.5-5.5 6.5-4.5 9.5"/>
              <path stroke-linecap="round" d="M12 3c4 2.5 5.5 6.5 4.5 9.5"/>
              <line x1="12" y1="3" x2="11" y2="17" stroke-linecap="round"/>
              <path stroke-linecap="round" d="M4 21h16"/>
            </svg>
          </div>
          <span class="font-body text-xs text-brand-stone leading-tight">Playa Cercana</span>
        </div>

        <!-- Restaurante -->
        <div class="flex flex-col items-center gap-3 text-center">
          <div class="w-14 h-14 flex items-center justify-center rounded-2xl bg-brand-blue/8 border border-brand-blue/10">
            <svg class="w-7 h-7 text-brand-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 11l1-8h16l1 8"/>
