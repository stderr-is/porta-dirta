        <p class="font-body text-brand-stone text-lg leading-relaxed max-w-2xl">
          Plazas limitadas. Reserva con antelación para garantizar tu experiencia.
        </p>
      </div>

      {livePackages.length === 0 ? (
        <!-- Empty state -->
        <div class="flex flex-col items-center gap-6 py-20 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-brand-gold/60" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/>
          </svg>
          <p class="font-display italic text-2xl text-brand-blue/60">
            Próximamente nuevas experiencias
          </p>
          <p class="font-body text-brand-stone/70 text-base max-w-md">
            Estamos preparando nuevos paquetes para la próxima temporada. Contacta con nosotros para más información.
          </p>
          <a
            href="#contacto"
            class="inline-flex items-center gap-2 border border-brand-gold text-brand-gold font-body text-sm uppercase tracking-widest px-8 py-3 hover:bg-brand-gold hover:text-white transition-colors duration-300"
          >
            Contactar
          </a>
        </div>
      ) : (
        <!-- Packages grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {livePackages.map((pkg) => {
            const isPast = pkg.lifecycle_status !== 'UPCOMING';
            const dateObj = new Date(pkg.start_date);
            const dateStr = dateObj.toLocaleDateString('es-ES', {
              day: 'numeric', month: 'long', year: 'numeric', timeZone: 'Europe/Madrid'
            });
            return (
              <article
                class={`group relative flex flex-col bg-brand-linen rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 ${isPast ? 'opacity-60 grayscale' : ''}`}
                aria-label={pkg.title}
              >
                <!-- Cover image -->
                <div class="relative overflow-hidden h-56 flex-shrink-0 bg-brand-earth/20">
                  {pkg.cover_url ? (
                    <img
                      src={pkg.cover_url}
                      alt={pkg.title}
                      class={`w-full h-full object-cover transition-transform duration-500 ${isPast ? '' : 'group-hover:scale-105'}`}
                      loading="lazy"
                      decoding="async"
                    />
