---
/**
 * experiencias.astro — Local Experiences page for Porta D'irta
 *
 * Sections:
 *   1. Hero — full-viewport with overlay, badge pills, scroll chevron
 *   2. Intro ("Más allá de la villa") — two-column, image mosaic
 *   3. Sierra de Irta — dramatic full-width dark split, activity list
 *   4. Mar & Playa — 3-column activity card grid
 *   5. Cultura & Gastronomía — 2 large glassmorphism cards on dark
 *   6. Colaboraciones Locales — 4 partner logo placeholders
 *   7. Booking / Contact form — frosted glass, anchor: #contacto
 *   8. Cross-sell strip — Hotel, Restaurante, Eventos & Celebraciones
 *
 * Wave 2 notes:
 *   - Replace all picsum images with real photography.
 *   - Replace partner logo divs with real partner logos.
 */

import Layout from '../layouts/Layout.astro';

// ── Hi.Events: fetch live experiences at build time ──────────────────────────
const hieventsUrl = import.meta.env.PUBLIC_HIEVENTS_URL ?? 'http://localhost:8082';
const tastyigniterUrl = import.meta.env.PUBLIC_TASTYIGNITER_URL ?? 'http://localhost:8081';

let hiEvents: any[] = [];
try {
  const res = await fetch(`${hieventsUrl}/public/organizers/1/events`, {
    headers: { Accept: 'application/json' },
  });
  if (res.ok) {
    const json = await res.json();
    hiEvents = json.data ?? [];
  }
} catch (e: any) {
  console.warn('[experiencias] Hi.Events unavailable:', e.message);
}

/** Return price in whole euros and a pre-filled inquiry anchor for a given event slug. */
function getExp(slug: string) {
  const ev = hiEvents.find((e) => e.slug === slug);
  if (!ev) return { price: null, label: slug, anchor: '#contacto' };
  const rawPrice = ev.product_categories
    ?.flatMap((c: any) => c.products ?? [])
    ?.find((p: any) => p.price != null)?.price ?? null;
  const price = rawPrice != null ? Math.round(rawPrice / 100) : null;
  return {
    price,
    label: ev.title as string,
    anchor: `#contacto`,
  };
}

const sierra = getExp('ruta-guiada-sierra-de-irta');   // €35
const kayak  = getExp('kayak-y-snorkel-en-la-costa');  // €45
const vinos  = getExp('cata-de-vinos-y-gastronomia');  // €28
const castle = getExp('visita-guiada-al-castillo-papal'); // €15
---

<Layout
  title="Experiencias"
  description="Descubre la Costa del Azahar con excursiones, actividades náuticas, cultura y gastronomía diseñadas exclusivamente para los huéspedes de Porta D'irta en Peñíscola."
  lang="es"
  ogImage="https://picsum.photos/1200/630?random=50"
>

  <!-- ============================================================
       SECTION 1: HERO
       Full-viewport, photo background with brand-blue/65 overlay.
       Centred label, display heading, subtitle, badge pills, chevron.
       ============================================================ -->
  <section
    class="relative flex items-center justify-center min-h-screen w-full overflow-hidden"
    aria-label="Hero — Experiencias en Peñíscola"
  >

    <!-- Background photo -->
    <!-- REPLACE: real aerial/landscape hero photo -->
    <img
      src="https://picsum.photos/1920/1080?random=50"
      alt="Costa del Azahar vista desde Peñíscola"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      decoding="async"
    />

    <!-- Brand-blue overlay -->
    <div
      class="absolute inset-0 bg-brand-blue/65"
      aria-hidden="true"
    ></div>

    <!-- Hero content -->
    <div class="relative z-10 flex flex-col items-center gap-6 px-4 text-center max-w-4xl mx-auto">

      <!-- Section label -->
      <p class="font-body uppercase tracking-[0.3em] text-brand-gold text-sm font-medium">
        EXPERIENCIAS
      </p>

      <!-- Main heading -->
      <h1 class="font-display italic text-7xl text-white leading-tight">
        Descubre la Costa del Azahar
      </h1>

      <!-- Thin gold divider -->
      <div class="w-16 h-px bg-brand-gold opacity-60" aria-hidden="true"></div>

      <!-- Subtitle -->
      <p class="font-body text-white/80 text-lg leading-relaxed max-w-xl">
        Excursiones, gastronomía y aventuras diseñadas para nuestros huéspedes
      </p>

      <!-- Badge pills -->
      <div class="flex flex-wrap justify-center gap-3 mt-2">
        <span class="bg-white/20 backdrop-blur-sm border border-white/30 text-white font-body text-sm px-5 py-2 rounded-full">
          Naturaleza
        </span>
        <span class="bg-white/20 backdrop-blur-sm border border-white/30 text-white font-body text-sm px-5 py-2 rounded-full">
          Mar
        </span>
        <span class="bg-white/20 backdrop-blur-sm border border-white/30 text-white font-body text-sm px-5 py-2 rounded-full">
          Cultura
        </span>
        <span class="bg-white/20 backdrop-blur-sm border border-white/30 text-white font-body text-sm px-5 py-2 rounded-full">
          Gastronomía
        </span>
      </div>

      <!-- Scroll chevron -->
      <a
        href="#experiencias"
        class="mt-6 inline-flex items-center gap-2 font-body text-white/70 text-xs uppercase tracking-widest hover:text-white transition-colors duration-300"
        aria-label="Descubrir experiencias"
      >
        Descubrir experiencias
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </a>

    </div>

  </section>


  <!-- ============================================================
       SECTION 2: INTRO ("MÁS ALLÁ DE LA VILLA")
       Two-column: copy left, 2×2 image mosaic right.
       ============================================================ -->
  <section
    id="experiencias"
    class="bg-brand-cream py-24 md:py-32 px-4"
    aria-label="Más allá de la villa — experiencias para huéspedes"
  >
    <div class="max-w-7xl mx-auto">

      <!-- Two-column grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Left: text -->
        <div class="flex flex-col gap-6">

          <!-- Label -->
          <p class="font-body uppercase tracking-[0.3em] text-brand-gold text-xs font-medium">
            PARA NUESTROS HUÉSPEDES
          </p>

          <!-- Heading -->
          <h2 class="font-display font-light text-5xl text-brand-blue leading-tight">
            Todo lo que Peñíscola tiene que ofrecerte
          </h2>

          <!-- Thin gold rule -->
          <div class="w-12 h-px bg-brand-gold"></div>

          <!-- Paragraphs -->
          <p class="font-body text-brand-stone text-lg leading-relaxed">
            En Porta D'irta creemos que una estancia perfecta va mucho más allá de las comodidades
            de la villa. Por eso hemos seleccionado las mejores experiencias de la Costa del Azahar
            y las hemos organizado exclusivamente para nuestros huéspedes, desde rutas de montaña
            en la Sierra de Irta hasta aventuras acuáticas en el Mediterráneo cristalino.
          </p>
          <p class="font-body text-brand-stone text-lg leading-relaxed">
            Trabajamos con guías locales certificados y colaboradores de confianza para garantizarte
            autenticidad, seguridad y momentos únicos. Solo tienes que decirnos qué te apetece y
            nuestro equipo lo organiza todo: recogida, reservas y hasta la cesta de picnic para el
            camino.
          </p>

        </div>

        <!-- Right: 2×2 image mosaic -->
        <div class="grid grid-cols-2 gap-4">

          <!-- REPLACE: real photo -->
          <div class="overflow-hidden rounded-xl">
            <img
              src="https://picsum.photos/400/300?random=51"
              alt="Senderismo en la Sierra de Irta"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
          </div>

          <!-- REPLACE: real photo -->
          <div class="overflow-hidden rounded-xl">
            <img
              src="https://picsum.photos/400/300?random=52"
              alt="Kayak en el Mediterráneo"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
          </div>

          <!-- REPLACE: real photo -->
          <div class="overflow-hidden rounded-xl">
            <img
              src="https://picsum.photos/400/300?random=53"
              alt="Castillo de Peñíscola"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
          </div>

          <!-- REPLACE: real photo -->
          <div class="overflow-hidden rounded-xl">
            <img
              src="https://picsum.photos/400/300?random=54"
              alt="Gastronomía local — arroz a banda"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
          </div>

        </div>

      </div>

    </div>
  </section>


  <!-- ============================================================
       SECTION 3: SIERRA DE IRTA
       Dramatic full-width dark split: image left, content right.
       ============================================================ -->
  <section
    class="bg-brand-blue min-h-screen flex flex-col lg:flex-row overflow-hidden"
    aria-label="Sierra de Irta — parque natural"
  >

    <!-- Left: large image taking full height -->
    <!-- REPLACE: real Sierra de Irta photo -->
    <div class="relative w-full lg:w-1/2 min-h-[50vh] lg:min-h-screen flex-shrink-0">
      <img
        src="https://picsum.photos/800/900?random=55"
        alt="Sierra de Irta, parque natural de Peñíscola"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
    </div>

    <!-- Right: content -->
    <div class="w-full lg:w-1/2 flex items-center py-24 md:py-32 px-8 md:px-16">
      <div class="flex flex-col gap-8 max-w-lg">

        <!-- Label -->
        <p class="font-body uppercase tracking-[0.3em] text-brand-gold text-xs font-medium">
          NATURALEZA
        </p>

        <!-- Heading -->
        <h2 class="font-display italic text-6xl text-white leading-tight">
          Sierra de Irta
        </h2>

        <!-- Thin gold rule -->
        <div class="w-12 h-px bg-brand-gold"></div>

        <!-- Paragraphs -->
        <p class="font-body text-white/80 text-base leading-relaxed">
          El Parque Natural de la Sierra de Irta es uno de los últimos tramos de litoral virgen
          del Mediterráneo español. Con más de 5.000 hectáreas de monte bajo, acantilados y calas
          secretas, es el escenario ideal para conectar con la naturaleza a pocos minutos de la
          villa.
        </p>
        <p class="font-body text-white/80 text-base leading-relaxed">
          Nuestros guías locales te llevan por los senderos más espectaculares, adaptando el
          recorrido a tu nivel físico y tus intereses. Una experiencia que combina paisaje,
          historia y biodiversidad en estado puro.
        </p>

        <!-- Activity list -->
        <ul class="flex flex-col gap-4" aria-label="Actividades en la Sierra de Irta">

          <li class="flex items-center gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-shrink-0">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="font-body text-white text-base">Senderismo guiado</span>
          </li>

          <li class="flex items-center gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-shrink-0">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="font-body text-white text-base">Rutas en bicicleta</span>
          </li>

          <li class="flex items-center gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-shrink-0">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="font-body text-white text-base">Observación de aves</span>
          </li>

          <li class="flex items-center gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-shrink-0">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="font-body text-white text-base">Fotografía de naturaleza</span>
          </li>

        </ul>

        <!-- CTA — pre-selects "sierra-irta" in the contact form -->
        <div class="pt-2 flex items-center gap-4 flex-wrap">
          <a
            href="#contacto"
            data-exp="sierra-irta"
            class="exp-cta inline-flex items-center justify-center px-8 py-4 bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium rounded-lg transition-colors duration-300 shadow-lg"
          >
            Reservar Excursión
          </a>
          {sierra.price && (
            <span class="font-body text-white/60 text-sm">desde €{sierra.price}/persona</span>
          )}
        </div>

      </div>
    </div>

  </section>


  <!-- ============================================================
       SECTION 4: MAR & PLAYA
       Cream background. 3-column activity card grid.
       ============================================================ -->
  <section
    class="bg-brand-cream py-24 md:py-32 px-4"
    aria-label="Actividades acuáticas — Mar y Playa"
  >
    <div class="max-w-7xl mx-auto">

      <!-- Section heading -->
      <div class="text-center mb-16">
        <p class="font-body uppercase tracking-[0.3em] text-brand-gold text-xs font-medium mb-4">
          MAR &amp; PLAYA
        </p>
        <h2 class="font-display font-light text-5xl text-brand-blue">
          El Mediterráneo a tu puerta
        </h2>
      </div>

      <!-- Cards grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Card 1: Kayak & Snorkel (live event from Hi.Events) -->
        <!-- REPLACE: real activity photo -->
        <article class="bg-white rounded-xl overflow-hidden shadow-md flex flex-col">

          <div class="relative overflow-hidden">
            <img
              src="https://picsum.photos/400/300?random=56"
              alt="Kayak y snorkel en Peñíscola"
              class="w-full h-56 object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute top-4 right-4">
              <span class="bg-brand-gold text-white font-body text-xs font-medium uppercase tracking-wide px-3 py-1 rounded-full shadow">
                {kayak.price ? `desde €${kayak.price}/persona` : 'Consultar precio'}
              </span>
            </div>
          </div>

          <div class="flex flex-col gap-3 p-6 flex-1">
            <h3 class="font-display text-2xl text-brand-blue font-light leading-snug">
              Kayak &amp; Snorkel
            </h3>
            <p class="font-body text-brand-stone text-sm leading-relaxed">
              Explora las calas y fondos marinos de la Sierra de Irta en kayak. Sesión de 2.5 horas
              con guía certificado, equipo incluido (kayak doble, chaleco, palas, gafas y tubo).
              Apto para todos los niveles.
            </p>
            <div class="mt-auto pt-4">
              <a
                href="#contacto"
                data-exp="actividades-acuaticas"
                class="exp-cta inline-flex items-center gap-1 font-body text-xs uppercase tracking-widest text-brand-gold hover:text-brand-stone font-medium transition-colors duration-300"
                aria-label="Consultar disponibilidad de Kayak y Snorkel"
              >
                Consultar disponibilidad
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </div>
          </div>

        </article>

        <!-- Card 2: Snorkel en las Cuevas -->
        <article class="bg-white rounded-xl overflow-hidden shadow-md flex flex-col">

          <div class="relative overflow-hidden">
            <img
              src="https://picsum.photos/400/300?random=57"
              alt="Snorkel en las cuevas marinas de Peñíscola"
              class="w-full h-56 object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute top-4 right-4">
              <span class="bg-brand-gold text-white font-body text-xs font-medium uppercase tracking-wide px-3 py-1 rounded-full shadow">
                desde €35/persona
              </span>
            </div>
          </div>

          <div class="flex flex-col gap-3 p-6 flex-1">
            <h3 class="font-display text-2xl text-brand-blue font-light leading-snug">
              Snorkel en las Cuevas
            </h3>
            <p class="font-body text-brand-stone text-sm leading-relaxed">
              Sumérgete en las cuevas y grutas submarinas de la costa de Peñíscola. Nuestros
              monitores de buceo certificados te acompañan para descubrir un mundo submarino
