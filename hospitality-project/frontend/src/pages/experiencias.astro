              loading="lazy"
              decoding="async"
            />
            <div class="absolute top-4 right-4">
              <span class="bg-brand-gold text-white font-body text-xs font-medium uppercase tracking-wide px-3 py-1 rounded-full shadow">
                desde €45/persona
              </span>
            </div>
          </div>

          <div class="flex flex-col gap-3 p-6 flex-1">
            <h3 class="font-display text-2xl text-brand-blue font-light leading-snug">
              Pesca Tradicional
            </h3>
            <p class="font-body text-brand-stone text-sm leading-relaxed">
              Embárcate con pescadores locales al amanecer y aprende las técnicas de pesca
              artesanal del Mediterráneo. Una experiencia auténtica que termina con los
              mejores ejemplares cocinados a bordo o en nuestra cocina.
            </p>
            <div class="mt-auto pt-4">
              <a
                href="#contacto"
                data-exp="actividades-acuaticas"
                class="exp-cta inline-flex items-center gap-1 font-body text-xs uppercase tracking-widest text-brand-gold hover:text-brand-stone font-medium transition-colors duration-300"
                aria-label="Consultar disponibilidad de Pesca Tradicional"
              >
                Consultar disponibilidad
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </div>
          </div>

        </article>

      </div>

    </div>
  </section>


  <!-- ============================================================
       SECTION 5: CULTURA & GASTRONOMÍA
       Dark bg. Two large glassmorphism cards side by side.
       ============================================================ -->
  <section
    class="bg-brand-blue py-24 md:py-32 px-4"
    aria-label="Cultura y Gastronomía en Peñíscola"
  >
    <div class="max-w-7xl mx-auto">

      <!-- Section heading -->
      <div class="text-center mb-16">
        <p class="font-body uppercase tracking-[0.3em] text-brand-gold text-xs font-medium mb-4">
          CULTURA &amp; GASTRONOMÍA
        </p>
        <h2 class="font-display font-light italic text-5xl text-white">
          Peñíscola, historia y sabor
        </h2>
      </div>

      <!-- Two large cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Left card: Castillo Papal (live event from Hi.Events) -->
        <!-- REPLACE: real culture photo -->
        <article class="backdrop-blur-sm bg-white/10 border border-white/20 rounded-xl overflow-hidden flex flex-col">

          <div class="relative overflow-hidden">
            <img
              src="https://picsum.photos/700/500?random=59"
              alt="Castillo templario y casco antiguo de Peñíscola"
              class="w-full h-72 object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-blue/70 to-transparent"></div>
            {castle.price && (
              <div class="absolute top-4 right-4">
                <span class="bg-brand-gold text-white font-body text-xs font-medium uppercase tracking-wide px-3 py-1 rounded-full shadow">
                  desde €{castle.price}/persona
                </span>
              </div>
            )}
          </div>

          <div class="flex flex-col gap-4 p-8 flex-1">
            <h3 class="font-display text-3xl text-white font-light">Peñíscola Histórica</h3>
            <p class="font-body text-white/80 text-base leading-relaxed">
              Descubre los secretos del castillo templario donde el Papa Luna escribió sus
              bulas, y pasea por las callejuelas empedradas de la ciudad amurallada. Nuestros
              guías locales dan vida a siglos de historia medieval, árabe y cristiana en un
              recorrido personalizado a tu ritmo.
            </p>
            <div class="mt-auto pt-4">
              <a
                href="#contacto"
                data-exp="cultura-historia"
                class="exp-cta inline-flex items-center justify-center px-6 py-3 bg-brand-gold hover:bg-brand-stone text-brand-blue font-body text-sm uppercase tracking-widest font-medium rounded-lg transition-colors duration-300"
              >
                Explorar
              </a>
            </div>
          </div>

        </article>

        <!-- Right card: Cata de Vinos (live event from Hi.Events) -->
        <!-- REPLACE: real food/wine photo -->
        <article class="backdrop-blur-sm bg-white/10 border border-white/20 rounded-xl overflow-hidden flex flex-col">

          <div class="relative overflow-hidden">
            <img
              src="https://picsum.photos/700/500?random=60"
              alt="Ruta gastronómica — vinos y mariscos de la Costa del Azahar"
              class="w-full h-72 object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-blue/70 to-transparent"></div>
            {vinos.price && (
              <div class="absolute top-4 right-4">
                <span class="bg-brand-gold text-white font-body text-xs font-medium uppercase tracking-wide px-3 py-1 rounded-full shadow">
                  desde €{vinos.price}/persona
                </span>
              </div>
            )}
          </div>

