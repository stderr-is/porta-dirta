---
/**
 * experiencias.astro — Local Experiences page for Porta D'irta
 *
 * Sections:
 *   1. Hero — full-viewport with overlay, badge pills, scroll chevron
 *   2. Intro ("Más allá de la villa") — two-column, image mosaic
 *   3. Sierra de Irta — dramatic full-width dark split, activity list
 *   4. Mar & Playa — 3-column activity card grid
 *   5. Cultura & Gastronomía — 2 large glassmorphism cards on dark
 *   6. Colaboraciones Locales — 4 partner logo placeholders
 *   7. Booking / Contact form — frosted glass, anchor: #contacto
 *   8. Cross-sell strip — Hotel, Restaurante, Eventos & Celebraciones
 *
 * Wave 2 notes:
 *   - Replace all picsum images with real photography.
 *   - Replace partner logo divs with real partner logos.
 */

import Layout from '../layouts/Layout.astro';
import GarlandDivider from '../components/GarlandDivider.astro';
import { getCollection } from 'astro:content';

// ── Content collections ───────────────────────────────────────────────────────
const colaboradores = (await getCollection('colaboradores'))
  .sort((a, b) => a.data.orden - b.data.orden);

// ── Hi.Events: fetch live experiences at build time ──────────────────────────
const hieventsUrl = import.meta.env.PUBLIC_HIEVENTS_URL ?? 'http://localhost:8082';
const tastyigniterUrl = import.meta.env.PUBLIC_TASTYIGNITER_URL ?? 'http://localhost:8081';

let hiEvents: any[] = [];
try {
  const res = await fetch(`${hieventsUrl}/api/public/organizers/1/events`, {
    headers: { Accept: 'application/json' },
  });
  if (res.ok) {
    const json = await res.json();
    hiEvents = json.data ?? [];
  }
} catch (e: any) {
  console.warn('[experiencias] Hi.Events unavailable:', e.message);
}

/** Return price in whole euros and a pre-filled inquiry anchor for a given event slug. */
function getExp(slug: string) {
  const ev = hiEvents.find((e) => e.slug === slug);
  if (!ev) return { price: null, label: slug, anchor: '#contacto' };
  const rawPrice = ev.product_categories
    ?.flatMap((c: any) => c.products ?? [])
    ?.find((p: any) => p.price != null)?.price ?? null;
  const price = rawPrice != null ? Math.round(rawPrice / 100) : null;
  return {
    price,
    label: ev.title as string,
    anchor: `#contacto`,
  };
}

const sierra = getExp('ruta-guiada-sierra-de-irta');   // €35
const kayak  = getExp('kayak-y-snorkel-en-la-costa');  // €45
const vinos  = getExp('cata-de-vinos-y-gastronomia');  // €28
const castle = getExp('visita-guiada-al-castillo-papal'); // €15

// ── Nuestros Paquetes: structured data for the dynamic grid ───────────────────
interface HiPackage {
  id: number;
  title: string;
  slug: string;
  description_preview: string;
  start_date: string;
  lifecycle_status: 'UPCOMING' | 'PAST' | 'ENDED';
  cover_url: string | null;
  price: number | null; // whole euros
  booking_url: string;
}

const hiEventsBaseUrl = import.meta.env.PUBLIC_HIEVENTS_URL ?? 'https://events.hobbitonranch.com';

const livePackages: HiPackage[] = hiEvents
  .filter((e: any) => e.status === 'LIVE')
  .sort((a: any, b: any) => {
    // UPCOMING first, PAST/ENDED last
    if (a.lifecycle_status === 'UPCOMING' && b.lifecycle_status !== 'UPCOMING') return -1;
    if (a.lifecycle_status !== 'UPCOMING' && b.lifecycle_status === 'UPCOMING') return 1;
    return new Date(a.start_date).getTime() - new Date(b.start_date).getTime();
  })
  .map((e: any) => {
    const rawPrice = e.product_categories
      ?.flatMap((c: any) => c.products ?? [])
      ?.find((p: any) => p.price != null)?.price ?? null;
    return {
      id: e.id,
      title: e.title,
      slug: e.slug,
      description_preview: e.description_preview ?? '',
      start_date: e.start_date,
      lifecycle_status: e.lifecycle_status ?? 'UPCOMING',
      cover_url: e.images?.[0]?.url ?? null,
      price: rawPrice != null ? Math.round(rawPrice / 100) : null,
      booking_url: `${hiEventsBaseUrl}/e/${e.slug}`,
    };
  });
---

<Layout
  title="Experiencias"
  description="Descubre la Costa del Azahar con excursiones, actividades náuticas, cultura y gastronomía diseñadas exclusivamente para los huéspedes de Porta D'irta en Peñíscola."
  lang="es"
  ogImage="/assets/images/sierra-tower-wide.jpg"
>

  <!-- JSON-LD: Event structured data for upcoming packages (Google rich results) -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify([
    ...livePackages
      .filter(pkg => pkg.lifecycle_status === 'UPCOMING')
      .map(pkg => ({
        "@context": "https://schema.org",
        "@type": "Event",
        "name": pkg.title,
        "description": pkg.description_preview,
        "startDate": pkg.start_date,
        "eventStatus": "https://schema.org/EventScheduled",
        "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
        "location": {
          "@type": "Place",
          "name": "Porta D'irta",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Camí del Pebret, s/n",
            "addressLocality": "Peñíscola",
            "postalCode": "12598",
            "addressCountry": "ES"
          }
        },
        "organizer": {
          "@type": "Organization",
          "name": "Porta D'irta",
          "url": "https://portadirta.com"
        },
        "offers": pkg.price != null ? {
          "@type": "Offer",
          "price": pkg.price,
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock",
          "url": pkg.booking_url
        } : undefined,
        "image": pkg.cover_url ?? undefined,
        "url": pkg.booking_url,
      })),
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": "https://www.portadirta.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Experiencias",
          "item": "https://www.portadirta.com/experiencias"
        }
      ]
    }
  ])} />

  <!-- ============================================================
       SECTION 1: HERO
       Full-viewport, photo background with brand-blue/65 overlay.
       Centred label, display heading, subtitle, badge pills, chevron.
       ============================================================ -->
  <section
    class="relative flex items-center justify-center min-h-screen w-full overflow-hidden"
    aria-label="Hero — Experiencias en Peñíscola"
  >

    <!-- Background photo -->
    <!-- REPLACE: real aerial/landscape hero photo -->
    <img
      src="/assets/images/sierra-tower-sea.jpg"
      alt="Costa del Azahar vista desde Peñíscola"
      class="absolute inset-0 w-full h-full object-cover"
