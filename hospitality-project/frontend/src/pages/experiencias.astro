                    <div class="w-full h-full flex items-center justify-center bg-brand-earth/10">
                      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-brand-earth/40" aria-hidden="true">
                        <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                      </svg>
                    </div>
                  )}
                  <!-- PAST badge overlay -->
                  {isPast && (
                    <div class="absolute inset-0 flex items-center justify-center bg-brand-blue/40">
                      <span class="bg-brand-blue text-white font-body text-xs uppercase tracking-widest px-4 py-2 rounded-full">
                        Finalizado
                      </span>
                    </div>
                  )}
                  <!-- Price badge (upcoming only) -->
