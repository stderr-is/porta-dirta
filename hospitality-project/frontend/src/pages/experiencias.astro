                </div>

                <!-- Card body -->
                <div class="flex flex-col flex-1 gap-4 p-6">

                  <!-- Date -->
                  <p class="font-body text-brand-gold text-xs uppercase tracking-widest">
                    {dateStr}
                  </p>

                  <!-- Title -->
                  <h3 class="font-display font-light text-xl text-brand-blue leading-snug">
                    {pkg.title}
                  </h3>

                  <!-- Description preview -->
                  <p class="font-body text-brand-stone text-sm leading-relaxed line-clamp-3 flex-1">
                    {pkg.description_preview}
                  </p>

                  <!-- CTA -->
                  {!isPast && (
                    <a
                      href={pkg.booking_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="mt-auto inline-flex items-center justify-center gap-2 bg-brand-gold text-white font-body text-sm uppercase tracking-widest px-6 py-3 hover:bg-brand-stone transition-colors duration-300"
                      aria-label={`Reservar ${pkg.title}`}
                    >
                      Reservar
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                      </svg>
                    </a>
                  )}
                </div>

              </article>
            );
          })}
        </div>
      )}

    </div>
  </section>

  <GarlandDivider />

  <!-- ============================================================
       SECTION 3: SIERRA DE IRTA
       Dramatic full-width dark split: image left, content right.
       ============================================================ -->
  <section
    class="bg-brand-blue min-h-screen flex flex-col lg:flex-row overflow-hidden"
    aria-label="Sierra de Irta — parque natural"
  >

    <!-- Left: large image taking full height -->
    <!-- REPLACE: real Sierra de Irta photo -->
    <div class="relative w-full lg:w-1/2 min-h-[50vh] lg:min-h-screen flex-shrink-0">
      <img
        src="/assets/images/sierra-trail-vertical.jpg"
        alt="Sierra de Irta, parque natural de Peñíscola"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
    </div>

    <!-- Right: content -->
