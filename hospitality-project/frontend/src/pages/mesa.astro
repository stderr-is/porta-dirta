---
/**
 * mesa.astro — QR code table landing page
 *
 * This is the single URL printed on every table QR code.
 * Three large tap-friendly cards: La Carta, Menú Especial, Bebidas.
 * No hero, no scroll needed — everything above the fold on any phone.
 * noindex: not meant to rank, just for in-restaurant use.
 */

import fs from 'node:fs';
import Layout from '../layouts/Layout.astro';
import menuFallback from '../data/menu.json';

let menu: typeof menuFallback = menuFallback;
const menuDataPath = import.meta.env.MENU_DATA_PATH;
if (menuDataPath) {
  try { menu = JSON.parse(fs.readFileSync(`${menuDataPath}/menu.json`, 'utf-8')); } catch {}
}
---

<Layout
  title="Menús — Mesa"
  description="Consulta la carta, el menú especial y las bebidas del restaurante Porta D'irta."
  noindex={true}
>

  <div class="min-h-screen bg-brand-blue flex flex-col">

    <!-- ── Brand header ─────────────────────────────────────────── -->
    <header class="pt-32 pb-6 text-center px-4">
      <img
        src="/assets/logos/logo-negativo.png"
        alt="Porta D'irta"
        class="h-10 w-auto mx-auto mb-4"
        loading="eager"
      />
      <p class="font-body text-xs uppercase tracking-[0.3em] text-brand-gold">Restaurante</p>
    </header>

    <!-- ── Menu cards ───────────────────────────────────────────── -->
    <main class="flex-1 flex flex-col justify-center px-4 sm:px-6 pb-8 max-w-lg mx-auto w-full gap-3">

      <!-- La Carta -->
      <a
        href="/carta"
        class="group flex items-center justify-between gap-4 bg-white/10 hover:bg-white/15 active:bg-white/20 border border-white/20 hover:border-brand-gold/50 rounded-2xl px-6 py-5 transition-all duration-200"
      >
        <div class="flex items-center gap-4">
          <!-- Fork & knife icon -->
          <div class="shrink-0 w-10 h-10 rounded-full bg-brand-gold/15 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-xl text-white group-hover:text-brand-gold transition-colors duration-200 leading-tight">La Carta</p>
            <p class="font-body text-xs text-white/50 mt-0.5">Tapas · Arroces · Platos · Postres</p>
          </div>
        </div>
        <svg class="w-5 h-5 text-brand-gold/50 group-hover:text-brand-gold group-hover:translate-x-0.5 transition-all duration-200 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- Menú Especial -->
      <a
        href="/menu"
        class="group flex items-center justify-between gap-4 bg-white/10 hover:bg-white/15 active:bg-white/20 border border-white/20 hover:border-brand-gold/50 rounded-2xl px-6 py-5 transition-all duration-200"
      >
        <div class="flex items-center gap-4">
          <!-- Star icon -->
          <div class="shrink-0 w-10 h-10 rounded-full bg-brand-gold/15 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-xl text-white group-hover:text-brand-gold transition-colors duration-200 leading-tight">Menú Especial</p>
            <p class="font-body text-xs text-white/50 mt-0.5">{menu.available} · {menu.price.toFixed(0)}€/persona</p>
          </div>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <span class="font-display text-lg text-brand-gold leading-none">{menu.price.toFixed(0)}€</span>
          <svg class="w-5 h-5 text-brand-gold/50 group-hover:text-brand-gold group-hover:translate-x-0.5 transition-all duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      </a>

      <!-- Bebidas -->
      <a
        href="/bebidas"
        class="group flex items-center justify-between gap-4 bg-white/10 hover:bg-white/15 active:bg-white/20 border border-white/20 hover:border-brand-gold/50 rounded-2xl px-6 py-5 transition-all duration-200"
      >
        <div class="flex items-center gap-4">
          <!-- Wine glass icon -->
          <div class="shrink-0 w-10 h-10 rounded-full bg-brand-gold/15 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3h4.5M8.25 3l.94 7.515A6 6 0 0 0 12 21a6 6 0 0 0 2.81-10.485L15.75 3M12 21v-3.75M9 17.25h6"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-xl text-white group-hover:text-brand-gold transition-colors duration-200 leading-tight">Bebidas</p>
            <p class="font-body text-xs text-white/50 mt-0.5">Vinos · Cervezas · Refrescos · Cafés</p>
          </div>
        </div>
        <svg class="w-5 h-5 text-brand-gold/50 group-hover:text-brand-gold group-hover:translate-x-0.5 transition-all duration-200 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- Divider -->
      <div class="border-t border-white/10 my-1"></div>

      <!-- Reservar -->
      <a
        href="/reservar"
        class="flex items-center justify-center gap-2 px-6 py-4 rounded-2xl bg-brand-gold hover:bg-brand-stone active:scale-[0.98] text-brand-blue font-body text-sm uppercase tracking-widest font-semibold transition-all duration-200"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/>
        </svg>
        Reservar mesa
      </a>

    </main>

    <!-- ── Footer note ───────────────────────────────────────────── -->
    <footer class="pb-8 text-center">
      <p class="font-body text-[11px] text-white/25 uppercase tracking-widest">
        portadirta.com
      </p>
    </footer>

  </div>

</Layout>
