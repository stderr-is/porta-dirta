---
/**
 * Layout.astro — Base shell for all Porta D'irta pages
 *
 * Props:
 *   title       — Page <title> and og:title (required)
 *   description — Meta description and og:description (required)
 *   lang        — HTML lang attribute; defaults to 'es' (Spanish)
 *   ogImage     — Open Graph image URL; defaults to a brand placeholder
 *
 * Structure:
 *   <head> — Google Fonts, SEO meta tags, global CSS
 *   <body> — <Nav /> · <slot /> · <Footer />
 *
 * Wave 2 notes:
 *   - Replace ogImage default with a real hosted image.
 *   - Add canonical URL once domain is confirmed.
 *   - Consider adding structured data (JSON-LD) for the hotel/restaurant.
 */

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: string;
  ogImage?: string;
}

const {
  title,
  description,
  lang = 'es',
  ogImage = 'https://picsum.photos/1200/630',
} = Astro.props;

// Construct full page title with brand suffix
const fullTitle = `${title} | Porta D'irta`;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Favicon — Wave 2: replace with real favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Astro generator tag -->
    <meta name="generator" content={Astro.generator} />

    <!-- ── SEO ────────────────────────────────────────────────── -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : lang === 'en' ? 'en_GB' : lang === 'fr' ? 'fr_FR' : 'de_DE'} />
    <meta property="og:site_name" content="Porta D'irta" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- ── Google Fonts ───────────────────────────────────────── -->
    <!-- Preconnect for faster font loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!--
      Cormorant Garamond — display / headings (300, 400, 600, 700)
      Inter             — body / UI (300, 400, 500)
    -->
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Global styles (Tailwind + design tokens) are imported in the
         frontmatter above via `import '../styles/global.css'` —
         Astro injects the compiled stylesheet automatically. -->

    <!-- ── Beds24 booking widget dependencies ────────────────────── -->
    <!-- jQuery must load before jQuery UI and bookWidget -->
    <script is:inline src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <script is:inline src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js" integrity="sha256-lSjKY0/srUM9BE3dPm+c4fBo1dky2v27Gdjm2uoZaL0=" crossorigin="anonymous"></script>
    <script is:inline src="https://media.xmlcal.com/widget/1.01/js/bookWidget.min.js"></script>
  </head>

  <body class="bg-brand-cream font-body text-brand-blue antialiased">

    <!-- Fixed navigation — sits above all content via z-50 -->
    <Nav />

    <!-- Page-specific content injected here -->
    <main>
      <slot />
    </main>

    <!-- Site footer -->
    <Footer />

  </body>
</html>
